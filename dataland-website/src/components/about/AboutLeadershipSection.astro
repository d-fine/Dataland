---
import SectionHeader from '../SectionHeader.astro';
import type { Person } from '../../data/about';

interface Content {
  title: string;
  intro: string;
}

interface Props {
  content: Content;
  people: Person[];
}

const { content, people } = Astro.props;

const sectionClass = 'scroll-mt-16 bg-[var(--color-brand-blue)] px-6 py-12 text-white lg:px-8 lg:py-16';

const innerClass = 'max-w-[1200px] mx-auto flex flex-col gap-10';
const headerClass = 'mx-auto max-w-[860px]';
const gridClass = 'grid grid-cols-1 gap-8 sm:grid-cols-2 md:grid-cols-3';

const cardClass = 'flex h-full flex-col items-center gap-1.5 text-center';
const imageClass = 'h-[430px] w-full max-w-[340px] rounded-2xl object-cover object-top';
const nameWrapClass = 'flex items-start justify-center';
const nameClass = 'm-0 text-[1.45rem] font-bold leading-tight';
const roleWrapClass = 'mt-[0.1rem] flex items-start justify-center';
const roleClass = 'm-0 text-[1.14rem] leading-tight opacity-85';
const bioWrapClass = 'mt-8 flex min-h-[5.6rem] max-w-[320px] items-start justify-center';
const bioClass = 'm-0 text-[1.14rem] leading-[1.5] opacity-80';
const linksClass = 'mt-0.5 flex gap-4';
const iconLinkClass =
  'inline-flex text-white opacity-70 motion-safe:transition-opacity motion-safe:duration-200 hover:opacity-100';
---

<section id="team" class={sectionClass} aria-label="Leadership team">
  <div class={innerClass}>
    <SectionHeader title={content.title} intro={content.intro} tone="light" class={headerClass} />

    <div class={gridClass}>
      {
        people.map((person) => (
          <div class={cardClass}>
            <img src={person.imagePath} alt={person.name} class={imageClass} loading="lazy" width="340" height="540" />

            <div class={nameWrapClass}>
              <h3 class={nameClass}>{person.name}</h3>
            </div>

            <div class={roleWrapClass}>
              <p class={roleClass}>{person.role}</p>
            </div>

            <div class={bioWrapClass}>
              <p class={bioClass}>{person.bio}</p>
            </div>

            <div class={linksClass}>
              <a href={person.email} aria-label={`Email ${person.name}`} class={iconLinkClass}>
                <svg
                  width="26"
                  height="26"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect x="2" y="4" width="20" height="16" rx="2" />
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                </svg>
              </a>

              <a
                href={person.linkedIn}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${person.name} on LinkedIn`}
                class={iconLinkClass}
              >
                <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

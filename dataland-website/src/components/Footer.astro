---
const currentYear = new Date().getFullYear();
---

<footer class="bg-[var(--color-surface-50)] text-[var(--color-text)]">
  <div class="max-w-[1280px] mx-auto px-6 pt-12 pb-8 grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-[1.5fr_1.2fr_0.8fr_0.8fr_1fr] lg:pt-16 lg:pb-12">
    <!-- Column 1: Dataland brand -->
    <div class="flex flex-col gap-4">
      <a href="/" class="inline-flex" aria-label="Dataland home">
        <img src="/static/logos/gfx_logo_dataland_orange_S.svg" alt="Dataland" width="140" height="32" loading="lazy" class="h-7 w-auto" />
      </a>
      <div class="flex items-center gap-2 text-sm text-[var(--color-text-muted)]">
        <span>A</span>
        <img src="/static/logos/footer_wertestiftung.png" alt="Werte-Stiftung" width="100" height="28" loading="lazy" class="h-5 w-auto object-contain" />
        <span>Company</span>
      </div>
    </div>

    <!-- Column 2: Tech Hub -->
    <div>
      <h3 class="text-sm font-bold uppercase tracking-wider m-0 mb-4 text-[var(--color-text)]">Tech Hub</h3>
      <ul class="list-none p-0 m-0 grid grid-cols-2 gap-x-6 gap-y-2.5">
        <li><a href="/api/swagger-ui/index.html" class="text-[var(--color-text-muted)] no-underline text-sm motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]">Datasets</a></li>
        <li><a href="/users/swagger-ui/index.html" class="text-[var(--color-text-muted)] no-underline text-sm motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]">Users</a></li>
        <li><a href="/documents/swagger-ui/index.html" class="text-[var(--color-text-muted)] no-underline text-sm motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]">Documents</a></li>
        <li><a href="/data-sourcing/swagger-ui/index.html" class="text-[var(--color-text-muted)] no-underline text-sm motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]">Data Sourcing</a></li>
        <li><a href="/community/swagger-ui/index.html" class="text-[var(--color-text-muted)] no-underline text-sm motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]">Community</a></li>
        <li><a href="/accounting/swagger-ui/index.html" class="text-[var(--color-text-muted)] no-underline text-sm motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]">Accounting</a></li>
        <li><a href="/qa/swagger-ui/index.html" class="text-[var(--color-text-muted)] no-underline text-sm motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]">Quality Assurance</a></li>
        <li><a href="/specifications/swagger-ui/index.html" class="text-[var(--color-text-muted)] no-underline text-sm motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]">Specifications</a></li>
      </ul>
    </div>

    <!-- Column 3: ESG Frameworks -->
    <div>
      <h3 class="text-sm font-bold uppercase tracking-wider m-0 mb-4 text-[var(--color-text)]">ESG Frameworks</h3>
      <ul class="list-none p-0 m-0 flex flex-col gap-2.5">
        <li><a href="https://github.com/d-fine/Dataland/wiki/Data-Framework-Documentation" target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-muted)] no-underline text-sm motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]">Overview</a></li>
      </ul>
    </div>

    <!-- Column 4: Follow Dataland -->
    <div>
      <h3 class="text-sm font-bold uppercase tracking-wider m-0 mb-4 text-[var(--color-text)]">Follow Dataland</h3>
      <ul class="list-none p-0 m-0 flex flex-col gap-2.5">
        <li>
          <a href="https://www.linkedin.com/company/dataland-gmbh/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-[var(--color-text-muted)] no-underline text-sm motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
            LinkedIn
          </a>
        </li>
      </ul>
    </div>

    <!-- Column 5: Integration -->
    <div>
      <h3 class="text-sm font-bold uppercase tracking-wider m-0 mb-4 text-[var(--color-text)]">Integration of</h3>
      <div class="flex items-center gap-5">
        <img src="/static/logos/footer_gleif.svg" alt="GLEIF" width="80" height="28" loading="lazy" class="h-7 w-auto object-contain" />
        <img src="/static/logos/footer_eurodat.svg" alt="EuroDaT" width="80" height="28" loading="lazy" class="h-7 w-auto object-contain" />
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-[var(--color-surface-200)]">
    <div class="max-w-[1280px] mx-auto px-6 py-5 flex flex-col gap-4 items-center lg:flex-row lg:justify-between">
      <div class="flex flex-wrap gap-5 items-center pl-16">
        <a href="/terms" class="text-[var(--color-text-muted)] no-underline text-[0.8125rem] min-h-[44px] min-w-[44px] inline-flex items-center motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]">Legal</a>
        <a href="/imprint" class="text-[var(--color-text-muted)] no-underline text-[0.8125rem] min-h-[44px] min-w-[44px] inline-flex items-center motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]">Imprint</a>
        <a href="/dataprivacy" class="text-[var(--color-text-muted)] no-underline text-[0.8125rem] min-h-[44px] min-w-[44px] inline-flex items-center motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]">Data Privacy</a>
        <button type="button" onclick="if(typeof Cookiebot !== 'undefined') Cookiebot.show()" class="text-[var(--color-text-muted)] text-[0.8125rem] bg-transparent border-none cursor-pointer p-0 font-[inherit] min-h-[44px] min-w-[44px] inline-flex items-center motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]">Cookie Settings</button>
      </div>
      <div class="flex items-center gap-4 text-[0.8125rem] text-[var(--color-text-muted)]">
        <span>&copy; {currentYear} Dataland</span>
      </div>
    </div>
  </div>
</footer>

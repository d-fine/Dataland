---
import CtaBand from '../primitives/CtaBand.astro';

interface Content {
  ctaTitle: string;
  buttons: {
    contact: string;
    try: string;
  };
}

interface Props {
  content: Content;
}

const { content } = Astro.props;

const sectionClass =
  'bg-[radial-gradient(circle_at_top_left,rgba(62,106,142,0.28),transparent_34%),linear-gradient(135deg,#091119_0%,#101922_38%,#172635_72%,#21384b_100%)] px-6 pb-10 text-white lg:px-8 lg:pb-12';

const sectionInnerClass = 'max-w-[1200px] mx-auto pt-8';

const buttonRowClass = 'flex flex-wrap justify-center gap-3';

const ctaTitleClass = 'text-white';

const primaryButtonClass = 'btn btn--orange';

const secondaryButtonClass = 'btn btn--white';
---

<section class={sectionClass} aria-label="Documentation call to action">
  <div class={sectionInnerClass}>
    <CtaBand title={content.ctaTitle} titleClass={ctaTitleClass}>
      <div class:list={[buttonRowClass, 'btn-group-equal']} data-equal-buttons>
        <a href="/about#contact" class={secondaryButtonClass}>{content.buttons.contact}</a>
        <a href="/register" class={primaryButtonClass}>{content.buttons.try}</a>
      </div>
    </CtaBand>
  </div>
</section>

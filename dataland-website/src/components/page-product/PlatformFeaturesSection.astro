---
import type { FeatureCard } from '../../data/product';
import SectionHeader from '../primitives/SectionHeader.astro';
import InfoCard from '../cards/InfoCard.astro';

interface Content {
  title: string;
  intro: string;
}

interface Props {
  content: Content;
  cards: FeatureCard[];
}

const { content, cards } = Astro.props;

const sectionClass = 'scroll-mt-16 py-12 px-6 bg-[var(--color-brand-blue)] text-white lg:py-16 lg:px-8';

const sectionInnerClass = 'max-w-[1200px] mx-auto flex flex-col gap-8';

const sectionHeaderClass = 'mx-auto max-w-[860px]';

const gridClass = 'grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3';

const infoCardClass = 'px-6 py-5';

const infoCardTitleClass = 'text-white';

const topAccentClass = 'mb-4 h-[3px] w-14 rounded-full bg-[var(--color-primary)]';

const textClass = 'card-text mt-4 text-white/82';
---

<section id="features" class={sectionClass} aria-label="Platform features">
  <div class={sectionInnerClass}>
    <SectionHeader title={content.title} intro={content.intro} tone="light" class={sectionHeaderClass} />
    <div class={gridClass}>
      {
        cards.map((card) => (
          <InfoCard variant="glass" title={card.title} titleClass={infoCardTitleClass} class={infoCardClass}>
            <div slot="before" class={topAccentClass} aria-hidden="true" />
            <p class={textClass}>{card.text}</p>
          </InfoCard>
        ))
      }
    </div>
  </div>
</section>

---
import type { GettingDataBlock } from '../../content/product';
import SectionHeader from '../primitives/SectionHeader.astro';
import CardShell from '../primitives/CardShell.astro';

interface Content {
  title: string;
  intro: string;
}

interface Props {
  content: Content;
  blocks: GettingDataBlock[];
}

const { content, blocks } = Astro.props;

const sectionClass = 'scroll-mt-16 py-12 px-6 bg-[var(--color-surface-0)] lg:py-16 lg:px-8';

const sectionInnerClass = 'max-w-[1200px] mx-auto flex flex-col gap-10';

const sectionHeaderClass = 'mx-auto max-w-[860px]';

const gridClass = 'grid grid-cols-1 gap-6 lg:grid-cols-2';

const cardClass =
  'grid h-full grid-rows-[3.4rem_0.7rem_1fr_2.5rem_2.5rem] rounded-xl p-6 shadow-[0_8px_24px_rgba(15,23,42,0.08)] motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-[0_12px_28px_rgba(15,23,42,0.12)]';

const titleClass = 'm-0 self-start text-left text-[1.45rem] font-bold leading-[1.12] text-[var(--color-text)]';

const textClass = 'card-text self-start text-left text-[var(--color-text-muted)]';

const accentBarWrapClass = 'flex items-start justify-start self-start -mt-1';

const accentBarClass = 'h-[3px] w-14 rounded-full bg-[var(--color-primary)]';

const highlightRowClass =
  'inline-flex w-full items-center justify-start gap-1.5 self-center text-left text-[1rem] font-semibold leading-[1.3] text-[var(--color-text-muted)]';

const highlightCheckClass =
  'inline-flex shrink-0 items-center justify-center text-[1.5rem] leading-none text-[var(--color-primary)]';

const checkMark = '\u2713';
---

<section id="getting-data" class={sectionClass} aria-label="Getting data">
  <div class={sectionInnerClass}>
    <SectionHeader title={content.title} intro={content.intro} class={sectionHeaderClass} />
    <div class={gridClass}>
      {
        blocks.map((block, index) => (
          <CardShell as="article" variant={index === 0 ? 'warm' : 'cool'} class={cardClass}>
            <h3 class={titleClass}>{block.title}</h3>
            <div class={accentBarWrapClass} aria-hidden="true">
              <div class={accentBarClass} />
            </div>
            <p class={textClass}>{block.text}</p>
            {block.highlights.map((highlight) => (
              <span class={highlightRowClass}>
                <span class={highlightCheckClass}>{checkMark}</span>
                {highlight}
              </span>
            ))}
          </CardShell>
        ))
      }
    </div>
  </div>
</section>

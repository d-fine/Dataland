---
import type { ProductApplicationArea, UseCase } from '../../data/product';
import SectionHeader from '../primitives/SectionHeader.astro';
import CardShell from '../primitives/CardShell.astro';
import ApplicationAreaCard from './ApplicationAreaCard.astro';

interface Content {
  title: string;
  intro: string;
  supportText: string;
}

interface Props {
  content: Content;
  useCases: UseCase[];
  applicationAreas: ProductApplicationArea[];
}

const { content, useCases, applicationAreas } = Astro.props;

const sectionClass = 'scroll-mt-16 py-12 px-6 bg-[var(--color-surface-50)] lg:py-16 lg:px-8';

const sectionInnerClass = 'max-w-[1200px] mx-auto flex flex-col gap-8';

const sectionHeaderClass = 'mx-auto max-w-[860px]';

const useCasesWrapClass = 'flex flex-col gap-8';

const cardsGridClass = 'grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3';

const useCaseCardClass =
  'grid h-full grid-rows-[4.5rem_1fr] items-start justify-items-start gap-1.5 rounded-xl p-6 pt-3 text-left shadow-[0_1px_4px_rgba(0,0,0,0.04)] motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-[0_4px_16px_rgba(0,0,0,0.08)]';

const useCaseHeaderClass = 'grid w-full grid-cols-[5.25rem_1fr] items-center gap-3';

const useCaseIconBaseClass =
  'h-[5.25rem] w-[5.25rem] object-contain [filter:brightness(0)_saturate(100%)_invert(35%)_sepia(18%)_saturate(1059%)_hue-rotate(167deg)_brightness(90%)_contrast(91%)]';

const portfolioIconClass = 'scale-[1.68]';

const complementIconClass = 'scale-[1.42]';

const formatUpdateIconClass = 'translate-x-3 scale-[1.36]';

const useCaseTitleClass = 'card-title text-[var(--color-text)] leading-[1.18]';

const useCaseTitleLineClass = 'block';

const useCaseDescriptionClass = 'card-text text-[var(--color-text-muted)]';

const supportWrapClass = 'flex flex-col gap-5 pt-2';

const supportTextClass =
  'mx-auto max-w-[760px] text-center text-[1.06rem] font-bold leading-relaxed m-0 text-[var(--color-text-muted)] lg:text-[1.12rem]';

const applicationGridClass = 'grid grid-cols-2 gap-4 md:grid-cols-3 xl:grid-cols-6';
---

<section id="use-cases" class={sectionClass} aria-label="Use cases">
  <div class={sectionInnerClass}>
    <SectionHeader title={content.title} intro={content.intro} class={sectionHeaderClass} />
    <div class={useCasesWrapClass}>
      <div class={cardsGridClass}>
        {
          useCases.map((uc) => (
            <CardShell class={useCaseCardClass} accentTop={true}>
              <div class={useCaseHeaderClass}>
                <img
                  src={uc.icon}
                  alt=""
                  aria-hidden="true"
                  width="88"
                  height="88"
                  loading="lazy"
                  class:list={[
                    useCaseIconBaseClass,
                    uc.icon === '/static/product/use_cases/img_use_case_portfolio_monitoring.png' && portfolioIconClass,
                    uc.icon === '/static/product/use_cases/img_use_case_complement.png' && complementIconClass,
                    uc.icon === '/static/product/use_cases/img_use_case_format_update.png' && formatUpdateIconClass,
                  ]}
                />
                <h3 class={useCaseTitleClass}>
                  {(uc.titleLines ?? [uc.title]).map((line) => (
                    <span class={useCaseTitleLineClass}>{line}</span>
                  ))}
                </h3>
              </div>
              <p class={useCaseDescriptionClass}>{uc.description}</p>
            </CardShell>
          ))
        }
      </div>
      <div class={supportWrapClass}>
        <p class={supportTextClass}>{content.supportText}</p>
        <div class={applicationGridClass}>
          {
            applicationAreas.map((area) => (
              <ApplicationAreaCard icon={area.icon} titleLines={[...area.titleLines] as [string, string]} />
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

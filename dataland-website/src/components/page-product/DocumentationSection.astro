---
import type { DocumentationLink } from '../../content/product';
import SectionHeader from '../primitives/SectionHeader.astro';
import ArrowLink from '../primitives/ArrowLink.astro';
import CardShell from '../primitives/CardShell.astro';

interface FrameworkDocContent {
  url: string;
  description: string;
}

interface Content {
  title: string;
  intro: string;
  frameworkGuideTitle: string;
  frameworkGuideLink: string;
  apiReferenceTitle: string;
  apiReferenceDescription: string;
}

interface Props {
  content: Content;
  frameworkDoc: FrameworkDocContent;
  apiLinks: DocumentationLink[];
}

const { content, frameworkDoc, apiLinks } = Astro.props;

const sectionClass =
  'scroll-mt-16 bg-[radial-gradient(circle_at_top_left,rgba(62,106,142,0.28),transparent_34%),linear-gradient(135deg,#091119_0%,#101922_38%,#172635_72%,#21384b_100%)] px-6 py-16 text-white lg:px-8 lg:py-20';

const sectionInnerClass = 'max-w-[1200px] mx-auto flex flex-col items-center gap-12';

const sectionHeaderClass = 'mx-auto max-w-[860px]';

const cardsGridClass = 'grid grid-cols-1 gap-6 w-full md:grid-cols-[1fr_1.5fr] md:items-stretch';

const frameworkCardClass = 'relative flex flex-col justify-between gap-6 overflow-hidden rounded-[1.5rem] p-7 lg:p-9';

const apiCardClass =
  'flex flex-col justify-between gap-6 rounded-[1.5rem] p-7 shadow-[0_20px_50px_rgba(0,0,0,0.22)] lg:p-9';

const cardTitleClass = 'card-title text-white';

const cardBodyClass = 'flex flex-col gap-4';

const cardTextClass = 'card-text min-h-[3.25rem] text-white/74';

const githubMarkClass =
  'pointer-events-none absolute right-8 top-[9.8rem] hidden h-34 w-34 object-contain opacity-92 md:block lg:right-10 lg:top-[10.8rem] lg:h-48 lg:w-48';

const apiLinksGridClass = 'grid grid-cols-1 gap-3 sm:grid-cols-2';

const apiLinkClass =
  'inline-flex items-center gap-2 rounded-xl border border-white/12 bg-white/8 px-4 py-3 text-sm font-medium text-white/90 no-underline motion-safe:transition-colors motion-safe:duration-150 hover:bg-white/12 hover:text-white';

const frameworkGuideLinkClass = 'self-start';

const apiLinkDotClass = 'w-1.5 h-1.5 rounded-full bg-[var(--color-primary)] shrink-0';
---

<section id="documentation" class={sectionClass} aria-label="Documentation and API references">
  <div class={sectionInnerClass}>
    <SectionHeader title={content.title} intro={content.intro} tone="light" class={sectionHeaderClass} />

    <div class={cardsGridClass}>
      <CardShell variant="glass" class={frameworkCardClass}>
        <div class={cardBodyClass}>
          <h3 class={cardTitleClass}>{content.frameworkGuideTitle}</h3>
          <p class={cardTextClass}>{frameworkDoc.description}</p>
        </div>
        <img
          src="/static/logos/logo_other_GitHub_Invertocat_White.png"
          alt=""
          aria-hidden="true"
          width="200"
          height="200"
          class={githubMarkClass}
        />
        <ArrowLink href={frameworkDoc.url} target="_blank" rel="noopener noreferrer" class={frameworkGuideLinkClass}>
          {content.frameworkGuideLink} &rarr;
        </ArrowLink>
      </CardShell>

      <CardShell variant="glass" class={apiCardClass}>
        <div class={cardBodyClass}>
          <h3 class={cardTitleClass}>{content.apiReferenceTitle}</h3>
          <p class={cardTextClass}>{content.apiReferenceDescription}</p>
        </div>
        <div class={apiLinksGridClass}>
          {
            apiLinks.map((doc) => (
              <a href={doc.url} target="_blank" rel="noopener noreferrer" class={apiLinkClass}>
                <span class={apiLinkDotClass} aria-hidden="true" />
                {doc.label}
              </a>
            ))
          }
        </div>
      </CardShell>
    </div>
  </div>
</section>

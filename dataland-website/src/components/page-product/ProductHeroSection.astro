---
interface HeroContent {
  titleLeading: string;
  titleAccent: string;
  buttons: {
    try: string;
    demo: string;
    contact: string;
  };
}

interface Props {
  content: HeroContent;
}

const { content } = Astro.props;

const sectionClass =
  'bg-[linear-gradient(90deg,#020408_0%,#08111b_24%,#142231_52%,#27435d_82%,#345877_100%)] px-6 pt-26 pb-12 text-white lg:px-8 lg:pt-30 lg:pb-16';
const sectionInnerClass = 'max-w-[1200px] mx-auto grid grid-cols-1 gap-10 lg:grid-cols-[48%_52%] lg:items-stretch';

const textColumnClass = 'flex h-full flex-col lg:pr-4 lg:pt-1';

const titleClass = 'page-title text-white leading-[1.05] lg:text-[2.35rem]';

const titleAccentClass = 'text-[var(--color-primary)]';

const arrowsWrapClass = 'flex flex-1 items-center justify-center py-6';

const arrowsRowClass = 'flex w-full max-w-[36rem] items-center justify-center gap-12 lg:gap-16';

const textBlockClass = 'flex flex-1 flex-col';

const arrowImageBaseClass = 'h-[11rem] w-auto';

const arrowImageSoftClass = `${arrowImageBaseClass} opacity-65 saturate-[0.45]`;

const arrowImageMidClass = `${arrowImageBaseClass} opacity-82 saturate-[0.72]`;

const buttonRowClass = 'mt-auto flex flex-wrap gap-3';

const primaryButtonClass = 'btn btn--orange';

const secondaryButtonClass = 'btn btn--white';

const imageWrapClass = 'flex min-h-[320px] justify-center lg:min-h-[460px] lg:justify-end';

const imageClass =
  'h-full w-full max-w-[720px] rounded-[1.5rem] object-cover shadow-[0_20px_55px_rgba(0,0,0,0.28)] lg:max-w-none';
---

<section class={sectionClass} aria-label="Product introduction">
  <div class={sectionInnerClass}>
    <div class={textColumnClass}>
      <div class={textBlockClass}>
        <h1 class={titleClass}>
          {content.titleLeading}
          <br />
          <span class={titleAccentClass}>{content.titleAccent}</span>
        </h1>
        <div class={arrowsWrapClass}>
          <div class={arrowsRowClass} aria-hidden="true">
            <img
              src="/static/images/arrow_right_orange_simple.svg"
              alt=""
              width="30"
              height="45"
              class={arrowImageSoftClass}
            />
            <img
              src="/static/images/arrow_right_orange_simple.svg"
              alt=""
              width="30"
              height="45"
              class={arrowImageMidClass}
            />
            <img
              src="/static/images/arrow_right_orange_simple.svg"
              alt=""
              width="30"
              height="45"
              class={arrowImageBaseClass}
            />
          </div>
        </div>
      </div>
      <div class:list={[buttonRowClass, 'btn-group-equal']} data-equal-buttons>
        <a href="/register" class={primaryButtonClass}>{content.buttons.try}</a>
        <a href="/about#contact" class={secondaryButtonClass}>{content.buttons.demo}</a>
        <a href="/about#contact" class={secondaryButtonClass}>{content.buttons.contact}</a>
      </div>
    </div>
    <div class={imageWrapClass}>
      <img
        src="/static/images/platform-screenshot.png"
        alt="Dataland platform showing structured company-level sustainability data"
        width="720"
        height="520"
        loading="eager"
        class={imageClass}
        style="object-position: -2px -2px;"
      />
    </div>
  </div>
</section>

---
import type { CreditCostRow, PricingFeatureItemData } from '../../data/product';
import SectionHeader from '../primitives/SectionHeader.astro';
import CtaBand from '../primitives/CtaBand.astro';
import AnnualMembershipPanel from '../panels/AnnualMembershipPanel.astro';
import SharedCostPanel from '../panels/SharedCostPanel.astro';

interface Content {
  title: string;
  intro: string;
  annualMembership: {
    title: string;
    price: string;
    intro: string;
  };
  sharedCost: {
    title: string;
    intro: string;
    footnote: string;
    highlight: string;
    membersHeader: string;
    costHeader: string;
  };
  ctaTitle: string;
  buttons: {
    contact: string;
    try: string;
  };
}

interface Props {
  content: Content;
  membershipItems: PricingFeatureItemData[];
  sharedCostItems: PricingFeatureItemData[];
  creditRows: CreditCostRow[];
}

const { content, membershipItems, sharedCostItems, creditRows } = Astro.props;

const sectionClass = 'scroll-mt-16 py-12 px-6 bg-[var(--color-brand-blue)] lg:py-20 lg:px-8';

const sectionInnerClass = 'max-w-[1200px] mx-auto flex flex-col gap-12';

const sectionHeaderClass = 'items-center text-center';

const panelsWrapClass = 'flex flex-col gap-4';

const ctaButtonsClass = 'flex flex-wrap justify-center gap-3';

const ctaTitleClass = 'max-w-[46rem] text-white';

const primaryButtonClass = 'btn btn--primary';

const secondaryButtonClass = 'btn btn--outline';

const ctaBandClass = 'pt-7';
---

<section id="membership-pricing" class={sectionClass} aria-label="Membership and pricing">
  <div class={sectionInnerClass}>
    <SectionHeader title={content.title} intro={content.intro} tone="light" class={sectionHeaderClass} />

    <div class={panelsWrapClass}>
      <AnnualMembershipPanel
        title={content.annualMembership.title}
        price={content.annualMembership.price}
        intro={content.annualMembership.intro}
        items={membershipItems}
      />
      <SharedCostPanel
        title={content.sharedCost.title}
        intro={content.sharedCost.intro}
        footnote={content.sharedCost.footnote}
        highlight={content.sharedCost.highlight}
        membersHeader={content.sharedCost.membersHeader}
        costHeader={content.sharedCost.costHeader}
        items={sharedCostItems}
        rows={creditRows}
      />
    </div>

    <CtaBand title={content.ctaTitle} titleClass={ctaTitleClass} class={ctaBandClass}>
      <div class={ctaButtonsClass}>
        <a href="/about#contact" class={secondaryButtonClass}>{content.buttons.contact}</a>
        <a href="/register" class={primaryButtonClass}>{content.buttons.try}</a>
      </div>
    </CtaBand>
  </div>
</section>

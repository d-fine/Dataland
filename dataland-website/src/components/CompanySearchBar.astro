---
// No server-side props needed — all logic runs in the browser
---

<div class="relative w-full max-w-[520px]" id="company-search-root">
  <svg
    class="absolute left-4 top-1/2 -translate-y-1/2 text-white/50 pointer-events-none"
    aria-hidden="true"
    width="20"
    height="20"
    viewBox="0 0 20 20"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      d="M17.5 17.5L13.875 13.875M15.8333 9.16667C15.8333 12.8486 12.8486 15.8333 9.16667 15.8333C5.48477 15.8333 2.5 12.8486 2.5 9.16667C2.5 5.48477 5.48477 2.5 9.16667 2.5C12.8486 2.5 15.8333 5.48477 15.8333 9.16667Z"
      stroke="currentColor"
      stroke-width="1.67"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  </svg>
  <input
    id="company-search-input"
    type="text"
    placeholder="Search by company name or LEI..."
    class="w-full py-3.5 pr-4 pl-11 border-[1.5px] border-white/20 rounded-lg text-base font-[var(--font-family)] text-[var(--color-text)] bg-white box-border placeholder:text-[var(--color-text-muted)]"
    aria-label="Search by company name or LEI"
    aria-autocomplete="list"
    aria-expanded="false"
    aria-controls="company-search-listbox"
    autocomplete="off"
  />
  <ul
    id="company-search-listbox"
    role="listbox"
    class="absolute z-50 mt-1 w-full bg-white border border-gray-200 rounded-lg shadow-lg overflow-y-auto max-h-[264px] hidden"
  ></ul>
  <p id="company-search-warning" class="mt-1.5 text-xs text-red-500 hidden" role="alert">
    Please type at least 3 characters.
  </p>
</div>

<script>
  const DEBOUNCE_MS = 300;
  const MIN_LENGTH_WARNING_MS = 1000;
  const RESULT_LIMIT = 100;

  const input = document.getElementById('company-search-input') as HTMLInputElement;
  const listbox = document.getElementById('company-search-listbox') as HTMLUListElement;
  const warning = document.getElementById('company-search-warning') as HTMLParagraphElement;

  interface CompanyIdAndName {
    companyId: string;
    companyName: string;
  }

  let suggestions: CompanyIdAndName[] = [];
  let activeIndex = -1;
  let debounceTimer = 0;
  let minLengthWarningTimer = 0;

  function escapeRegex(s: string): string {
    return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  function highlight(name: string, search: string): string {
    if (!search) return name;
    return name.replace(
      new RegExp(`(${escapeRegex(search)})`, 'gi'),
      '<mark class="bg-yellow-100 text-inherit rounded-sm">$1</mark>'
    );
  }

  function renderSuggestions(): void {
    if (suggestions.length === 0) {
      listbox.classList.add('hidden');
      listbox.innerHTML = '';
      input.setAttribute('aria-expanded', 'false');
      return;
    }

    const search = input.value.trim();
    const items = suggestions.map((company, index) => {
      const li = document.createElement('li');
      li.setAttribute('role', 'option');
      li.setAttribute('aria-selected', String(index === activeIndex));
      li.className = [
        'px-4 py-2.5 cursor-pointer text-sm text-gray-800 flex items-center gap-2',
        index === activeIndex ? 'bg-gray-100' : 'hover:bg-gray-50',
      ].join(' ');
      li.innerHTML = `
        <svg class="shrink-0 text-gray-400" width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M17.5 17.5L13.875 13.875M15.8333 9.16667C15.8333 12.8486 12.8486 15.8333 9.16667 15.8333C5.48477 15.8333 2.5 12.8486 2.5 9.16667C2.5 5.48477 5.48477 2.5 9.16667 2.5C12.8486 2.5 15.8333 5.48477 15.8333 9.16667Z"
            stroke="currentColor" stroke-width="1.67" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>${highlight(company.companyName, search)}</span>
      `;
      li.addEventListener('mousedown', (e) => {
        e.preventDefault();
        selectCompany(company);
      });
      return li;
    });

    if (suggestions.length >= RESULT_LIMIT) {
      const footer = document.createElement('li');
      footer.className = 'px-4 py-2 text-xs text-gray-500 font-medium border-t border-gray-100';
      footer.setAttribute('aria-live', 'polite');
      footer.textContent = `Only showing ${RESULT_LIMIT} results, please refine your query.`;
      items.push(footer);
    }

    listbox.replaceChildren(...items);
    listbox.classList.remove('hidden');
    input.setAttribute('aria-expanded', 'true');
  }

  function selectCompany(company: CompanyIdAndName): void {
    window.location.href = `/companies/${company.companyId}`;
  }

  async function fetchSuggestions(searchString: string): Promise<CompanyIdAndName[]> {
    const params = new URLSearchParams({ searchString, resultLimit: String(RESULT_LIMIT) });
    const response = await fetch(`${window.location.origin}/api/companies/names?${params}`);
    if (!response.ok) {
      console.error(`Company search failed: ${response.status} ${response.statusText}`);
      return [];
    }
    return response.json() as Promise<CompanyIdAndName[]>;
  }

  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    clearTimeout(minLengthWarningTimer);

    const trimmed = input.value.trim();

    if (trimmed.length === 0) {
      suggestions = [];
      activeIndex = -1;
      warning.classList.add('hidden');
      renderSuggestions();
      return;
    }

    if (trimmed.length < 3) {
      suggestions = [];
      activeIndex = -1;
      renderSuggestions();
      minLengthWarningTimer = window.setTimeout(() => {
        warning.classList.remove('hidden');
      }, MIN_LENGTH_WARNING_MS);
      return;
    }

    warning.classList.add('hidden');
    debounceTimer = window.setTimeout(async () => {
      suggestions = await fetchSuggestions(trimmed);
      activeIndex = -1;
      renderSuggestions();
    }, DEBOUNCE_MS);
  });

  input.addEventListener('keydown', (event) => {
    if (suggestions.length === 0) return;

    if (event.key === 'ArrowDown') {
      event.preventDefault();
      activeIndex = Math.min(activeIndex + 1, suggestions.length - 1);
      renderSuggestions();
    } else if (event.key === 'ArrowUp') {
      event.preventDefault();
      activeIndex = Math.max(activeIndex - 1, -1);
      renderSuggestions();
    } else if (event.key === 'Enter' && activeIndex >= 0) {
      event.preventDefault();
      selectCompany(suggestions[activeIndex]);
    } else if (event.key === 'Escape') {
      suggestions = [];
      activeIndex = -1;
      renderSuggestions();
    }
  });

  input.addEventListener('blur', () => {
    setTimeout(() => {
      suggestions = [];
      activeIndex = -1;
      renderSuggestions();
    }, 150);
  });
</script>


---
import type { ProblemSolutionPair } from '../../data/whyUs';
import SectionHeader from '../primitives/SectionHeader.astro';

interface Content {
  title: string;
  intro: string;
  buttons: {
    features: string;
    useCases: string;
    contact: string;
  };
}

interface Props {
  content: Content;
  pairs: ProblemSolutionPair[];
}

const { content, pairs } = Astro.props;

const sectionClass = 'py-12 px-6 bg-[var(--color-surface-50)] lg:py-16 lg:px-8';

const sectionInnerClass = 'max-w-[1200px] mx-auto flex flex-col gap-10';

const sectionHeaderClass = 'mx-auto max-w-[860px]';

const pairsListClass = 'flex flex-col gap-8';

const pairCardClass =
  'grid grid-cols-1 gap-4 overflow-hidden rounded-[1.5rem] border border-[var(--color-surface-200)] bg-[linear-gradient(90deg,#eef1f4_0%,#f8f7f4_38%,#fff3ea_70%,#ffe6d6_100%)] shadow-[0_12px_32px_rgba(15,23,42,0.06)] lg:grid-cols-[1fr_auto_1fr] lg:grid-rows-[auto_auto_auto] lg:gap-x-0 lg:gap-y-0';

const problemLabelClass = 'text-[0.82rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-label-muted)]';

const solutionLabelClass = 'text-[0.82rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-label-warm)]';

const problemLabelWrapClass = 'px-6 pt-4 pb-1 lg:px-7 lg:pt-5 lg:pb-1.5 lg:row-start-1 lg:col-start-1';

const problemTitleWrapClass = 'px-6 pb-3 lg:px-7 lg:pb-4 lg:row-start-2 lg:col-start-1';

const problemTitleClass = 'card-title text-[var(--color-text)]';

const problemTextWrapClass = 'px-6 pb-6 lg:px-7 lg:pb-7 lg:row-start-3 lg:col-start-1';

const bodyTextClass = 'card-text text-[var(--color-text-muted)]';

const arrowWrapClass = 'hidden lg:flex lg:row-span-3 lg:col-start-2 items-center justify-center px-3';

const mobileDividerClass = 'h-px bg-[var(--color-surface-200)] lg:hidden';

const solutionLabelWrapClass = 'px-6 pt-4 pb-1 lg:px-7 lg:pt-5 lg:pb-1.5 lg:row-start-1 lg:col-start-3';

const solutionTitleWrapClass = 'px-6 pb-3 lg:px-7 lg:pb-4 lg:row-start-2 lg:col-start-3';

const solutionTitleClass = 'card-title text-[var(--color-primary)]';

const solutionTextWrapClass = 'px-6 pb-6 lg:px-7 lg:pb-7 lg:row-start-3 lg:col-start-3';

const ctaRowClass = 'flex flex-wrap gap-3 justify-center';

const primaryButtonClass = 'btn btn--orange';

const secondaryButtonClass = 'btn btn--white';
---

<section id="why-us" class={sectionClass} aria-label="Why financial institutions choose Dataland">
  <div class={sectionInnerClass}>
    <SectionHeader title={content.title} intro={content.intro} class={sectionHeaderClass} />

    <div class={pairsListClass}>
      {
        pairs.map((pair) => (
          <div class={pairCardClass}>
            <div class={problemLabelWrapClass}>
              <span class={problemLabelClass}>Common Problems</span>
            </div>
            <div class={problemTitleWrapClass}>
              <h3 class={problemTitleClass}>{pair.problemTitle}</h3>
            </div>
            <div class={problemTextWrapClass}>
              <p class={bodyTextClass}>{pair.problemText}</p>
            </div>
            <div class={arrowWrapClass} aria-hidden="true">
              <img src="/static/images/arrow_right_orange_simple.svg" alt="" width="42" height="42" />
            </div>
            <div class={mobileDividerClass} aria-hidden="true" />
            <div class={solutionLabelWrapClass}>
              <span class={solutionLabelClass}>Dataland Solution</span>
            </div>
            <div class={solutionTitleWrapClass}>
              <h3 class={solutionTitleClass}>{pair.solutionTitle}</h3>
            </div>
            <div class={solutionTextWrapClass}>
              <p class={bodyTextClass}>{pair.solutionText}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class={ctaRowClass}>
      <a href="/product#features" class={primaryButtonClass}>{content.buttons.features}</a>
      <a href="/product#use-cases" class={secondaryButtonClass}>{content.buttons.useCases}</a>
      <a href="/about#contact" class={secondaryButtonClass}>{content.buttons.contact}</a>
    </div>
  </div>
</section>

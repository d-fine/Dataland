---
import type { MemberLogo } from '../../config/logos';
import SectionHeader from '../primitives/SectionHeader.astro';

interface Content {
  title: string;
  intro: string;
}

interface Props {
  content: Content;
  logos: MemberLogo[];
}

const { content, logos } = Astro.props;
const membersCarousel: MemberLogo[] = [...logos, ...logos];

const sectionClass = 'py-12 px-6 bg-[var(--color-surface-0)] lg:py-16 lg:px-8';

const sectionInnerClass = 'max-w-[1200px] mx-auto flex flex-col items-center gap-12 lg:gap-14';

const sectionHeaderClass = 'mx-auto max-w-[860px]';

const marqueeClass =
  'trusted-by-marquee w-full overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_10%,black_90%,transparent)]';

const trackClass = 'trusted-by-track flex w-max items-center gap-5 lg:gap-7';

const logoLinkBaseClass = 'flex h-28 w-52 shrink-0 items-center justify-center px-4 py-3 lg:h-32 lg:w-60 lg:px-5';

const logoFrameWrapClass =
  'flex h-[3.75rem] w-full max-w-[9.75rem] items-center justify-center lg:h-[4.25rem] lg:max-w-[10.5rem]';

const logoFrameClass = 'flex h-full w-full items-center justify-center';

const logoImageBaseClass =
  'block max-h-full max-w-full object-contain opacity-85 grayscale-[20%] motion-safe:transition-[opacity,filter,transform] motion-safe:duration-200 hover:opacity-100 hover:grayscale-0';
---

<section class={sectionClass} aria-label="Trusted by leading financial institutions">
  <div class={sectionInnerClass}>
    <SectionHeader title={content.title} intro={content.intro} class={sectionHeaderClass} />
    <div class={marqueeClass}>
      <div class={trackClass}>
        {
          membersCarousel.map((logo, index) => (
            <a
              href="/network#our-members"
              class:list={[logoLinkBaseClass, logo.carouselContainerClassName]}
              aria-label={`See ${logo.name} on the community page`}
            >
              <div class={logoFrameWrapClass}>
                <div class:list={[logoFrameClass, logo.imageFrameClassName]}>
                  <img
                    src={logo.imagePath}
                    alt={logo.name}
                    class:list={[logoImageBaseClass, logo.className]}
                    style={`transform: scale(${logo.scale ?? 1}); transform-origin: center;`}
                    loading={index < logos.length ? 'eager' : 'lazy'}
                    width="176"
                    height="80"
                  />
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .trusted-by-track {
    animation: trusted-by-scroll 84s linear infinite;
  }

  .trusted-by-marquee:hover .trusted-by-track {
    animation-play-state: paused;
  }

  @keyframes trusted-by-scroll {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .trusted-by-track {
      animation: none;
    }
  }
</style>

---
import YouTubeEmbed from '../media/YouTubeEmbed.astro';
import type { Testimonial } from '../../content/testimonials';
import ArrowLink from '../primitives/ArrowLink.astro';

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;

const sectionClass = 'pt-8 pb-12 px-6 bg-[var(--color-surface-0)] lg:pt-10 lg:pb-16 lg:px-8';
const sectionInnerClass = 'max-w-[1200px] mx-auto';
const gridClass = 'grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3';
const cardClass = 'flex flex-col gap-4';
const metaWrapClass = 'flex flex-col gap-0.5';
const authorClass = 'text-base font-bold m-0 text-[var(--color-text)]';
const affiliationClass = 'text-sm m-0 text-[var(--color-text-muted)]';
const linkWrapClass = 'mt-10 flex';
---

<section class={sectionClass} aria-label="Testimonial videos">
  <div class={sectionInnerClass}>
    <div class={gridClass}>
      {
        testimonials.map((t) => (
          <div class={cardClass}>
            <YouTubeEmbed videoId={t.youtubeId} title={`${t.author} - ${t.affiliation}`} />
            <div class={metaWrapClass}>
              <p class={authorClass}>{t.author}</p>
              <p class={affiliationClass}>{t.affiliation}</p>
            </div>
          </div>
        ))
      }
    </div>
    <div class={linkWrapClass}>
      <ArrowLink href="/">&larr; Back to Main</ArrowLink>
    </div>
  </div>
</section>

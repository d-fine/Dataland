---
import CardShell from './CardShell.astro';

interface Props {
  as?: string;
  href?: string;
  class?: string;
  title: string;
  text?: string;
  accentTop?: boolean;
  variant?: 'light' | 'warm' | 'cool' | 'dark' | 'glass';
  [key: string]: unknown;
}

const { as = 'div', href, class: className, title, text, accentTop = true, variant = 'light', ...rest } = Astro.props;
---

<CardShell
  as={as}
  href={href}
  variant={variant}
  accentTop={accentTop}
  class:list={['flex h-full flex-col overflow-hidden text-[var(--color-text)]', className]}
  {...rest}
>
  <slot name="media" />
  <div class="flex h-full flex-col gap-4 p-6">
    <slot name="meta" />
    <div class="flex flex-col gap-1.5">
      <h3 class="card-title font-medium text-[var(--color-text)]">{title}</h3>
      {text && <p class="card-text text-[var(--color-text-muted)]">{text}</p>}
    </div>
    <slot />
  </div>
</CardShell>

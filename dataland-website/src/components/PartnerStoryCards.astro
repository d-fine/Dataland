---
import type { PartnerStorySummary } from '../data/partnerStories';

interface Props {
  stories: PartnerStorySummary[];
  title?: string;
  intro?: string;
  sectionClass?: string;
}

const {
  stories,
  title = 'Our partners',
  intro,
  sectionClass = 'scroll-mt-16 py-12 px-6 bg-[var(--color-surface-50)] lg:py-16 lg:px-8',
} = Astro.props;
---

<section id="partners" class={sectionClass} aria-label={title}>
  <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
    <div class="flex flex-col gap-3 text-center">
      <h2 class="text-[1.75rem] font-bold m-0 text-[var(--color-text)]">{title}</h2>
      {
        intro && (
          <p class="mx-auto max-w-[760px] text-[0.9375rem] leading-relaxed m-0 text-[var(--color-text-muted)]">
            {intro}
          </p>
        )
      }
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {
        stories.map((story) => (
          <a
            href={story.link}
            class="flex h-full flex-col overflow-hidden rounded-xl border border-[var(--color-surface-200)] border-t-4 border-t-[var(--color-primary)] bg-[#ecece7] text-[var(--color-text)] no-underline shadow-[0_6px_18px_rgba(15,23,42,0.08)] motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-[0_8px_22px_rgba(15,23,42,0.12)]"
          >
            <div class="flex min-h-[6.25rem] items-center justify-center overflow-hidden bg-white px-6 py-5">
              <div class:list={story.darkLogoFrame ? 'rounded-[0.35rem] bg-[#111111] px-3 py-[0.45rem]' : undefined}>
                <img
                  src={story.logo}
                  alt=""
                  class:list={['h-16 w-full object-contain object-center', story.logoClassName]}
                  loading="lazy"
                  width="220"
                  height="64"
                />
              </div>
            </div>
            <div class="flex h-full flex-col gap-4 p-6">
              <div class="flex flex-col gap-1.5">
                <h3 class="m-0 min-h-[2.35rem] text-[1.14rem] font-medium leading-snug text-[var(--color-text)]">{story.title}</h3>
                <p class="m-0 text-[0.9375rem] leading-relaxed text-[var(--color-text-muted)]">{story.text}</p>
              </div>
              <span class="mt-auto text-sm font-semibold text-[var(--color-primary)]">Read more &rarr;</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

---
import type { PartnerStorySummary } from '../data/partnerStories';
import SectionHeader from './SectionHeader.astro';
import StoryCard from './StoryCard.astro';

interface Props {
  stories: PartnerStorySummary[];
  title?: string;
  intro?: string;
  sectionClass?: string;
}

const {
  stories,
  title = 'Our partners',
  intro,
  sectionClass = 'scroll-mt-16 py-12 px-6 bg-[var(--color-surface-50)] lg:py-16 lg:px-8',
} = Astro.props;
---

<section id="partners" class={sectionClass} aria-label={title}>
  <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
    <SectionHeader title={title} intro={intro} class="mx-auto max-w-[760px]" />

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {
        stories.map((story) => (
          <StoryCard
            as="a"
            href={story.link}
            title={story.title}
            text={story.text}
            class="bg-[#ecece7] no-underline shadow-[0_6px_18px_rgba(15,23,42,0.08)] motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-[0_8px_22px_rgba(15,23,42,0.12)]"
          >
            <div
              slot="media"
              class="flex min-h-[6.25rem] items-center justify-center overflow-hidden bg-white px-6 py-5"
            >
              <div class:list={story.darkLogoFrame ? 'rounded-[0.35rem] bg-[#111111] px-3 py-[0.45rem]' : undefined}>
                <img
                  src={story.logo}
                  alt=""
                  class:list={['h-16 w-full object-contain object-center', story.logoClassName]}
                  loading="lazy"
                  width="220"
                  height="64"
                />
              </div>
            </div>
            <span class="mt-auto text-[1.06rem] font-semibold text-[var(--color-primary)]">Read more &rarr;</span>
          </StoryCard>
        ))
      }
    </div>
  </div>
</section>

---
import type { PartnerStorySummary } from '../data/partnerStories';

interface Props {
  stories: PartnerStorySummary[];
  title?: string;
  intro?: string;
  sectionClass?: string;
}

const {
  stories,
  title = 'Our partners',
  intro,
  sectionClass = 'scroll-mt-16 py-12 px-6 bg-[var(--color-surface-50)] lg:py-16 lg:px-8',
} = Astro.props;
---

<section id="partners" class={sectionClass} aria-label={title}>
  <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
    <div class="flex flex-col gap-3 text-center">
      <h2 class="text-[1.75rem] font-bold m-0 text-[var(--color-text)]">{title}</h2>
      {intro && <p class="mx-auto max-w-[760px] text-[0.9375rem] leading-relaxed m-0 text-[var(--color-text-muted)]">{intro}</p>}
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {stories.map((story) => (
        <a href={story.link} class="flex h-full flex-col overflow-hidden rounded-xl border border-[#9FB2C3] bg-[#C8D5E0] text-[var(--color-text)] no-underline shadow-[0_8px_24px_rgba(15,23,42,0.06)] motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-[0_14px_30px_rgba(15,23,42,0.1)]">
          <div class="flex min-h-[8.75rem] items-center justify-center overflow-hidden bg-[var(--color-surface-50)] px-4 py-5">
            <div class:list={story.darkLogoFrame ? 'rounded-[0.35rem] bg-[#111111] px-3 py-[0.45rem]' : undefined}>
              <img
                src={story.logo}
                alt=""
                class:list={['h-20 w-full object-contain object-center lg:h-24', story.logoClassName]}
                loading="lazy"
                width="320"
                height="120"
              />
            </div>
          </div>
          <div class="flex h-full flex-col justify-between gap-5 bg-[#C8D5E0] p-6 lg:p-8">
            <div class="flex flex-col gap-3">
              <h3 class="m-0 text-[1.2rem] font-bold leading-tight text-[var(--color-text)]">{story.title}</h3>
              <p class="m-0 text-[0.98rem] leading-relaxed text-[var(--color-text-muted)]">{story.text}</p>
            </div>
            <span class="text-sm font-semibold text-[var(--color-primary)]">Read more &rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

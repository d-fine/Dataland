---
import type { PartnerStorySummary } from '../data/partnerStories';

interface Props {
  stories: PartnerStorySummary[];
  title?: string;
  intro?: string;
  sectionClass?: string;
}

const {
  stories,
  title = 'Our partners',
  intro,
  sectionClass = 'scroll-mt-16 py-12 px-6 bg-[var(--color-surface-50)] lg:py-16 lg:px-8',
} = Astro.props;
---

<section id="partners" class={sectionClass} aria-label={title}>
  <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
    <div class="flex flex-col gap-3 text-center">
      <h2 class="text-[1.75rem] font-bold m-0 text-[var(--color-text)]">{title}</h2>
      {intro && <p class="mx-auto max-w-[760px] text-[0.9375rem] leading-relaxed m-0 text-[var(--color-text-muted)]">{intro}</p>}
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">
      {stories.map((story) => (
        <a href={story.link} class="flex h-full flex-col overflow-hidden rounded-xl border-[3px] border-[#EAF2F8] bg-[#EAF2F8] text-[var(--color-text)] no-underline motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-[0_4px_16px_rgba(0,0,0,0.08)]">
          <div class="flex min-h-[6.25rem] items-center justify-center bg-white px-6 py-5">
            <div class:list={story.darkLogoFrame ? 'rounded-[0.35rem] bg-[#111111] px-3 py-[0.45rem]' : undefined}>
              <img
                src={story.logo}
                alt=""
                class:list={['h-16 w-full object-contain object-center', story.logoClassName]}
                loading="lazy"
                width="220"
                height="64"
              />
            </div>
          </div>
          <div class="flex h-full flex-col gap-4 p-6">
            <div class="flex min-h-[2.75rem] flex-wrap items-start gap-2">
              <span class="inline-flex items-center rounded-md bg-[var(--color-primary)]/12 px-3 py-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.08em] text-[var(--color-primary)]">{story.primaryTag}</span>
              {story.secondaryTags.map((tag) => (
                <span class="inline-flex items-center rounded-md bg-[#2C4A6B]/10 px-2.5 py-1.5 text-[0.66rem] font-semibold uppercase tracking-[0.08em] text-[#2C4A6B]">{tag}</span>
              ))}
            </div>
            <h3 class="m-0 min-h-[4.5rem] text-[1.05rem] font-medium leading-snug text-[var(--color-text)]">{story.title}</h3>
            <p class="m-0 text-[0.9375rem] leading-relaxed text-[var(--color-text-muted)]">{story.text}</p>
            <span class="mt-auto text-sm font-semibold text-[var(--color-primary)]">Read more &rarr;</span>
          </div>
        </a>
      ))}
    </div>

    <div class="flex justify-center">
      <a href="/partner-stories" class="btn btn--outline">See all partner stories</a>
    </div>
  </div>
</section>

---
import type { PartnerStoryUseCase } from '../../config/partner-stories';

interface Props {
  item: PartnerStoryUseCase;
  iconSrc: string;
}

const { item, iconSrc } = Astro.props;
---

<section class="grid grid-cols-1 gap-4 pb-6 last:pb-0 lg:grid-cols-[17%_83%] lg:items-center">
  <div class="flex items-center justify-center">
    <img
      src={iconSrc}
      alt=""
      aria-hidden="true"
      width="112"
      height="112"
      class="h-24 w-24 object-contain"
      loading="lazy"
    />
  </div>
  <div class="flex flex-col gap-3">
    <h4 class="m-0 text-[1.14rem] font-bold text-[var(--color-primary)]">{item.title}</h4>
    <div class="flex flex-col gap-2.5">
      {
        item.lines.map((line) => (
          <p class="m-0 text-[0.95rem] leading-relaxed text-[var(--color-text-muted)]">{line}</p>
        ))
      }
    </div>
  </div>
</section>

---
import type { PartnerStoryDetail } from '../../config/partner-stories';
import ArrowLink from '../primitives/ArrowLink.astro';
import InsetPanel from '../panels/InsetPanel.astro';
import LogoPanel from '../panels/LogoPanel.astro';
import PartnerUseCaseRow from './PartnerUseCaseRow.astro';
import TagGroup from '../cards/TagGroup.astro';

interface Props {
  story: PartnerStoryDetail;
  useCaseIconByKey: Record<string, string>;
}

const { story, useCaseIconByKey } = Astro.props;
---

<div
  class="mx-auto flex max-w-[980px] flex-col gap-8 rounded-[1.5rem] border border-t-4 border-[var(--color-surface-200)] bg-[var(--color-surface-0)] px-5 py-6 text-[var(--color-text)] shadow-[0_4px_16px_rgba(0,0,0,0.06)] lg:px-7 lg:py-7"
  style="border-top-color: var(--color-primary);"
>
  <header class="grid grid-cols-1 gap-6 lg:grid-cols-[32%_68%] lg:items-center">
    <LogoPanel
      logo={story.logo}
      name={story.name}
      logoClassName={story.logoClassName}
      darkLogoFrame={story.darkLogoFrame}
    />
    <div class="flex flex-col gap-4 lg:pl-2">
      <TagGroup primaryTag={story.primaryTag} secondaryTags={story.secondaryTags} />
      <h2 class="m-0 text-[1.75rem] font-bold leading-tight text-[var(--color-text)] lg:text-[2.3rem]">
        {story.heroTitle}
      </h2>
      {
        story.externalUrl && (
          <ArrowLink href={story.externalUrl} target="_blank" rel="noopener noreferrer">
            {story.closingCtaLabel ?? 'Visit the website'}
            <span aria-hidden="true">&rarr;</span>
          </ArrowLink>
        )
      }
    </div>
  </header>

  <div class="flex flex-col gap-4">
    {
      story.intro.map((paragraph) => (
        <p class="m-0 text-[1rem] leading-relaxed text-[var(--color-text-muted)]">{paragraph}</p>
      ))
    }
  </div>

  <section class="flex flex-col gap-5">
    <h3 class="m-0 text-[1.14rem] font-bold text-[var(--color-text)]">Key use cases</h3>
    <div class="flex flex-col gap-8">
      {story.keyUseCases.map((item) => <PartnerUseCaseRow item={item} iconSrc={useCaseIconByKey[item.icon]} />)}
    </div>
  </section>

  <InsetPanel title="Integration benefits">
    <ul
      class="m-0 grid list-disc gap-3 pl-5 text-[0.95rem] leading-relaxed text-[var(--color-text-muted)] lg:grid-cols-2"
    >
      {story.benefits.map((benefit) => <li>{benefit}</li>)}
    </ul>
  </InsetPanel>

  <div class="flex flex-col items-start gap-5 pt-4 lg:flex-row lg:flex-wrap lg:items-center lg:justify-end lg:gap-x-8">
    {
      story.externalUrl && (
        <ArrowLink href={story.externalUrl} target="_blank" rel="noopener noreferrer">
          Visit the website
          <span aria-hidden="true">&rarr;</span>
        </ArrowLink>
      )
    }
    <ArrowLink href="/product#use-cases">
      Explore further use cases
      <span aria-hidden="true">&rarr;</span>
    </ArrowLink>
    <a href="/about#contact" class="btn btn--orange"> Get in touch </a>
  </div>
</div>

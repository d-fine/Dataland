---
interface Props {
  quote: string;
  author: string;
  role: string;
  class?: string;
  quoteClass?: string;
}

const { quote, author, role, class: className, quoteClass } = Astro.props;
---

<blockquote
  class:list={[
    'm-0 rounded-r-xl border-l-4 border-l-[var(--color-primary)] bg-[var(--color-surface-50)] px-6 py-5',
    className,
  ]}
>
  <p class:list={['card-text mb-3 italic text-[var(--color-text)]', quoteClass]}>&ldquo;{quote}&rdquo;</p>
  <footer class="flex flex-col gap-0.5">
    <cite class="text-[0.95rem] font-bold not-italic text-[var(--color-text)]">{author}</cite>
    <span class="text-[0.82rem] text-[var(--color-text-muted)]">{role}</span>
  </footer>
</blockquote>

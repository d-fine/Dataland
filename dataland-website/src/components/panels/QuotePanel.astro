---
interface Props {
  quote: string;
  author: string;
  role: string;
  class?: string;
  quoteClass?: string;
}

const { quote, author, role, class: className, quoteClass } = Astro.props;

const classes = {
  panel: 'm-0 rounded-r-xl border-l-4 border-l-[var(--color-primary)] bg-[var(--color-surface-50)] px-6 py-5',
  quote: 'card-text mb-3 italic text-[var(--color-text)]',
  footer: 'mt-5 flex flex-col gap-0.5',
  author: 'text-[0.95rem] font-bold not-italic text-[var(--color-text)]',
  role: 'text-[0.82rem] text-[var(--color-text-muted)]',
} as const;
---

<blockquote class:list={[classes.panel, className]}>
  <p class:list={[classes.quote, quoteClass]}>&ldquo;{quote}&rdquo;</p>
  <footer class={classes.footer}>
    <cite class={classes.author}>{author}</cite>
    <span class={classes.role}>{role}</span>
  </footer>
</blockquote>

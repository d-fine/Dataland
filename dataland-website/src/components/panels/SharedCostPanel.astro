---
import CardShell from '../primitives/CardShell.astro';
import PricingFeatureItem from './PricingFeatureItem.astro';

interface PricingItem {
  title: string;
  text: string;
}

interface CreditRow {
  members: string;
  cost: string;
}

interface Props {
  title?: string;
  intro?: string;
  footnote?: string;
  highlight?: string;
  membersHeader?: string;
  costHeader?: string;
  items: readonly PricingItem[];
  rows: readonly CreditRow[];
}

const {
  title = 'Shared cost approach',
  intro = 'The cost of sourcing datasets is shared among members requesting the same data.',
  footnote = 'Dataset = 1 company, 1 framework, 1 reporting period.',
  highlight = 'The more members request the same company, the lower the cost per dataset.',
  membersHeader = '# of Members',
  costHeader = 'Cost (Credits)',
  items,
  rows,
} = Astro.props;

const classes = {
  card: 'rounded-[1.5rem] px-5 py-7 sm:px-8 sm:py-8 lg:px-10 lg:py-10',
  grid: 'grid grid-cols-1 gap-6 sm:gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-stretch',
  leftColumn: 'flex h-full flex-col gap-5',
  leftTop: 'flex flex-col gap-5',
  title: 'm-0 text-[1.75rem] font-bold leading-tight',
  intro: 'section-intro text-white/90',
  items: 'flex flex-col gap-5',
  footnote: 'm-0 pt-1 text-[0.82rem] leading-relaxed text-white/58',
  rightColumn: 'grid h-full grid-rows-[auto_1fr] gap-4 sm:gap-5',
  spacerTitle: 'invisible text-[1.75rem] font-bold leading-tight',
  tablePanel: 'flex h-full min-h-0 min-w-0 items-center justify-center rounded-[1.25rem] bg-white/6 px-3 py-4 sm:px-6',
  tableInner: 'w-full max-w-[20rem] sm:max-w-[24rem]',
  table: 'w-full border-collapse',
  headerRow: 'border-b-2 border-white',
  headCell: 'px-4 py-1 text-center text-[0.9rem] font-bold uppercase tracking-[0.04em] text-white sm:px-8 sm:text-[0.95rem]',
  bodyCell: 'px-4 py-1 text-center text-[1rem] font-bold text-white sm:px-8 sm:text-[1.06rem]',
  bodyRow: 'border-b border-[var(--color-surface-200)]',
  lastBodyRow: 'border-b-0',
  highlight: 'm-0 mt-4 text-center text-[1.06rem] font-semibold leading-relaxed text-[var(--color-primary)] lg:text-[1.12rem]',
} as const;
---

<section aria-label="Shared cost approach">
  <CardShell as="article" variant="dark" class={classes.card}>
    <div class={classes.grid}>
      <div class={classes.leftColumn}>
        <div class={classes.leftTop}>
          <h3 class={classes.title}>{title}</h3>
          <p class={classes.intro}>{intro}</p>
          <div class={classes.items}>
            {items.map((item) => <PricingFeatureItem title={item.title} text={item.text} />)}
          </div>
        </div>
        <p class={classes.footnote}>{footnote}</p>
      </div>
      <div class={classes.rightColumn}>
        <div class={classes.spacerTitle} aria-hidden="true">
          {title}
        </div>
        <div class={classes.tablePanel}>
          <div class={classes.tableInner}>
            <table class={classes.table}>
              <thead>
                <tr class={classes.headerRow}>
                  <th class={classes.headCell}>{membersHeader}</th>
                  <th class={classes.headCell}>{costHeader}</th>
                </tr>
              </thead>
              <tbody>
                {
                  rows.map((row, idx) => (
                    <tr class:list={[classes.bodyRow, idx === rows.length - 1 && classes.lastBodyRow]}>
                      <td class={classes.bodyCell}>{row.members}</td>
                      <td class={classes.bodyCell}>{row.cost}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
            <p class={classes.highlight}>{highlight}</p>
          </div>
        </div>
      </div>
    </div>
  </CardShell>
</section>

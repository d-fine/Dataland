---
import CompanySearchBar from '../CompanySearchBar.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;

const sectionClass =
  'px-6 bg-[radial-gradient(circle_at_top_left,rgba(62,106,142,0.28),transparent_34%),linear-gradient(135deg,#091119_0%,#101922_38%,#172635_72%,#21384b_100%)] text-white py-14 lg:py-16';

const sectionInnerClass = 'max-w-[1200px] mx-auto flex flex-col items-center justify-center gap-4';

const titleClass = 'relative -top-6 text-2xl font-bold m-0 text-center';
---

<section class={sectionClass} aria-label="Search sustainability data by company name or LEI">
  <div class={sectionInnerClass}>
    <h2 class={titleClass}>{title}</h2>
    <CompanySearchBar />
  </div>
</section>

---
import {
  CONTACT_PHONE,
  CONTACT_PHONE_DISPLAY,
  CONTACT_EMAIL,
  CONTACT_EMAIL_DISPLAY,
  CONTACT_INQUIRY_MAILTO,
  CONTACT_ADDRESS,
} from '../data/about';
import { DOCUMENTATION_LINKS } from '../data/product';

const currentYear = new Date().getFullYear();
const documentationColumns = [
  {
    title: 'Documentation',
    links: [DOCUMENTATION_LINKS[1], DOCUMENTATION_LINKS[3], DOCUMENTATION_LINKS[5], DOCUMENTATION_LINKS[7]],
  },
  {
    title: undefined,
    links: [DOCUMENTATION_LINKS[2], DOCUMENTATION_LINKS[4], DOCUMENTATION_LINKS[6], DOCUMENTATION_LINKS[8]],
  },
  {
    title: 'Framework Guide',
    links: [{ label: 'Overview', url: DOCUMENTATION_LINKS[0].url }],
  },
];
---

<footer class="bg-[var(--color-dark-panel)] text-white">
  <div class="border-t border-white/10">
    <div
      class="mx-auto grid max-w-[1280px] grid-cols-1 gap-10 px-6 py-10 md:grid-cols-2 xl:grid-cols-[1.35fr_0.9fr_0.9fr_0.9fr_1fr] lg:py-12"
    >
      <div class="flex flex-col gap-4">
        <a href="/" class="inline-flex w-full max-w-[192px]" aria-label="Dataland home">
          <img
            src="/static/logos/logo_dataland_orange.svg"
            alt="Dataland"
            width="240"
            height="55"
            loading="lazy"
            class="h-auto w-full object-contain"
          />
        </a>
        <a
          href="https://wertestiftung.org/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-full max-w-[192px]"
          aria-label="Visit Werte-Stiftung"
        >
          <img
            src="/static/images/a_werte-stiftung_company.svg"
            alt="Werte-Stiftung Company"
            width="240"
            height="24"
            loading="lazy"
            class="h-auto w-full object-contain opacity-72"
          />
        </a>
        <div class="flex flex-col gap-3">
          <div class="flex flex-col gap-1">
            <p class="m-0 text-[0.95rem] font-semibold text-white">{CONTACT_ADDRESS.company}</p>
            <div class="flex items-start gap-2">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                class="mt-1.5 shrink-0 self-start text-white/60"
              >
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              <div class="mt-0.5 flex flex-col gap-1">
                <p class="m-0 text-[0.82rem] text-white/60">{CONTACT_ADDRESS.street}</p>
                <p class="m-0 text-[0.82rem] text-white/60">
                  {CONTACT_ADDRESS.city}, {CONTACT_ADDRESS.country}
                </p>
              </div>
            </div>
          </div>
          <a
            href={CONTACT_PHONE}
            class="inline-flex items-center gap-2 text-[0.82rem] text-white/68 no-underline motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
            {CONTACT_PHONE_DISPLAY}
          </a>
          <a
            href={CONTACT_EMAIL}
            class="inline-flex items-center gap-2 text-[0.82rem] text-white/68 no-underline motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            {CONTACT_EMAIL_DISPLAY}
          </a>
        </div>
      </div>

      {
        documentationColumns.map((column, index) => (
          <div>
            {column.title ? (
              <h3 class="m-0 mb-4 text-[0.95rem] font-bold uppercase tracking-[0.16em] text-white">
                {column.title}
              </h3>
            ) : (
              <div class="mb-4 h-[1.14rem]" aria-hidden="true"></div>
            )}
            <ul class="m-0 flex list-none flex-col items-start gap-2.5 p-0">
              {column.links.map(({ url, label }) => (
                <li>
                  <a
                    href={url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-left text-[1rem] text-white/68 no-underline motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]"
                  >
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      <div>
        <h3 class="m-0 mb-4 text-[0.95rem] font-bold uppercase tracking-[0.16em] text-white">Connect and explore</h3>
        <ul class="m-0 flex list-none flex-col items-start gap-2.5 p-0">
          <li>
            <a
              href="https://www.linkedin.com/company/dataland-gmbh/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2.5 text-[1rem] text-white/68 no-underline motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
              LinkedIn
            </a>
          </li>
          <li>
            <a
              href={CONTACT_INQUIRY_MAILTO}
              class="inline-flex items-center gap-2.5 text-[1rem] text-white/68 no-underline motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
              </svg>
              Get in touch
            </a>
          </li>
          <li>
            <a
              href="/partner-stories"
              class="inline-flex items-center gap-2.5 text-[1rem] text-white/68 no-underline motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M3 21h18" />
                <path d="M5 21V8l4-3 4 3v13" />
                <path d="M13 21V5l3-2 3 2v16" />
                <path d="M8 11h.01" />
                <path d="M8 15h.01" />
                <path d="M16 9h.01" />
                <path d="M16 13h.01" />
              </svg>
              Integration partners
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto flex max-w-[1280px] flex-col items-center gap-4 px-6 py-5 lg:flex-row lg:justify-between">
      <div class="flex flex-wrap items-center gap-5">
        <a
          href="/legal"
          class="inline-flex min-h-[44px] min-w-[44px] items-center text-[0.8125rem] text-white/60 no-underline motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]"
          >Legal</a
        >
        <a
          href="/imprint"
          class="inline-flex min-h-[44px] min-w-[44px] items-center text-[0.8125rem] text-white/60 no-underline motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]"
          >Imprint</a
        >
        <a
          href="/dataprivacy"
          class="inline-flex min-h-[44px] min-w-[44px] items-center text-[0.8125rem] text-white/60 no-underline motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]"
          >Data Privacy</a
        >
        <button
          type="button"
          onclick="if(typeof Cookiebot !== 'undefined') Cookiebot.show()"
          class="inline-flex min-h-[44px] min-w-[44px] items-center border-none bg-transparent p-0 text-[0.8125rem] text-white/60 cursor-pointer font-[inherit] motion-safe:transition-colors duration-150 hover:text-[var(--color-primary)]"
          >Cookie Settings</button
        >
      </div>
      <div class="flex items-center gap-4 text-[0.8125rem] text-white/60">
        <span>&copy; {currentYear} Dataland</span>
      </div>
    </div>
  </div>
</footer>

---
import CardShell from '../CardShell.astro';
import type { PartnerStorySummary } from '../../data/partnerStories';

interface Content {
  eyebrow: string;
  title: string;
  intro: string;
}

interface Props {
  content: Content;
  stories: PartnerStorySummary[];
}

const { content, stories } = Astro.props;

const sectionClass =
  'bg-[linear-gradient(90deg,#020408_0%,#08111b_24%,#142231_52%,#27435d_82%,#345877_100%)] px-6 pt-16 pb-12 text-white lg:px-8 lg:pt-24 lg:pb-16';

const sectionInnerClass = 'max-w-[1200px] mx-auto flex flex-col gap-6';

const textWrapClass = 'max-w-[840px]';

const eyebrowClass = 'm-0 mb-3 text-[0.82rem] font-semibold uppercase tracking-[0.16em] text-white/60';

const titleClass = 'm-0 text-[2rem] font-bold leading-[1.15] lg:text-[3rem]';

const introClass = 'mt-4 mb-0 max-w-[720px] text-[1rem] leading-relaxed text-white/78';

const gridClass = 'grid grid-cols-1 gap-6 md:grid-cols-2';

const cardClass =
  'flex h-full flex-col overflow-hidden text-white no-underline motion-safe:transition-colors motion-safe:duration-200 hover:bg-white/14';

const logoStageClass = 'flex min-h-[8rem] items-center justify-center overflow-hidden bg-white px-4 py-5';

const cardBodyClass = 'flex h-full flex-col gap-4 p-6';

const cardTitleClass = 'm-0 text-[1.14rem] font-medium leading-snug';

const cardTextClass = 'm-0 text-[0.95rem] leading-relaxed text-white/72';
---

<section class={sectionClass} aria-label="Integration partner stories overview">
  <div class={sectionInnerClass}>
    <div class={textWrapClass}>
      <p class={eyebrowClass}>{content.eyebrow}</p>
      <h1 class={titleClass}>{content.title}</h1>
      <p class={introClass}>{content.intro}</p>
    </div>

    <div class={gridClass}>
      {
        stories.map((story) => (
          <CardShell
            as="a"
            href={story.link}
            variant="glass"
            accentTop={true}
            class={cardClass}
          >
            <div class={logoStageClass}>
              <div class:list={story.darkLogoFrame ? 'rounded-[0.35rem] bg-[#111111] px-3 py-[0.45rem]' : undefined}>
                <img
                  src={story.logo}
                  alt=""
                  class:list={['h-20 w-full object-contain object-center', story.logoClassName]}
                  loading="lazy"
                  width="320"
                  height="120"
                />
              </div>
            </div>

            <div class={cardBodyClass}>
              <h2 class={cardTitleClass}>{story.title}</h2>
              <p class={cardTextClass}>{story.text}</p>
            </div>
          </CardShell>
        ))
      }
    </div>
  </div>
</section>

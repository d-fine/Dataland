---
import Base from '../layouts/Base.astro';
import {
  COMPANY_COPY,
  LEADERSHIP_TEAM,
  PARTNERS,
  CONTACT_PHONE,
  CONTACT_PHONE_DISPLAY,
  CONTACT_EMAIL,
  CONTACT_EMAIL_DISPLAY,
  CONTACT_ADDRESS,
} from '../data/about';
import { NEWS_ITEMS } from '../data/news';
---

<Base title="About — Dataland" description="Learn about Dataland's mission, team, and partners.">

  <!-- Section 1: Company (grey) -->
  <section id="company" class="pt-16 pb-12 px-6 bg-[var(--color-surface-50)] lg:pt-24 lg:pb-16 lg:px-8" aria-label="About Dataland">
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 gap-10 lg:grid-cols-[40%_60%] lg:items-start">
      <div class="flex flex-wrap items-center gap-8 lg:flex-col lg:items-start">
        <img src="/static/logos/gfx_logo_dataland_orange_S.svg" alt="Dataland" width="180" height="56" loading="eager" class="h-10 lg:h-14 w-auto object-contain" />
        <div class="flex flex-wrap items-center gap-8">
          <img src="/static/logos/logo_wertestiftung.png" alt="Werte-Stiftung" width="140" height="56" loading="lazy" class="w-[120px] lg:w-[150px] h-auto object-contain" />
          <img src="/static/logos/logo_dfine.svg" alt="d-fine" width="100" height="56" loading="lazy" class="w-[100px] lg:w-[130px] h-auto object-contain" />
          <img src="/static/logos/logo_pwc.svg" alt="PwC" width="80" height="56" loading="lazy" class="w-[70px] lg:w-[90px] h-auto object-contain" />
        </div>
      </div>
      <div class="flex flex-col gap-4">
        <h1 class="text-[2rem] font-bold m-0 text-[var(--color-text)]">{COMPANY_COPY.title}</h1>
        <p class="text-base leading-[1.7] m-0 text-[var(--color-text-muted)]">{COMPANY_COPY.text1}</p>
        <p class="text-base leading-[1.7] m-0 text-[var(--color-text-muted)]">{COMPANY_COPY.text2}</p>
      </div>
    </div>
  </section>

  <!-- Section 2: Team (white / special dark blue) -->
  <section id="team" class="py-12 px-6 bg-[#0f3a82] text-white lg:py-16 lg:px-8" aria-label="Leadership team">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-10">
      <h2 class="text-[1.75rem] font-bold m-0 text-center">Leadership team</h2>
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 md:grid-cols-3">
        {LEADERSHIP_TEAM.map((person) => (
          <div class="flex flex-col items-center gap-3 text-center">
            <img
              src={person.imagePath}
              alt={person.name}
              class="w-[180px] h-[180px] rounded-full object-cover object-top border-[3px] border-white/20"
              loading="lazy"
              width="280"
              height="280"
            />
            <h3 class="text-xl font-bold m-0">{person.name}</h3>
            <p class="text-[0.9375rem] m-0 opacity-85">{person.role}</p>
            <p class="text-sm leading-normal m-0 opacity-75 max-w-[320px]">{person.bio}</p>
            <div class="flex gap-3 mt-1">
              <a href={person.email} aria-label={`Email ${person.name}`} class="text-white opacity-70 inline-flex motion-safe:transition-opacity motion-safe:duration-200 hover:opacity-100">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                </svg>
              </a>
              <a href={person.linkedIn} target="_blank" rel="noopener noreferrer" aria-label={`${person.name} on LinkedIn`} class="text-white opacity-70 inline-flex motion-safe:transition-opacity motion-safe:duration-200 hover:opacity-100">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 3: Partners (grey) -->
  <section id="partners" class="py-12 px-6 bg-[var(--color-surface-50)] lg:py-16 lg:px-8" aria-label="Partners">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
      <h2 class="text-[1.75rem] font-bold m-0 text-[var(--color-text)] text-center">Partners</h2>
      <div class="grid grid-cols-2 gap-6 lg:grid-cols-4">
        {PARTNERS.map((partner) => (
          <a
            href={partner.url}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              'flex items-center justify-center p-8 px-6 rounded-xl border no-underline min-h-[100px] motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-[0_4px_16px_rgba(0,0,0,0.08)]',
              partner.darkBg
                ? 'bg-[#1a1a2e] border-[#2a2a3e]'
                : 'bg-[var(--color-surface-0)] border-[var(--color-surface-200)]',
            ]}
          >
            <img
              src={partner.imagePath}
              alt={partner.name}
              class="max-h-[120px] w-auto object-contain"
              loading="lazy"
              width="160"
              height="60"
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 4: Updates (white) -->
  <section id="updates" class="py-12 px-6 bg-[var(--color-surface-0)] lg:py-16 lg:px-8" aria-label="News and updates">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
      <h2 class="text-[1.75rem] font-bold m-0 text-[var(--color-text)] text-center">News and updates</h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {NEWS_ITEMS.map((item) => (
          <a href={item.link} target="_blank" rel="noopener noreferrer" class="flex flex-col no-underline text-[var(--color-text)] bg-[var(--color-surface-50)] rounded-xl overflow-hidden motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-[0_4px_16px_rgba(0,0,0,0.08)]">
            <div class="relative aspect-square overflow-hidden bg-[var(--color-surface-200)]">
              <img
                src={item.image}
                alt=""
                class="absolute inset-0 w-full h-full object-cover blur-2xl scale-110 opacity-50"
                loading="lazy"
                width="400"
                height="400"
                aria-hidden="true"
              />
              <img
                src={item.image}
                alt=""
                class="relative w-full h-full object-contain"
                loading="lazy"
                width="400"
                height="400"
              />
            </div>
            <div class="p-4 px-5 pb-5 flex flex-col gap-1.5">
              <h3 class="text-base font-bold m-0 leading-snug">{item.title}</h3>
              <time class="text-[0.8125rem] text-[var(--color-text-muted)]">{item.date}</time>
              <span class="text-sm font-semibold text-[var(--color-primary)] mt-1">Read more &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 5: Contact (dark) -->
  <section id="contact" class="py-12 px-6 bg-[#111111] text-white lg:py-16 lg:px-8" aria-label="Contact us">
    <div class="max-w-[1200px] mx-auto flex flex-col items-center gap-8 lg:flex-row lg:justify-between lg:items-start">
      <div class="flex flex-col gap-6 lg:max-w-[50%]">
        <h2 class="text-[1.75rem] font-bold m-0">Get in touch</h2>
        <p class="text-[0.9375rem] leading-relaxed m-0 opacity-80">Interested in becoming a Dataland member or learning more about the platform? Reach out to us directly.</p>
        <div class="flex flex-col gap-1">
          <p class="text-base font-semibold m-0">{CONTACT_ADDRESS.company}</p>
          <p class="text-[0.9375rem] m-0 opacity-75">{CONTACT_ADDRESS.street}</p>
          <p class="text-[0.9375rem] m-0 opacity-75">{CONTACT_ADDRESS.city}</p>
          <p class="text-[0.9375rem] m-0 opacity-75">{CONTACT_ADDRESS.country}</p>
        </div>
        <div class="flex flex-col gap-3">
          <a href={CONTACT_PHONE} class="inline-flex items-center gap-2 text-white no-underline text-[0.9375rem] opacity-85 motion-safe:transition-opacity motion-safe:duration-200 hover:opacity-100">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            {CONTACT_PHONE_DISPLAY}
          </a>
          <a href={CONTACT_EMAIL} class="inline-flex items-center gap-2 text-white no-underline text-[0.9375rem] opacity-85 motion-safe:transition-opacity motion-safe:duration-200 hover:opacity-100">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            {CONTACT_EMAIL_DISPLAY}
          </a>
        </div>
      </div>
      <div class="flex flex-col items-center gap-4 text-center lg:items-start lg:text-left lg:pt-8">
        <a
          href="mailto:info@dataland.com?subject=Inquiry%20about%20Dataland%20membership&body=Dear%20Dataland%20team%2C%0A%0AI%20am%20interested%20in%20learning%20more%20about%20Dataland%20membership.%0A%0AName%3A%20%0ACompany%3A%20%0ARole%3A%20%0A%0APlease%20get%20back%20to%20me%20at%20your%20earliest%20convenience.%0A%0ABest%20regards"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-[var(--color-primary)] text-white font-semibold text-base rounded-md no-underline motion-safe:transition-colors duration-150 hover:bg-[#e55d10]"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
          Get in touch
        </a>
      </div>
    </div>
  </section>

</Base>

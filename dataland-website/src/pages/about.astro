---
import Base from '../layouts/Base.astro';
import PartnerStoryCards from '../components/PartnerStoryCards.astro';
import {
  COMPANY_COPY,
  LEADERSHIP_TEAM,
  CONTACT_PHONE,
  CONTACT_PHONE_DISPLAY,
  CONTACT_EMAIL,
  CONTACT_EMAIL_DISPLAY,
  CONTACT_INQUIRY_MAILTO,
  CONTACT_ADDRESS,
} from '../data/about';
import { PARTNER_STORY_SUMMARIES } from '../data/partnerStories';
import { NEWS_ITEMS } from '../data/news';
---

<Base title="About — Dataland" description="Learn about Dataland's mission, team, and partners.">
  <!-- Section 1: Company (grey) -->
  <section
    id="company"
    class="scroll-mt-16 bg-[radial-gradient(circle_at_65%_80%,rgba(62,106,142,0.32),transparent_24%),linear-gradient(90deg,#020408_0%,#08111b_24%,#142231_52%,#27435d_82%,#345877_100%)] px-6 pt-16 pb-12 text-white lg:px-8 lg:pt-24 lg:pb-16"
    aria-label="About Dataland"
  >
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 gap-10 lg:grid-cols-[52%_48%] lg:items-stretch">
      <div class="flex justify-center lg:justify-start">
        <img
          src="/static/images/img_about_main.png"
          alt="Dataland team and company overview"
          width="720"
          height="520"
          loading="eager"
          class="h-full w-full max-w-[680px] rounded-[1.5rem] object-contain object-left shadow-[0_20px_55px_rgba(0,0,0,0.28)] lg:max-w-none"
        />
      </div>
      <div class="flex h-full flex-col justify-between gap-7 lg:pt-1">
        <div class="flex flex-col gap-4">
          <h1 class="m-0 text-[1.9rem] font-bold leading-[1.04] text-white lg:text-[2.3rem]">
            Built for Europe, in Europe
          </h1>
          <div class="flex flex-1 flex-col justify-center gap-4 pt-4 lg:pt-8">
            <p class="m-0 text-[1.06rem] leading-[1.6] text-white/78 lg:text-[1.18rem]">
              {COMPANY_COPY.text1}
            </p>
            <p class="m-0 text-[1.06rem] leading-[1.6] text-white/78 lg:text-[1.18rem]">
              Dataland is part of the <span class="font-bold text-[#3E6A8E]">Werte-Stiftung</span> foundation, with strategic
              support from <span class="font-bold text-[#3E6A8E]">d-fine</span> and <span
                class="font-bold text-[#3E6A8E]">PwC</span
              >.
            </p>
          </div>
        </div>
        <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-6 pt-2 lg:flex-nowrap">
          <img
            src="/static/logos/logo_wertestiftung.png"
            alt="Werte-Stiftung"
            width="160"
            height="64"
            loading="lazy"
            class="w-[140px] lg:w-[165px] h-auto object-contain"
          />
          <div class="-mx-3 lg:-mx-5">
            <img
              src="/static/logos/logo_pwc.svg"
              alt="PwC"
              width="190"
              height="88"
              loading="lazy"
              class="h-auto w-[148px] object-contain lg:w-[178px]"
            />
          </div>
          <img
            src="/static/logos/logo_d-fine_RGB.svg"
            alt="d-fine"
            width="140"
            height="64"
            loading="lazy"
            class="w-[120px] lg:w-[145px] h-auto object-contain brightness-0 invert opacity-95"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: Team (white / special dark blue) -->
  <section
    id="team"
    class="scroll-mt-16 py-12 px-6 bg-[#2C4A6B] text-white lg:py-16 lg:px-8"
    aria-label="Leadership team"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-10">
      <div class="mx-auto flex max-w-[860px] flex-col gap-3 text-center">
        <h2 class="text-[1.75rem] font-bold m-0 text-center">Leadership team</h2>
        <p class="m-0 text-[1.06rem] leading-relaxed text-white/72 lg:text-[1.12rem]">
          The leadership team combines expertise in data, technology, and financial services.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 md:grid-cols-3">
        {
          LEADERSHIP_TEAM.map((person) => (
            <div class="flex h-full flex-col items-center gap-1.5 text-center">
              <img
                src={person.imagePath}
                alt={person.name}
                class="h-[430px] w-full max-w-[340px] rounded-2xl object-cover object-top"
                loading="lazy"
                width="340"
                height="540"
              />
              <div class="flex items-start justify-center">
                <h3 class="m-0 text-[1.52rem] font-bold leading-tight">{person.name}</h3>
              </div>
              <div class="mt-[0.1rem] flex items-start justify-center">
                <p class="m-0 text-[1.38rem] leading-tight opacity-85">{person.role}</p>
              </div>
              <div class="mt-8 flex min-h-[5.6rem] items-start justify-center max-w-[320px]">
                <p class="m-0 text-[1.08rem] leading-[1.5] opacity-80">{person.bio}</p>
              </div>
              <div class="mt-0.5 flex gap-4">
                <a
                  href={person.email}
                  aria-label={`Email ${person.name}`}
                  class="text-white opacity-70 inline-flex motion-safe:transition-opacity motion-safe:duration-200 hover:opacity-100"
                >
                  <svg
                    width="26"
                    height="26"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <rect x="2" y="4" width="20" height="16" rx="2" />
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                  </svg>
                </a>
                <a
                  href={person.linkedIn}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${person.name} on LinkedIn`}
                  class="text-white opacity-70 inline-flex motion-safe:transition-opacity motion-safe:duration-200 hover:opacity-100"
                >
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                  </svg>
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Section 3: Partners (grey) -->
  <PartnerStoryCards
    title="Integration partners"
    intro="Dataland data is embedded into partner platforms, enabling Members to seamlessly access sustainability data through familiar interfaces and workflows."
    stories={PARTNER_STORY_SUMMARIES}
  />

  <!-- Section 4: Updates (white) -->
  <section
    id="updates"
    class="scroll-mt-16 py-12 px-6 bg-[var(--color-surface-0)] lg:py-16 lg:px-8"
    aria-label="News and updates"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
      <div class="mx-auto flex max-w-[860px] flex-col gap-3 text-center">
        <h2 class="text-[1.75rem] font-bold m-0 text-[var(--color-text)] text-center">News and updates</h2>
        <p class="m-0 text-[1.06rem] leading-relaxed text-[var(--color-text-muted)] lg:text-[1.12rem]">
          Recent updates, announcements, and insights reflect Dataland&apos;s ongoing development.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          NEWS_ITEMS.map((item) => (
            <a
              href={item.link}
              target="_blank"
              rel="noopener noreferrer"
              class="flex flex-col no-underline text-[var(--color-text)] bg-[var(--color-surface-50)] rounded-xl overflow-hidden motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-[0_4px_16px_rgba(0,0,0,0.08)]"
            >
              <div class="relative h-[240px] overflow-hidden bg-[var(--color-surface-200)] sm:h-[260px]">
                <img
                  src={item.image}
                  alt=""
                  class="absolute inset-0 h-full w-full object-cover blur-2xl scale-110 opacity-50"
                  loading="lazy"
                  width="400"
                  height="400"
                  aria-hidden="true"
                />
                <img
                  src={item.image}
                  alt=""
                  class="relative h-full w-full object-cover"
                  loading="lazy"
                  width="400"
                  height="400"
                />
              </div>
              <div class="p-4 px-5 pb-5 flex flex-col gap-1.5">
                <h3 class="text-base font-bold m-0 leading-snug">{item.title}</h3>
                <time class="text-[0.8125rem] text-[var(--color-text-muted)]">{item.date}</time>
                <span class="text-sm font-semibold text-[var(--color-primary)] mt-1">Read more &rarr;</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Section 5: Contact (dark) -->
  <section
    id="contact"
    class="scroll-mt-16 bg-[radial-gradient(circle_at_top_left,rgba(62,106,142,0.28),transparent_34%),linear-gradient(135deg,#091119_0%,#101922_38%,#172635_72%,#21384b_100%)] px-6 py-14 text-white lg:px-8 lg:py-18"
    aria-label="Contact us"
  >
    <div class="mx-auto grid max-w-[1200px] grid-cols-1 gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-stretch">
      <div
        class="flex flex-col justify-between gap-8 rounded-[1.5rem] border border-white/10 bg-white/6 p-7 backdrop-blur-[2px] lg:p-9"
      >
        <div class="flex flex-col gap-5">
          <p class="m-0 text-[0.82rem] font-semibold uppercase tracking-[0.16em] text-white/55">Contact</p>
          <h2 class="m-0 max-w-[12ch] text-[1.9rem] font-bold leading-[1.05] lg:text-[2.3rem]">
            Bring sustainability data into your workflow.
          </h2>
          <p class="m-0 max-w-[42rem] text-[1.02rem] leading-relaxed text-white/78 lg:text-[1.12rem]">
            Whether you are exploring membership, a partnership, or a product deep dive, we can point you to the right
            next step.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-7 md:grid-cols-2">
          <div class="flex flex-col gap-2.5">
            <p class="m-0 text-[0.78rem] font-semibold uppercase tracking-[0.14em] text-white/48">Office</p>
            <div class="flex flex-col gap-1">
              <p class="m-0 text-base font-semibold text-white">{CONTACT_ADDRESS.company}</p>
              <p class="m-0 text-[0.95rem] text-white/72">{CONTACT_ADDRESS.street}</p>
              <p class="m-0 text-[0.95rem] text-white/72">{CONTACT_ADDRESS.city}</p>
              <p class="m-0 text-[0.95rem] text-white/72">{CONTACT_ADDRESS.country}</p>
            </div>
          </div>

          <div class="flex flex-col gap-3">
            <p class="m-0 text-[0.78rem] font-semibold uppercase tracking-[0.14em] text-white/48">Direct</p>
            <a
              href={CONTACT_PHONE}
              class="inline-flex items-center gap-2.5 text-white no-underline text-[0.98rem] motion-safe:transition-opacity motion-safe:duration-200 hover:opacity-100 opacity-84"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                ></path>
              </svg>
              {CONTACT_PHONE_DISPLAY}
            </a>
            <a
              href={CONTACT_EMAIL}
              class="inline-flex items-center gap-2.5 text-white no-underline text-[0.98rem] motion-safe:transition-opacity motion-safe:duration-200 hover:opacity-100 opacity-84"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
              </svg>
              {CONTACT_EMAIL_DISPLAY}
            </a>
          </div>
        </div>
      </div>

      <div
        class="flex flex-col justify-between gap-6 rounded-[1.5rem] border border-white/12 bg-[linear-gradient(180deg,rgba(255,255,255,0.14),rgba(255,255,255,0.08))] p-7 shadow-[0_20px_50px_rgba(0,0,0,0.22)] lg:p-9"
      >
        <div class="flex flex-col gap-4">
          <p class="m-0 text-[0.82rem] font-semibold uppercase tracking-[0.16em] text-white/55">Start here</p>
          <h3 class="m-0 text-[1.55rem] font-bold leading-tight lg:text-[2rem]">
            Pick the path that fits what you want to do next.
          </h3>
          <p class="m-0 text-[0.98rem] leading-relaxed text-white/74">
            Reach out directly, stay up to date, or start exploring the platform on your own.
          </p>
        </div>

        <div class="flex flex-col gap-4">
          <a
            href={CONTACT_INQUIRY_MAILTO}
            class="inline-flex w-full items-center justify-center gap-3 whitespace-nowrap rounded-xl bg-[var(--color-primary)] px-8 py-4 text-base font-semibold text-white no-underline motion-safe:transition-colors duration-150 hover:bg-[#e55d10]"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            Get in touch
          </a>
          <a
            href="/product#documentation"
            class="inline-flex w-full items-center justify-center gap-3 whitespace-nowrap rounded-xl border border-white/16 bg-white px-8 py-4 text-base font-semibold text-[#111111] no-underline motion-safe:transition-colors duration-150 hover:bg-white/90"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path>
              <path d="M14 3v6h6"></path>
              <path d="M8 13h8"></path>
              <path d="M8 17h8"></path>
              <path d="M8 9h2"></path>
            </svg>
            View documentation
          </a>
          <a
            href="/register"
            class="inline-flex w-full items-center justify-center gap-3 whitespace-nowrap rounded-xl border border-white/16 bg-white/8 px-8 py-4 text-base font-semibold text-white no-underline motion-safe:transition-colors duration-150 hover:bg-white/12"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M12 5v14"></path>
              <path d="M5 12h14"></path>
            </svg>
            Try it free
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>

---
import Base from '../layouts/Base.astro';
---

<Base title="Newsletter — Dataland" description="Subscribe to the Dataland newsletter.">
  <section class="bg-[var(--color-surface-0)] py-12 lg:py-16">
    <div class="overflow-hidden bg-[#20242a]">
      <div class="mx-auto grid max-w-[1280px] lg:grid-cols-[minmax(0,0.9fr)_minmax(420px,1.1fr)]">
        <div class="px-6 py-8 lg:px-8 lg:py-10 lg:pr-10">
          <h1 class="m-0 text-left text-[2rem] font-bold leading-[1.15] text-white">Subscribe to our newsletter</h1>

          <p class="mt-3 mb-0 max-w-[30rem] text-left text-[1.06rem] leading-relaxed text-white/75 lg:text-[1.12rem]">
            Stay informed about Dataland updates, product developments, and news.
          </p>

          <form id="newsletter-form" class="mt-7 flex max-w-[30rem] flex-col gap-4.5" novalidate>
            <div class="flex flex-col gap-1.5">
              <label for="firstName" class="text-sm font-semibold text-white/80">First name</label>
              <input
                id="firstName"
                name="firstName"
                type="text"
                class="newsletter-input"
                placeholder="Your first name"
              />
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="lastName" class="text-sm font-semibold text-white/80">Last name</label>
              <input id="lastName" name="lastName" type="text" class="newsletter-input" placeholder="Your last name" />
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="company" class="text-sm font-semibold text-white/80">Company</label>
              <input id="company" name="company" type="text" class="newsletter-input" placeholder="Your company" />
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="email" class="text-sm font-semibold text-white/80">Email</label>
              <input id="email" name="email" type="email" class="newsletter-input" placeholder="Your email address" />
            </div>

            <div class="flex flex-col gap-3 pt-1 sm:flex-row sm:items-center">
              <button
                id="submit-button"
                type="submit"
                disabled
                class="inline-flex items-center justify-center rounded-md bg-[var(--color-primary)] px-8 py-2.5 text-base font-semibold text-white opacity-50 cursor-not-allowed"
              >
                Submit
              </button>

              <p id="form-message" class="m-0 text-[0.95rem] leading-relaxed text-white/80"></p>
            </div>
          </form>
        </div>

        <div class="relative flex min-h-[280px] items-center justify-end bg-[#171a1f] lg:min-h-full">
          <img
            src="/static/images/newsletter-hero.png"
            alt="Dataland newsletter illustration"
            class="h-full w-full object-contain object-right"
          />
          <div
            class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[#171a1f]/35 via-transparent to-transparent"
          >
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  import { initNewsletterForm } from '../scripts/newsletter';
  initNewsletterForm();
</script>

<style>
  .newsletter-input {
    width: 100%;
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.04);
    color: white;
    padding: 0.82rem 0.95rem;
    font-size: 0.95rem;
    outline: none;
    transition:
      border-color 0.15s,
      box-shadow 0.15s;
  }

  .newsletter-input::placeholder {
    color: rgba(255, 255, 255, 0.38);
  }

  .newsletter-input:focus {
    border-color: rgba(255, 255, 255, 0.3);
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.12);
  }

  .newsletter-input.is-error {
    border-color: #dc2626;
    box-shadow: 0 0 0 1px #dc2626;
  }

  #submit-button.is-enabled {
    opacity: 1;
    cursor: pointer;
    transition:
      background-color 0.15s,
      opacity 0.15s;
  }

  #submit-button.is-enabled:hover {
    background: var(--color-primary-hover);
  }

  #form-message.is-error {
    color: #fca5a5;
  }

  #form-message.is-success {
    color: #86efac;
  }
</style>

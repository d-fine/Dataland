---
import Base from '../layouts/Base.astro';
import PartnersSection from '../components/page-partner-stories/PartnersSection.astro';
import { COMMUNITY_GRID_ITEMS } from '../data/communityGrid';
import { PARTNERS } from '../data/about';
import { TRUSTED_BY_LOGOS } from '../data/members';
import { COMMUNITY_PAGE_CONTENT } from '../data/pageContent';
import CommunityHeroSection from '../components/page-community/CommunityHeroSection.astro';
import CommunityTrustedOrganizationsSection from '../components/page-community/CommunityTrustedOrganizationsSection.astro';
import CommunityCtaSection from '../components/page-community/CommunityCtaSection.astro';
---

<Base title={COMMUNITY_PAGE_CONTENT.meta.title} description={COMMUNITY_PAGE_CONTENT.meta.description}>
  <CommunityHeroSection content={COMMUNITY_PAGE_CONTENT.hero} items={COMMUNITY_GRID_ITEMS} />

  <CommunityTrustedOrganizationsSection
    content={COMMUNITY_PAGE_CONTENT.trustedOrganizations}
    logos={TRUSTED_BY_LOGOS}
  />

  <PartnersSection partners={PARTNERS} title={COMMUNITY_PAGE_CONTENT.partners.title} showTopAccent={false} />

  <CommunityCtaSection content={COMMUNITY_PAGE_CONTENT.cta} />
</Base>

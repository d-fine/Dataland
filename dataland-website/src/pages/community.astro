---
import Base from '../layouts/Base.astro';
import PartnersSection from '../components/PartnersSection.astro';
import { COMMUNITY_GRID_ITEMS } from '../data/communityGrid';
import { PARTNERS } from '../data/about';
import { TRUSTED_BY_LOGOS } from '../data/members';
---

<Base
  title="Community - Dataland"
  description="See how Dataland supports ESG data needs across sectors, use cases, and reporting requirements."
>
  <section
    class="px-6 pt-16 pb-12 text-white bg-[linear-gradient(90deg,#020408_0%,#08111b_24%,#142231_52%,#27435d_82%,#345877_100%)] lg:px-8 lg:pt-24 lg:pb-16"
    aria-label="Community overview"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-10">
      <div class="max-w-[900px] mx-auto text-center">
        <h1 class="m-0 text-[1.75rem] font-bold text-white">
          Dataland combines flexibility and breadth to support ESG data needs for different institution types,
          operational models, and reporting requirements.
        </h1>
      </div>

      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
        {
          COMMUNITY_GRID_ITEMS.map((item) => (
            <article class="flex h-full flex-col rounded-[1.1rem] border border-white/12 bg-[linear-gradient(180deg,rgba(255,255,255,0.12)_0%,rgba(255,255,255,0.06)_100%)] px-6 py-5 shadow-[0_10px_24px_rgba(0,0,0,0.12)] backdrop-blur-[2px]">
              <div class="mb-4 h-[3px] w-14 rounded-full bg-[var(--color-primary)]" aria-hidden="true" />
              <div class="mb-4 flex items-center gap-4 text-white/76">
                {item.icon === 'sectors' && (
                  <svg
                    width="42"
                    height="42"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    class="shrink-0"
                  >
                    <path d="M3 21h18" />
                    <path d="M5 21V8l4-3 4 3v13" />
                    <path d="M13 21V5l3-2 3 2v16" />
                    <path d="M8 11h.01" />
                    <path d="M8 15h.01" />
                    <path d="M16 9h.01" />
                    <path d="M16 13h.01" />
                  </svg>
                )}
                {item.icon === 'sizes' && (
                  <svg
                    width="42"
                    height="42"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    class="shrink-0"
                  >
                    <rect x="3" y="11" width="5" height="10" rx="1" />
                    <rect x="10" y="7" width="5" height="14" rx="1" />
                    <rect x="17" y="3" width="4" height="18" rx="1" />
                  </svg>
                )}
                {item.icon === 'use_cases' && (
                  <svg
                    width="42"
                    height="42"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    class="shrink-0"
                  >
                    <path d="M4 6h7" />
                    <path d="M4 12h10" />
                    <path d="M4 18h8" />
                    <circle cx="16" cy="6" r="2" />
                    <circle cx="19" cy="12" r="2" />
                    <circle cx="15" cy="18" r="2" />
                  </svg>
                )}
                {item.icon === 'frameworks' && (
                  <svg
                    width="42"
                    height="42"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    class="shrink-0"
                  >
                    <rect x="3" y="4" width="18" height="16" rx="2" />
                    <path d="M7 8h10" />
                    <path d="M7 12h10" />
                    <path d="M7 16h6" />
                  </svg>
                )}
                {item.icon === 'delivery' && (
                  <svg
                    width="42"
                    height="42"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    class="shrink-0"
                  >
                    <rect x="3" y="5" width="10" height="14" rx="2" />
                    <path d="M16 7h5" />
                    <path d="M16 12h5" />
                    <path d="M16 17h5" />
                  </svg>
                )}
                {item.icon === 'collaboration' && (
                  <svg
                    width="42"
                    height="42"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    class="shrink-0"
                  >
                    <path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2" />
                    <circle cx="10" cy="7" r="4" />
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                  </svg>
                )}
                <h2 class="m-0 text-[1.08rem] font-bold text-white">{item.title}</h2>
              </div>
              <p class="m-0 text-[0.98rem] leading-relaxed text-white/82">{item.text}</p>
            </article>
          ))
        }
      </div>

      <div class="flex flex-wrap justify-center gap-3">
        <a href="/product#customer-stories" class="btn btn--primary">Read Customer Stories</a>
        <a href="/product#use-cases" class="btn btn--outline">Explore Use Cases</a>
        <a href="/about#contact" class="btn btn--outline">Get in touch</a>
      </div>
    </div>
  </section>

  <section
    id="trusted-organizations"
    class="py-12 px-6 bg-[var(--color-surface-0)] lg:py-16 lg:px-8"
    aria-label="Trusted organizations"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-10">
      <div class="max-w-[760px] mx-auto text-center">
        <h2 class="text-[1.75rem] font-bold m-0 text-[var(--color-text)]">
          A community of institutions from different industries, sizes, and operating models.
        </h2>
      </div>

      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
        {
          TRUSTED_BY_LOGOS.map((logo) => (
            <div
              class:list={[
                'flex h-28 items-center justify-center rounded-[1.25rem] border border-[var(--color-surface-200)] bg-[var(--color-surface-50)] px-5 py-4 lg:h-32',
                logo.gridContainerClassName,
              ]}
            >
              <div class="flex h-[3.75rem] w-full max-w-[9.75rem] items-center justify-center lg:h-[4.25rem] lg:max-w-[10.5rem]">
                <div class:list={['flex h-full w-full items-center justify-center', logo.imageFrameClassName]}>
                  <img
                    src={logo.imagePath}
                    alt={logo.name}
                    class:list={['block max-h-full max-w-full object-contain', logo.className]}
                    style={`transform: scale(${logo.scale ?? 1}); transform-origin: center;`}
                    loading="lazy"
                    width="160"
                    height="64"
                  />
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <PartnersSection partners={PARTNERS} title="Our partners strengthen the Dataland network." showTopAccent={false} />

  <section
    class="bg-[radial-gradient(circle_at_top_left,rgba(62,106,142,0.28),transparent_34%),linear-gradient(135deg,#091119_0%,#101922_38%,#172635_72%,#21384b_100%)] px-6 py-14 text-white lg:px-8 lg:py-16"
    aria-label="Community call to action"
  >
    <div class="max-w-[1200px] mx-auto">
      <div class="flex flex-col items-center gap-10 text-center">
        <div class="flex flex-col items-center gap-4">
          <h2 class="m-0 text-[1.45rem] font-semibold leading-relaxed text-white lg:text-[1.7rem]">Interested in joining us?</h2>
          <p class="m-0 max-w-[42rem] text-[1.06rem] leading-relaxed text-white/76 lg:text-[1.12rem]">
            Talk to us about membership, partnerships, and how Dataland can support your organization.
          </p>
        </div>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/about#contact" class="btn btn--primary">Get in touch</a>
        </div>
      </div>
    </div>
  </section>
</Base>

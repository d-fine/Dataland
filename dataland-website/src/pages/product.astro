---
import Base from '../layouts/Base.astro';
import {
  HOW_IT_WORKS_BLOCKS,
  GETTING_DATA_BLOCKS,
  FEATURE_CARDS,
  USE_CASES,
  CUSTOMER_STORIES_DETAILED,
  FRAMEWORK_DOC,
  API_DOC_LINKS,
} from '../data/product';

const CREDITS_TABLE = [
  { members: '1', cost: '1' },
  { members: '2', cost: '0.5' },
  { members: '3', cost: '0.4' },
  { members: '4', cost: '0.3' },
  { members: '5-9', cost: '0.2' },
  { members: '> 10', cost: '0.1' },
];
---

<Base
  title="Product — Dataland"
  description="Explore Dataland's ESG data platform features, frameworks, use cases, and pricing."
>
  <!-- Section 1: Intro -->
  <section
    class="bg-[linear-gradient(90deg,#020408_0%,#08111b_24%,#142231_52%,#27435d_82%,#345877_100%)] px-6 pt-16 pb-12 text-white lg:px-8 lg:pt-24 lg:pb-16"
    aria-label="Product introduction"
  >
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 gap-10 lg:grid-cols-[48%_52%] lg:items-stretch">
      <div class="flex h-full flex-col lg:pr-4 lg:pt-1">
        <div class="flex flex-1 flex-col">
          <h1 class="m-0 text-[1.95rem] font-bold leading-[1.05] text-white lg:text-[2.35rem]">
            Structured, source-based sustainability data
            <br />
            <span class="text-[var(--color-primary)]">for regulatory reporting and investment analysis.</span>
          </h1>
          <div class="flex flex-1 items-center justify-center py-6">
            <div class="flex w-full max-w-[36rem] items-center justify-center gap-12 lg:gap-16" aria-hidden="true">
              <img
                src="/static/images/arrow_right_orange_simple.svg"
                alt=""
                width="30"
                height="45"
                class="h-[11rem] w-auto opacity-65 saturate-[0.45]"
              />
              <img
                src="/static/images/arrow_right_orange_simple.svg"
                alt=""
                width="30"
                height="45"
                class="h-[11rem] w-auto opacity-82 saturate-[0.72]"
              />
              <img
                src="/static/images/arrow_right_orange_simple.svg"
                alt=""
                width="30"
                height="45"
                class="h-[11rem] w-auto"
              />
            </div>
          </div>
        </div>
        <div class="mt-auto flex flex-wrap gap-3">
          <a href="/register" class="btn btn--primary">Try it free</a>
          <a href="/about#contact" class="btn btn--outline">Book a demo</a>
          <a href="/about#contact" class="btn btn--outline">Get in touch</a>
        </div>
      </div>
      <div class="flex min-h-[320px] justify-center lg:min-h-[460px] lg:justify-end">
        <img
          src="/static/images/platform-screenshot.png"
          alt="Dataland platform showing structured company-level sustainability data"
          width="720"
          height="520"
          loading="eager"
          class="h-full w-full max-w-[720px] rounded-[1.5rem] object-cover object-left shadow-[0_20px_55px_rgba(0,0,0,0.28)] lg:max-w-none"
        />
      </div>
    </div>
  </section>

  <!-- Section 2: How It Works (white) -->
  <section
    id="how-it-works"
    class="scroll-mt-16 py-12 px-6 bg-[var(--color-surface-50)] lg:py-16 lg:px-8"
    aria-label="How it works"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-10">
      <div class="max-w-[860px] mx-auto flex flex-col gap-3 text-center">
        <h2 class="text-[1.75rem] font-bold m-0 text-[var(--color-text)]">How it works</h2>
        <p class="text-[1.06rem] leading-relaxed m-0 text-[var(--color-text-muted)] lg:text-[1.12rem]">
          Access and use Dataland in the way that fits your team
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        {
          HOW_IT_WORKS_BLOCKS.map((block, index) => (
            <article class="grid h-full grid-rows-[9.6rem_minmax(6.1rem,auto)_1.1rem_minmax(6.1rem,auto)] rounded-[1.25rem] border border-[var(--color-surface-200)] border-t-4 border-t-[var(--color-primary)] bg-[var(--color-surface-warm)] px-6 py-1 shadow-[0_10px_24px_rgba(15,23,42,0.05)]">
              <div class="flex items-center justify-center">
                <img
                  src={
                    index === 0
                      ? '/static/images/img_icon_desktop.png'
                      : index === 1
                        ? '/static/images/img_icon_api.png'
                        : '/static/images/img_icon_partner.png'
                  }
                  alt=""
                  aria-hidden="true"
                  width="176"
                  height="176"
                  class:list={[
                    'object-contain [filter:brightness(0)_saturate(100%)_invert(35%)_sepia(18%)_saturate(1059%)_hue-rotate(167deg)_brightness(90%)_contrast(91%)]',
                    index === 1 ? 'h-44 w-44' : 'h-40 w-40',
                  ]}
                  loading="lazy"
                />
              </div>
              <div class="flex flex-col items-center gap-1 self-start text-center">
                <h3 class="m-0 text-[1.02rem] font-bold leading-[1.22] text-[var(--color-text)]">{block.leftTitle}</h3>
                <p class="m-0 text-[1.02rem] leading-[1.38] text-[var(--color-text-muted)]">{block.leftText}</p>
              </div>
              <div class="flex items-center justify-center self-center" aria-hidden="true">
                <div class="h-[3px] w-14 rounded-full bg-[var(--color-primary)]" />
              </div>
              <div class="flex flex-col items-center gap-1 self-start text-center pt-2">
                <h3 class="m-0 text-[1.02rem] font-bold leading-[1.22] text-[var(--color-primary)]">
                  {block.rightTitle}
                </h3>
                <p class="m-0 text-[1.02rem] leading-[1.38] text-[var(--color-text-muted)]">{block.rightText}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Section 3: Getting Data (grey) -->
  <section
    id="getting-data"
    class="scroll-mt-16 py-12 px-6 bg-[var(--color-surface-0)] lg:py-16 lg:px-8"
    aria-label="Getting data"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-10">
      <div class="max-w-[860px] mx-auto flex flex-col gap-3 text-center">
        <h2 class="text-[1.75rem] font-bold m-0 text-[var(--color-text)]">Getting the data you need</h2>
        <p class="text-[1.06rem] leading-relaxed m-0 text-[var(--color-text-muted)] lg:text-[1.12rem]">
          Members can use all data available on the platform or request additional datasets as needed.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        {
          GETTING_DATA_BLOCKS.map((block, index) => (
            <article
              class:list={[
                'grid h-full grid-rows-[3.4rem_0.7rem_1fr_2.5rem_2.5rem] rounded-xl border border-[var(--color-surface-200)] p-6 shadow-[0_8px_24px_rgba(15,23,42,0.08)] motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-[0_12px_28px_rgba(15,23,42,0.12)]',
                index === 0 ? 'bg-[var(--color-surface-warm)]' : 'bg-[var(--color-surface-cool-soft)]',
              ]}
            >
              <h3 class="m-0 self-start text-left text-[1.4rem] font-bold leading-[1.12] text-[var(--color-text)]">
                {block.title}
              </h3>
              <div class="flex items-start justify-start self-start -mt-1" aria-hidden="true">
                <div class="h-[3px] w-14 rounded-full bg-[var(--color-primary)]" />
              </div>
              <p class="m-0 self-start text-left text-[1rem] leading-relaxed text-[var(--color-text-muted)]">
                {block.text}
              </p>
              {block.highlights.map((highlight) => (
                <span class="inline-flex w-full items-center justify-start gap-1.5 self-center text-left text-[1rem] font-semibold leading-[1.3] text-[var(--color-text-muted)]">
                  <span class="inline-flex shrink-0 items-center justify-center text-[1.5rem] leading-none text-[var(--color-primary)]">
                    ✓
                  </span>
                  {highlight}
                </span>
              ))}
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Section 4: Features (white) -->
  <section
    id="features"
    class="scroll-mt-16 py-12 px-6 bg-[var(--color-brand-blue)] text-white lg:py-16 lg:px-8"
    aria-label="Platform features"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
      <div class="mx-auto flex max-w-[860px] flex-col gap-3 text-center">
        <h2 class="text-[1.75rem] font-bold m-0 text-center">Platform features</h2>
        <p class="m-0 text-[1.06rem] leading-relaxed text-white/72 lg:text-[1.12rem]">
          Core platform capabilities for accessing, managing, and exporting Dataland data in daily workflows.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          FEATURE_CARDS.map((card) => (
            <div class="flex h-full flex-col rounded-[1.1rem] border border-white/12 bg-[linear-gradient(180deg,rgba(255,255,255,0.12)_0%,rgba(255,255,255,0.06)_100%)] px-6 py-5 shadow-[0_10px_24px_rgba(0,0,0,0.12)] backdrop-blur-[2px]">
              <div class="mb-4 h-[3px] w-14 rounded-full bg-[var(--color-primary)]" aria-hidden="true" />
              <h3 class="mt-0 mb-0 text-[1.1rem] font-bold leading-[1.22] text-white">{card.title}</h3>
              <p class="mt-4 mb-0 text-[0.95rem] leading-relaxed text-white/82">{card.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Section 5: Use Cases (grey) -->
  <section
    id="use-cases"
    class="scroll-mt-16 py-12 px-6 bg-[var(--color-surface-50)] lg:py-16 lg:px-8"
    aria-label="Use cases"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
      <div class="mx-auto flex max-w-[860px] flex-col gap-3 text-center">
        <h2 class="text-[1.75rem] font-bold m-0 text-[var(--color-text)]">Use cases</h2>
        <p class="m-0 text-[1.06rem] leading-relaxed text-[var(--color-text-muted)] lg:text-[1.12rem]">
          Dataland supports different ESG data use cases across reporting, analysis, and portfolio workflows.
        </p>
      </div>
      <div class="flex flex-col gap-8">
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
          {
            USE_CASES.map((uc) => (
              <div class="grid h-full grid-rows-[4.5rem_1fr] items-start justify-items-start gap-1.5 bg-[var(--color-surface-0)] rounded-xl border border-[var(--color-surface-200)] border-t-4 border-t-[var(--color-primary)] p-6 pt-3 text-left shadow-[0_1px_4px_rgba(0,0,0,0.04)] motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-[0_4px_16px_rgba(0,0,0,0.08)]">
                <div class="grid w-full grid-cols-[5.25rem_1fr] items-center gap-3">
                  <img
                    src={uc.icon}
                    alt=""
                    aria-hidden="true"
                    width="88"
                    height="88"
                    loading="lazy"
                    class:list={[
                      'h-[5.25rem] w-[5.25rem] object-contain [filter:brightness(0)_saturate(100%)_invert(35%)_sepia(18%)_saturate(1059%)_hue-rotate(167deg)_brightness(90%)_contrast(91%)]',
                      uc.icon === '/static/images/use_cases/img_use_case_portfolio_monitoring.png' && 'scale-[1.68]',
                      uc.icon === '/static/images/use_cases/img_use_case_complement.png' && 'scale-[1.42]',
                      uc.icon === '/static/images/use_cases/img_use_case_format_update.png' &&
                        'translate-x-3 scale-[1.36]',
                    ]}
                  />
                  <h3 class="text-[1.0625rem] font-bold m-0 text-[var(--color-text)] leading-[1.18]">
                    {(uc.titleLines ?? [uc.title]).map((line) => (
                      <span class="block">{line}</span>
                    ))}
                  </h3>
                </div>
                <p class="text-[0.9375rem] leading-relaxed m-0 text-[var(--color-text-muted)]">{uc.description}</p>
              </div>
            ))
          }
        </div>
        <div class="flex flex-col gap-5 pt-2">
          <p
            class="mx-auto max-w-[760px] text-center text-[0.98rem] leading-relaxed m-0 text-[var(--color-text-muted)]"
          >
            These use cases support different business areas across the company.
          </p>
          <div class="grid grid-cols-2 gap-4 md:grid-cols-3 xl:grid-cols-6">
            <div
              class="flex min-h-[8.2rem] flex-col items-center justify-start rounded-[1.2rem] border border-[#eadbcf] bg-[#f4ece3] px-4 py-5 text-center shadow-[0_14px_26px_rgba(15,23,42,0.12)]"
            >
              <img
                src="/static/images/img_icon_badge.svg"
                alt=""
                aria-hidden="true"
                width="56"
                height="56"
                class="h-14 w-14 object-contain"
                loading="lazy"
              />
              <span class="mt-4 text-[1.05rem] font-semibold leading-[1.15] text-[#1f3143]">Regulatory<br />reporting</span>
            </div>
            <div
              class="flex min-h-[8.2rem] flex-col items-center justify-start rounded-[1.2rem] border border-[#eadbcf] bg-[#f4ece3] px-4 py-5 text-center shadow-[0_14px_26px_rgba(15,23,42,0.12)]"
            >
              <img
                src="/static/images/img_icon_invest.svg"
                alt=""
                aria-hidden="true"
                width="56"
                height="56"
                class="h-14 w-14 object-contain"
                loading="lazy"
              />
              <span class="mt-4 text-[1.05rem] font-semibold leading-[1.15] text-[#1f3143]">Investment<br />analysis</span>
            </div>
            <div
              class="flex min-h-[8.2rem] flex-col items-center justify-start rounded-[1.2rem] border border-[#eadbcf] bg-[#f4ece3] px-4 py-5 text-center shadow-[0_14px_26px_rgba(15,23,42,0.12)]"
            >
              <img
                src="/static/images/img_icon_gauge.svg"
                alt=""
                aria-hidden="true"
                width="56"
                height="56"
                class="h-14 w-14 object-contain"
                loading="lazy"
              />
              <span class="mt-4 text-[1.05rem] font-semibold leading-[1.15] text-[#1f3143]">Risk<br />management</span>
            </div>
            <div
              class="flex min-h-[8.2rem] flex-col items-center justify-start rounded-[1.2rem] border border-[#eadbcf] bg-[#f4ece3] px-4 py-5 text-center shadow-[0_14px_26px_rgba(15,23,42,0.12)]"
            >
              <img
                src="/static/images/img_icon_portfolio.svg"
                alt=""
                aria-hidden="true"
                width="56"
                height="56"
                class="h-14 w-14 object-contain"
                loading="lazy"
              />
              <span class="mt-4 text-[1.05rem] font-semibold leading-[1.15] text-[#1f3143]">Portfolio<br />management</span>
            </div>
            <div
              class="flex min-h-[8.2rem] flex-col items-center justify-start rounded-[1.2rem] border border-[#eadbcf] bg-[#f4ece3] px-4 py-5 text-center shadow-[0_14px_26px_rgba(15,23,42,0.12)]"
            >
              <img
                src="/static/images/img_icon_bars_some.svg"
                alt=""
                aria-hidden="true"
                width="56"
                height="56"
                class="h-14 w-14 object-contain"
                loading="lazy"
              />
              <span class="mt-4 text-[1.05rem] font-semibold leading-[1.15] text-[#1f3143]">Performance<br />management</span
              >
            </div>
            <div
              class="flex min-h-[8.2rem] flex-col items-center justify-start rounded-[1.2rem] border border-[#eadbcf] bg-[#f4ece3] px-4 py-5 text-center shadow-[0_14px_26px_rgba(15,23,42,0.12)]"
            >
              <img
                src="/static/images/img_icon_contact.svg"
                alt=""
                aria-hidden="true"
                width="56"
                height="56"
                class="h-14 w-14 object-contain"
                loading="lazy"
              />
              <span class="mt-4 text-[1.05rem] font-semibold leading-[1.15] text-[#1f3143]">Client<br />advisory</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 6: Customer Stories (dark blue) -->
  <section
    id="customer-stories"
    class="scroll-mt-16 py-12 px-6 bg-[var(--color-surface-0)] text-[var(--color-text)] lg:py-16 lg:px-8"
    aria-label="Customer stories"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-12">
      <div class="mx-auto flex max-w-[860px] flex-col gap-3 text-center">
        <h2 class="text-[1.75rem] font-bold m-0 text-center text-[var(--color-text)]">Customer stories</h2>
        <p class="m-0 text-[1.06rem] leading-relaxed text-[var(--color-text-muted)] lg:text-[1.12rem]">
          Real-world experiences illustrate how ESG data challenges are addressed in practice.
        </p>
      </div>
      {
        CUSTOMER_STORIES_DETAILED.map((story) => (
          <article
            id={story.anchor}
            class="grid grid-cols-1 gap-6 rounded-xl border border-[var(--color-surface-200)] border-t-4 border-t-[var(--color-primary)] bg-[var(--color-surface-0)] p-6 scroll-mt-24 shadow-[0_4px_16px_rgba(0,0,0,0.06)] lg:grid-cols-[24%_76%] lg:p-8"
          >
            <div class="flex flex-col gap-4 lg:sticky lg:top-28 lg:self-start">
              <div class="flex min-h-[8rem] items-center justify-center rounded-xl bg-[var(--color-surface-50)] px-4 py-5">
                <img
                  src={story.logo}
                  alt={`${story.anchor.toUpperCase()} logo`}
                  class:list={['h-16 w-full object-contain object-center lg:h-20', story.logoClassName]}
                  loading="lazy"
                  width="220"
                  height="80"
                />
              </div>
                <div class="flex min-h-[2.75rem] flex-wrap items-start gap-2">
                  <span class="inline-flex items-center rounded-md bg-[var(--color-primary)]/12 px-3 py-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.08em] text-[var(--color-primary)]">
                    {story.primaryTag}
                  </span>
                  {story.secondaryTags.map((tag) => (
                    <span class="inline-flex items-center rounded-md bg-[#2C4A6B]/10 px-2.5 py-1.5 text-[0.66rem] font-semibold uppercase tracking-[0.08em] text-[#2C4A6B]">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
              <div class="flex flex-col gap-4">
                <h3 class="m-0 text-xl font-bold text-[var(--color-text)]">{story.title}</h3>
                <p class="m-0 text-[0.9375rem] leading-relaxed text-[var(--color-text-muted)]">{story.summary}</p>

                <h4 class="text-base font-bold m-0 text-[var(--color-primary)]">Challenge</h4>
                <p class="m-0 text-[0.9375rem] leading-relaxed text-[var(--color-text-muted)]">{story.challenge}</p>

                <h4 class="text-base font-bold m-0 text-[var(--color-primary)]">Solution</h4>
                <p class="m-0 text-[0.9375rem] leading-relaxed text-[var(--color-text-muted)]">{story.solution}</p>

                <h4 class="text-base font-bold m-0 text-[var(--color-primary)]">Value</h4>
                <p class="m-0 text-[0.9375rem] leading-relaxed text-[var(--color-text-muted)]">{story.value}</p>

                <blockquote class="m-0 rounded-r-xl border-l-4 border-[var(--color-primary)] bg-[var(--color-surface-50)] px-6 py-5">
                  <p class="m-0 mb-3 text-[0.9375rem] italic leading-relaxed text-[var(--color-text)]">
                    &ldquo;{story.quoteText}&rdquo;
                  </p>
                  <footer class="flex flex-col gap-0.5">
                    <cite class="text-sm font-bold not-italic text-[var(--color-text)]">{story.quoteAuthor}</cite>
                    <span class="text-[0.8125rem] text-[var(--color-text-muted)]">{story.quoteRole}</span>
                  </footer>
                </blockquote>

              {story.successStorySlug && (
                <a
                  href={`/success-stories/${story.successStorySlug}`}
                  class="text-[0.9375rem] font-semibold text-[var(--color-primary)] no-underline self-start hover:underline"
                >
                  Read full story &rarr;
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Section 7: Membership & Pricing (grey) -->
  <section
    id="membership-pricing"
    class="scroll-mt-16 py-12 px-6 bg-[var(--color-brand-blue)] lg:py-20 lg:px-8"
    aria-label="Membership and pricing"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-12">
      <div class="flex flex-col items-center gap-2 text-center">
        <h2 class="text-[1.75rem] font-bold m-0 text-white">Membership and pricing</h2>
        <p class="m-0 max-w-[640px] text-[1.06rem] leading-relaxed text-white/72 lg:text-[1.12rem]">
          A straightforward membership model with transparent pricing and shared sourcing costs.
        </p>
      </div>

      <div class="flex flex-col gap-4">
        <section aria-label="Simple membership model">
          <article
            class="rounded-[1.5rem] bg-[linear-gradient(135deg,#091119_0%,#172635_72%,#21384b_100%)] px-8 py-8 text-white shadow-[0_16px_36px_rgba(15,23,42,0.14)] lg:px-10 lg:py-10"
          >
            <div class="grid grid-cols-1 gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
              <div class="flex h-full flex-col gap-5">
                <h3 class="m-0 text-[1.85rem] font-bold leading-tight">Annual membership</h3>
                <span class="text-[3.4rem] font-bold leading-none lg:text-[4.6rem]">5,000 EUR</span>
                <div class="flex flex-1 items-center justify-center pt-2" aria-hidden="true">
                  <div class="flex h-[15rem] w-full max-w-[24rem] items-center justify-center gap-8">
                    <img
                      src="/static/images/arrow_right_orange_simple.svg"
                      alt=""
                      width="30"
                      height="45"
                      class="h-full w-auto opacity-65 saturate-[0.45]"
                    />
                    <img
                      src="/static/images/arrow_right_orange_simple.svg"
                      alt=""
                      width="30"
                      height="45"
                      class="h-full w-auto opacity-82 saturate-[0.72]"
                    />
                    <img
                      src="/static/images/arrow_right_orange_simple.svg"
                      alt=""
                      width="30"
                      height="45"
                      class="h-full w-auto"
                    />
                  </div>
                </div>
              </div>
              <div class="flex flex-col gap-6">
                <p class="m-0 text-[1.08rem] leading-relaxed text-white/90">
                  For this fee, everything already available on the platform is free for all Members:
                </p>
                <div class="flex flex-col gap-5">
                  <div class="flex flex-col gap-1.5 border-l-[3px] border-[var(--color-primary)] pl-4">
                    <h3 class="m-0 text-[1rem] font-bold text-white">Free unrestricted data use</h3>
                    <p class="m-0 text-[0.95rem] leading-relaxed text-white/74">
                      All datasets available on Dataland can be accessed and used for internal purposes without
                      restrictions.
                    </p>
                  </div>
                  <div class="flex flex-col gap-1.5 border-l-[3px] border-[var(--color-primary)] pl-4">
                    <h3 class="m-0 text-[1rem] font-bold text-white">Free use of all features</h3>
                    <p class="m-0 text-[0.95rem] leading-relaxed text-white/74">
                      Current features, from download to template conversion, as well as all future features we will
                      develop, are free for all members.
                    </p>
                  </div>
                  <div class="flex flex-col gap-1.5 border-l-[3px] border-[var(--color-primary)] pl-4">
                    <h3 class="m-0 text-[1rem] font-bold text-white">On-demand sourcing</h3>
                    <p class="m-0 text-[0.95rem] leading-relaxed text-white/74">
                      Missing datasets can be requested and automatically delivered through Active Portfolio Monitoring.
                    </p>
                  </div>
                  <div class="flex flex-col gap-1.5 border-l-[3px] border-[var(--color-primary)] pl-4">
                    <h3 class="m-0 text-[1rem] font-bold text-white">100 credits</h3>
                    <p class="m-0 text-[0.95rem] leading-relaxed text-white/74">for requesting missing datasets.</p>
                  </div>
                </div>
              </div>
            </div>
          </article>
        </section>

        <section aria-label="Shared cost approach">
          <article
            class="rounded-[1.5rem] bg-[linear-gradient(135deg,#091119_0%,#172635_72%,#21384b_100%)] px-8 py-8 text-white shadow-[0_16px_36px_rgba(15,23,42,0.14)] lg:px-10 lg:py-10"
          >
            <div class="grid grid-cols-1 gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-stretch">
              <div class="flex h-full flex-col gap-5">
                <div class="flex flex-col gap-5">
                  <h3 class="m-0 text-[1.85rem] font-bold leading-tight">Shared cost approach</h3>
                  <p class="m-0 text-[1.08rem] leading-relaxed text-white/90">
                    The cost of sourcing datasets is shared among members requesting the same data.
                  </p>
                  <div class="flex flex-col gap-5">
                    <div class="flex flex-col gap-1.5 border-l-[3px] border-[var(--color-primary)] pl-4">
                      <h3 class="m-0 text-[1rem] font-bold text-white">Additional credits</h3>
                      <p class="m-0 text-[0.95rem] leading-relaxed text-white/74">
                        Members can use the credits received with their annual subscription and purchase additional
                        credits for EUR 50 per credit.
                      </p>
                    </div>
                    <div class="flex flex-col gap-1.5 border-l-[3px] border-[var(--color-primary)] pl-4">
                      <h3 class="m-0 text-[1rem] font-bold text-white">Pay only for new data</h3>
                      <p class="m-0 text-[0.95rem] leading-relaxed text-white/74">
                        Credits are only used when new data is sourced. All datasets already on the platform are
                        included at no additional cost.
                      </p>
                    </div>
                  </div>
                </div>
                <p class="m-0 pt-1 text-[0.8rem] leading-relaxed text-white/58">
                  Dataset = 1 company, 1 framework, 1 reporting period.
                </p>
              </div>
              <div class="grid h-full grid-rows-[auto_1fr] gap-5">
                <div class="invisible text-[1.85rem] font-bold leading-tight" aria-hidden="true">
                  Shared cost approach
                </div>
                <div class="flex h-full min-h-0 items-center justify-center rounded-[1.25rem] bg-white/6 px-6 py-4">
                  <div class="max-w-[24rem]">
                    <table class="w-full border-collapse text-sm">
                      <thead>
                        <tr class="border-b-2 border-white">
                          <th
                            class="px-8 py-1 text-center text-[0.86rem] font-bold uppercase tracking-[0.04em] text-white"
                            ># of Members</th
                          >
                          <th
                            class="px-8 py-1 text-center text-[0.86rem] font-bold uppercase tracking-[0.04em] text-white"
                            >Cost (Credits)</th
                          >
                        </tr>
                      </thead>
                      <tbody>
                        {
                          CREDITS_TABLE.map((row, idx) => (
                            <tr
                              class:list={[
                                'border-b border-[var(--color-surface-200)]',
                                idx === CREDITS_TABLE.length - 1 && 'border-b-0',
                              ]}
                            >
                              <td class="px-8 py-1 text-center text-[1.02rem] font-bold text-white">{row.members}</td>
                              <td class="px-8 py-1 text-center text-[1.02rem] font-bold text-white">{row.cost}</td>
                            </tr>
                          ))
                        }
                      </tbody>
                    </table>
                    <p
                      class="m-0 mt-4 text-center text-[1rem] font-semibold leading-relaxed text-[var(--color-primary)]"
                    >
                      The more members request the same company, the lower the cost per dataset.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </article>
        </section>
      </div>

      <div class="flex flex-col items-center gap-6 pt-7 text-center">
        <p class="m-0 max-w-[46rem] text-[1.45rem] font-semibold leading-relaxed text-white">
          Join now to access high-quality ESG data and be part of building a non-profit European data infrastructure.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/about#contact" class="btn btn--outline">Get in touch</a>
          <a href="/register" class="btn btn--primary">Try it free</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 8: Documentation (dark) -->
  <section
    id="documentation"
    class="scroll-mt-16 bg-[radial-gradient(circle_at_top_left,rgba(62,106,142,0.28),transparent_34%),linear-gradient(135deg,#091119_0%,#101922_38%,#172635_72%,#21384b_100%)] px-6 py-16 text-white lg:px-8 lg:py-20"
    aria-label="Documentation and API references"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col items-center gap-12">
      <div class="mx-auto flex max-w-[860px] flex-col gap-3 text-center">
        <h2 class="text-[1.75rem] font-bold m-0 text-center">Documentation</h2>
        <p class="m-0 text-[1.06rem] leading-relaxed text-white/72 lg:text-[1.12rem]">
          Technical documentation enables seamless integration and efficient use of the platform.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 w-full md:grid-cols-[1fr_1.5fr] md:items-stretch">
        <!-- Left card: Framework Guide -->
        <div
          class="relative flex flex-col justify-between gap-6 overflow-hidden rounded-[1.5rem] border border-white/10 bg-white/6 p-7 backdrop-blur-[2px] lg:p-9"
        >
          <div class="flex flex-col gap-4">
            <h3 class="text-lg font-bold m-0 text-white">Framework Guide</h3>
            <p class="min-h-[3.25rem] text-[0.98rem] leading-relaxed m-0 text-white/74">{FRAMEWORK_DOC.description}</p>
          </div>
          <img
            src="/static/logos/logo_other_GitHub_Invertocat_White.png"
            alt=""
            aria-hidden="true"
            width="200"
            height="200"
            class="pointer-events-none absolute right-8 top-[9.8rem] h-34 w-34 object-contain opacity-92 lg:right-10 lg:top-[10.8rem] lg:h-48 lg:w-48"
          />
          <a
            href={FRAMEWORK_DOC.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-[var(--color-primary)] text-sm font-semibold no-underline self-start hover:underline"
          >
            View on GitHub &rarr;
          </a>
        </div>

        <!-- Right card: API Reference -->
        <div
          class="flex flex-col justify-between gap-6 rounded-[1.5rem] border border-white/12 bg-[linear-gradient(180deg,rgba(255,255,255,0.14),rgba(255,255,255,0.08))] p-7 shadow-[0_20px_50px_rgba(0,0,0,0.22)] lg:p-9"
        >
          <div class="flex flex-col gap-4">
            <h3 class="text-lg font-bold m-0 text-white">API Reference</h3>
            <p class="min-h-[3.25rem] text-[0.98rem] leading-relaxed m-0 text-white/74">
              Interactive Swagger documentation for every Dataland service.
            </p>
          </div>
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
            {
              API_DOC_LINKS.map((doc) => (
                <a
                  href={doc.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-xl border border-white/12 bg-white/8 px-4 py-3 text-sm font-medium text-white/90 no-underline motion-safe:transition-colors motion-safe:duration-150 hover:bg-white/12 hover:text-white"
                >
                  <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-primary)] shrink-0" aria-hidden="true" />
                  {doc.label}
                </a>
              ))
            }
          </div>
        </div>
      </div>

    </div>
  </section>

  <section
    class="bg-[radial-gradient(circle_at_top_left,rgba(62,106,142,0.28),transparent_34%),linear-gradient(135deg,#091119_0%,#101922_38%,#172635_72%,#21384b_100%)] px-6 pb-10 text-white lg:px-8 lg:pb-12"
    aria-label="Documentation call to action"
  >
    <div class="max-w-[1200px] mx-auto border-t border-white/10 pt-8">
      <div class="flex flex-col items-center gap-10 text-center">
        <p class="m-0 text-[1.45rem] font-semibold leading-relaxed text-white">Ready to get started?</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a
            href="/about#contact"
            class="btn btn--outline"
            >Get in touch</a
          >
          <a
            href="/register"
            class="btn btn--primary"
            >Try it free</a
          >
        </div>
      </div>
    </div>
  </section>
</Base>

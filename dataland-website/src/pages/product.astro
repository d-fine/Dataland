---
import Base from '../layouts/Base.astro';
import {
  HOW_IT_WORKS_BLOCKS,
  GETTING_DATA_BLOCKS,
  FEATURE_CARDS,
  USE_CASES,
  CUSTOMER_STORIES_DETAILED,
  FRAMEWORK_DOC,
  API_DOC_LINKS,
  type HowItWorksBlock,
  type GettingDataBlock,
  type FeatureCard,
  type UseCase,
  type CustomerStoryDetail,
  type DocumentationLink,
} from '../data/product';
import SectionHeader from '../components/SectionHeader.astro';
import ArrowLink from '../components/ArrowLink.astro';
import CardShell from '../components/CardShell.astro';
import CtaBand from '../components/CtaBand.astro';
import InfoCard from '../components/InfoCard.astro';
import ApplicationAreaCard from '../components/ApplicationAreaCard.astro';
import AnnualMembershipPanel from '../components/AnnualMembershipPanel.astro';
import SharedCostPanel from '../components/SharedCostPanel.astro';
import TagGroup from '../components/TagGroup.astro';
import LogoPanel from '../components/LogoPanel.astro';
import QuotePanel from '../components/QuotePanel.astro';

const CREDITS_TABLE: { members: string; cost: string }[] = [
  { members: '1', cost: '1' },
  { members: '2', cost: '0.5' },
  { members: '3', cost: '0.4' },
  { members: '4', cost: '0.3' },
  { members: '5-9', cost: '0.2' },
  { members: '> 10', cost: '0.1' },
];

const APPLICATION_AREAS: { icon: string; titleLines: readonly [string, string] }[] = [
  {
    icon: '/static/images/img_icon_badge.svg',
    titleLines: ['Regulatory', 'reporting'],
  },
  {
    icon: '/static/images/img_icon_invest.svg',
    titleLines: ['Investment', 'analysis'],
  },
  {
    icon: '/static/images/img_icon_gauge.svg',
    titleLines: ['Risk', 'management'],
  },
  {
    icon: '/static/images/img_icon_portfolio.svg',
    titleLines: ['Portfolio', 'management'],
  },
  {
    icon: '/static/images/img_icon_bars_some.svg',
    titleLines: ['Performance', 'management'],
  },
  {
    icon: '/static/images/img_icon_contact.svg',
    titleLines: ['Client', 'advisory'],
  },
] as const;

const MEMBERSHIP_INCLUDED_ITEMS: {
  title: string;
  text: string;
}[] = [
  {
    title: 'Free unrestricted data use',
    text: 'All datasets available on Dataland can be accessed and used for internal purposes without restrictions.',
  },
  {
    title: 'Free use of all features',
    text: 'Current features, from download to template conversion, as well as all future features we will develop, are free for all members.',
  },
  {
    title: 'On-demand sourcing',
    text: 'Missing datasets can be requested and automatically delivered through Active Portfolio Monitoring.',
  },
  {
    title: '100 credits',
    text: 'for requesting missing datasets.',
  },
] as const;

const SHARED_COST_ITEMS: {
  title: string;
  text: string;
}[] = [
  {
    title: 'Additional credits',
    text: 'Members can use the credits received with their annual subscription and purchase additional credits for EUR 50 per credit.',
  },
  {
    title: 'Pay only for new data',
    text: 'Credits are only used when new data is sourced. All datasets already on the platform are included at no additional cost.',
  },
] as const;
---

<Base
  title="Product — Dataland"
  description="Explore Dataland's ESG data platform features, frameworks, use cases, and pricing."
>
  <!-- Section 1: Intro -->
  <section
    class="bg-[linear-gradient(90deg,#020408_0%,#08111b_24%,#142231_52%,#27435d_82%,#345877_100%)] px-6 pt-16 pb-12 text-white lg:px-8 lg:pt-24 lg:pb-16"
    aria-label="Product introduction"
  >
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 gap-10 lg:grid-cols-[48%_52%] lg:items-stretch">
      <div class="flex h-full flex-col lg:pr-4 lg:pt-1">
        <div class="flex flex-1 flex-col">
          <h1 class="page-title text-white leading-[1.05] lg:text-[2.35rem]">
            Structured, source-based sustainability data
            <br />
            <span class="text-[var(--color-primary)]">for regulatory reporting and investment analysis.</span>
          </h1>
          <div class="flex flex-1 items-center justify-center py-6">
            <div class="flex w-full max-w-[36rem] items-center justify-center gap-12 lg:gap-16" aria-hidden="true">
              <img
                src="/static/images/arrow_right_orange_simple.svg"
                alt=""
                width="30"
                height="45"
                class="h-[11rem] w-auto opacity-65 saturate-[0.45]"
              />
              <img
                src="/static/images/arrow_right_orange_simple.svg"
                alt=""
                width="30"
                height="45"
                class="h-[11rem] w-auto opacity-82 saturate-[0.72]"
              />
              <img
                src="/static/images/arrow_right_orange_simple.svg"
                alt=""
                width="30"
                height="45"
                class="h-[11rem] w-auto"
              />
            </div>
          </div>
        </div>
        <div class="mt-auto flex flex-wrap gap-3">
          <a href="/register" class="btn btn--primary">Try it free</a>
          <a href="/about#contact" class="btn btn--outline">Book a demo</a>
          <a href="/about#contact" class="btn btn--outline">Get in touch</a>
        </div>
      </div>
      <div class="flex min-h-[320px] justify-center lg:min-h-[460px] lg:justify-end">
        <img
          src="/static/images/platform-screenshot.png"
          alt="Dataland platform showing structured company-level sustainability data"
          width="720"
          height="520"
          loading="eager"
          class="h-full w-full max-w-[720px] rounded-[1.5rem] object-cover shadow-[0_20px_55px_rgba(0,0,0,0.28)] lg:max-w-none"
          style="object-position: -2px -2px;"
        />
      </div>
    </div>
  </section>

  <!-- Section 2: How It Works (white) -->
  <section
    id="how-it-works"
    class="scroll-mt-16 py-12 px-6 bg-[var(--color-surface-50)] lg:py-16 lg:px-8"
    aria-label="How it works"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-10">
      <SectionHeader
        title="How it works"
        intro="Access and use Dataland in the way that fits your team."
        class="mx-auto max-w-[860px]"
      />
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        {
          HOW_IT_WORKS_BLOCKS.map((block: HowItWorksBlock, index: number) => (
            <CardShell
              as="article"
              variant="warm"
              accentTop={true}
              class="grid h-full grid-rows-[9.6rem_minmax(6.1rem,auto)_1.1rem_minmax(6.1rem,auto)] rounded-[1.25rem] px-6 py-1 shadow-[0_10px_24px_rgba(15,23,42,0.05)]"
            >
              <div class="flex items-center justify-center">
                <img
                  src={
                    index === 0
                      ? '/static/images/img_icon_desktop.png'
                      : index === 1
                        ? '/static/images/img_icon_api.png'
                        : '/static/images/img_icon_partner.png'
                  }
                  alt=""
                  aria-hidden="true"
                  width="176"
                  height="176"
                  class:list={[
                    'object-contain [filter:brightness(0)_saturate(100%)_invert(35%)_sepia(18%)_saturate(1059%)_hue-rotate(167deg)_brightness(90%)_contrast(91%)]',
                    index === 1 ? 'h-44 w-44' : 'h-40 w-40',
                  ]}
                  loading="lazy"
                />
              </div>
              <div class="flex flex-col items-center gap-1 self-start text-center">
                <h3 class="card-title text-[var(--color-text)]">{block.leftTitle}</h3>
                <p class="card-text text-[var(--color-text-muted)]">{block.leftText}</p>
              </div>
              <div class="flex items-center justify-center self-center" aria-hidden="true">
                <div class="h-[3px] w-14 rounded-full bg-[var(--color-primary)]" />
              </div>
              <div class="flex flex-col items-center gap-1 self-start text-center pt-2">
                <h3 class="card-title text-[var(--color-primary)]">{block.rightTitle}</h3>
                <p class="card-text text-[var(--color-text-muted)]">{block.rightText}</p>
              </div>
            </CardShell>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Section 3: Getting Data (grey) -->
  <section
    id="getting-data"
    class="scroll-mt-16 py-12 px-6 bg-[var(--color-surface-0)] lg:py-16 lg:px-8"
    aria-label="Getting data"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-10">
      <SectionHeader
        title="Getting the data you need"
        intro="Members can use all data available on the platform or request additional datasets as needed."
        class="mx-auto max-w-[860px]"
      />
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        {
          GETTING_DATA_BLOCKS.map((block: GettingDataBlock, index: number) => (
            <CardShell
              as="article"
              variant={index === 0 ? 'warm' : 'cool'}
              class="grid h-full grid-rows-[3.4rem_0.7rem_1fr_2.5rem_2.5rem] rounded-xl p-6 shadow-[0_8px_24px_rgba(15,23,42,0.08)] motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-[0_12px_28px_rgba(15,23,42,0.12)]"
            >
              <h3 class="m-0 self-start text-left text-[1.45rem] font-bold leading-[1.12] text-[var(--color-text)]">
                {block.title}
              </h3>
              <div class="flex items-start justify-start self-start -mt-1" aria-hidden="true">
                <div class="h-[3px] w-14 rounded-full bg-[var(--color-primary)]" />
              </div>
              <p class="card-text self-start text-left text-[var(--color-text-muted)]">{block.text}</p>
              {block.highlights.map((highlight) => (
                <span class="inline-flex w-full items-center justify-start gap-1.5 self-center text-left text-[1rem] font-semibold leading-[1.3] text-[var(--color-text-muted)]">
                  <span class="inline-flex shrink-0 items-center justify-center text-[1.5rem] leading-none text-[var(--color-primary)]">
                    ✓
                  </span>
                  {highlight}
                </span>
              ))}
            </CardShell>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Section 4: Features (white) -->
  <section
    id="features"
    class="scroll-mt-16 py-12 px-6 bg-[var(--color-brand-blue)] text-white lg:py-16 lg:px-8"
    aria-label="Platform features"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
      <SectionHeader
        title="Platform features"
        intro="Core platform capabilities for accessing, managing, and exporting Dataland data in daily workflows."
        tone="light"
        class="mx-auto max-w-[860px]"
      />
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          FEATURE_CARDS.map((card: FeatureCard) => (
            <InfoCard variant="glass" title={card.title} titleClass="text-white" class="px-6 py-5">
              <div slot="before" class="mb-4 h-[3px] w-14 rounded-full bg-[var(--color-primary)]" aria-hidden="true" />
              <p class="card-text mt-4 text-white/82">{card.text}</p>
            </InfoCard>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Section 5: Use Cases (grey) -->
  <section
    id="use-cases"
    class="scroll-mt-16 py-12 px-6 bg-[var(--color-surface-50)] lg:py-16 lg:px-8"
    aria-label="Use cases"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
      <SectionHeader
        title="Use cases"
        intro="Dataland supports different ESG data use cases across reporting, analysis, and portfolio workflows."
        class="mx-auto max-w-[860px]"
      />
      <div class="flex flex-col gap-8">
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
          {
            USE_CASES.map((uc: UseCase) => (
              <CardShell
                class="grid h-full grid-rows-[4.5rem_1fr] items-start justify-items-start gap-1.5 rounded-xl p-6 pt-3 text-left shadow-[0_1px_4px_rgba(0,0,0,0.04)] motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-[0_4px_16px_rgba(0,0,0,0.08)]"
                accentTop={true}
              >
                <div class="grid w-full grid-cols-[5.25rem_1fr] items-center gap-3">
                  <img
                    src={uc.icon}
                    alt=""
                    aria-hidden="true"
                    width="88"
                    height="88"
                    loading="lazy"
                    class:list={[
                      'h-[5.25rem] w-[5.25rem] object-contain [filter:brightness(0)_saturate(100%)_invert(35%)_sepia(18%)_saturate(1059%)_hue-rotate(167deg)_brightness(90%)_contrast(91%)]',
                      uc.icon === '/static/product/use_cases/img_use_case_portfolio_monitoring.png' && 'scale-[1.68]',
                      uc.icon === '/static/product/use_cases/img_use_case_complement.png' && 'scale-[1.42]',
                      uc.icon === '/static/product/use_cases/img_use_case_format_update.png' &&
                        'translate-x-3 scale-[1.36]',
                    ]}
                  />
                  <h3 class="card-title text-[var(--color-text)] leading-[1.18]">
                    {(uc.titleLines ?? [uc.title]).map((line) => (
                      <span class="block">{line}</span>
                    ))}
                  </h3>
                </div>
                <p class="card-text text-[var(--color-text-muted)]">{uc.description}</p>
              </CardShell>
            ))
          }
        </div>
        <div class="flex flex-col gap-5 pt-2">
          <p
            class="mx-auto max-w-[760px] text-center text-[1.06rem] font-bold leading-relaxed m-0 text-[var(--color-text-muted)] lg:text-[1.12rem]"
          >
            These use cases support different business areas across the company.
          </p>
          <div class="grid grid-cols-2 gap-4 md:grid-cols-3 xl:grid-cols-6">
            {
              APPLICATION_AREAS.map((area) => (
                <ApplicationAreaCard icon={area.icon} titleLines={[...area.titleLines] as [string, string]} />
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 6: Customer Stories (dark blue) -->
  <section
    id="customer-stories"
    class="scroll-mt-16 py-12 px-6 bg-[var(--color-surface-0)] text-[var(--color-text)] lg:py-16 lg:px-8"
    aria-label="Customer stories"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-12">
      <SectionHeader
        title="Customer stories"
        intro="Real-world experiences illustrate how ESG data challenges are addressed in practice."
        class="mx-auto max-w-[860px]"
      />
      {
        CUSTOMER_STORIES_DETAILED.map((story: CustomerStoryDetail) => (
          <article
            id={story.anchor}
            class="grid grid-cols-1 gap-6 rounded-xl border border-[var(--color-surface-200)] border-t-4 border-t-[var(--color-primary)] bg-[var(--color-surface-0)] p-6 scroll-mt-24 shadow-[0_4px_16px_rgba(0,0,0,0.06)] lg:grid-cols-[24%_76%] lg:p-8"
          >
            <div class="flex flex-col gap-4 lg:self-start">
              <LogoPanel
                logo={story.logo}
                name={`${story.anchor.toUpperCase()} logo`}
                logoClassName={story.logoClassName}
                class="min-h-[8rem] border-0 px-4 py-5 shadow-none"
                imageClass="h-16 w-full object-contain object-center lg:h-20"
                width={220}
                height={80}
              />
              <TagGroup primaryTag={story.primaryTag} secondaryTags={story.secondaryTags} />
            </div>
            <div class="flex flex-col gap-4">
              <h3 class="card-title text-[var(--color-text)]">{story.title}</h3>
              <p class="card-text text-[var(--color-text-muted)]">{story.summary}</p>
              <h4 class="card-title text-[var(--color-primary)]">Challenge</h4>
              <p class="card-text text-[var(--color-text-muted)]">{story.challenge}</p>

              <h4 class="card-title text-[var(--color-primary)]">Solution</h4>
              <p class="card-text text-[var(--color-text-muted)]">{story.solution}</p>

              <h4 class="card-title text-[var(--color-primary)]">Value</h4>
              <p class="card-text text-[var(--color-text-muted)]">{story.value}</p>

              <QuotePanel quote={story.quoteText} author={story.quoteAuthor} role={story.quoteRole} />

              {story.successStorySlug && (
                <ArrowLink href={`/success-stories/${story.successStorySlug}`} class="self-start">
                  Read full story &rarr;
                </ArrowLink>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Section 7: Membership & Pricing (grey) -->
  <section
    id="membership-pricing"
    class="scroll-mt-16 py-12 px-6 bg-[var(--color-brand-blue)] lg:py-20 lg:px-8"
    aria-label="Membership and pricing"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-12">
      <SectionHeader
        title="Membership and pricing"
        intro="A straightforward membership model with transparent pricing and shared sourcing costs."
        tone="light"
        class="items-center text-center"
      />

      <div class="flex flex-col gap-4">
        <AnnualMembershipPanel items={MEMBERSHIP_INCLUDED_ITEMS} />
        <SharedCostPanel items={SHARED_COST_ITEMS} rows={CREDITS_TABLE} />
      </div>

      <CtaBand
        title="Join now to access high-quality ESG data and be part of building a non-profit European data infrastructure."
        titleClass="max-w-[46rem] text-white"
        class="pt-7"
      >
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/about#contact" class="btn btn--outline">Get in touch</a>
          <a href="/register" class="btn btn--primary">Try it free</a>
        </div>
      </CtaBand>
    </div>
  </section>

  <!-- Section 8: Documentation (dark) -->
  <section
    id="documentation"
    class="scroll-mt-16 bg-[radial-gradient(circle_at_top_left,rgba(62,106,142,0.28),transparent_34%),linear-gradient(135deg,#091119_0%,#101922_38%,#172635_72%,#21384b_100%)] px-6 py-16 text-white lg:px-8 lg:py-20"
    aria-label="Documentation and API references"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col items-center gap-12">
      <SectionHeader
        title="Documentation"
        intro="Technical documentation enables seamless integration and efficient use of the platform."
        tone="light"
        class="mx-auto max-w-[860px]"
      />

      <div class="grid grid-cols-1 gap-6 w-full md:grid-cols-[1fr_1.5fr] md:items-stretch">
        <!-- Left card: Framework Guide -->
        <CardShell
          variant="glass"
          class="relative flex flex-col justify-between gap-6 overflow-hidden rounded-[1.5rem] p-7 lg:p-9"
        >
          <div class="flex flex-col gap-4">
            <h3 class="card-title text-white">Framework Guide</h3>
            <p class="card-text min-h-[3.25rem] text-white/74">{FRAMEWORK_DOC.description}</p>
          </div>
          <img
            src="/static/logos/logo_other_GitHub_Invertocat_White.png"
            alt=""
            aria-hidden="true"
            width="200"
            height="200"
            class="pointer-events-none absolute right-8 top-[9.8rem] h-34 w-34 object-contain opacity-92 lg:right-10 lg:top-[10.8rem] lg:h-48 lg:w-48"
          />
          <ArrowLink href={FRAMEWORK_DOC.url} target="_blank" rel="noopener noreferrer" class="self-start">
            View on GitHub &rarr;
          </ArrowLink>
        </CardShell>

        <!-- Right card: API Reference -->
        <CardShell
          variant="glass"
          class="flex flex-col justify-between gap-6 rounded-[1.5rem] p-7 shadow-[0_20px_50px_rgba(0,0,0,0.22)] lg:p-9"
        >
          <div class="flex flex-col gap-4">
            <h3 class="card-title text-white">API Reference</h3>
            <p class="card-text min-h-[3.25rem] text-white/74">
              Interactive Swagger documentation for every Dataland service.
            </p>
          </div>
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
            {
              API_DOC_LINKS.map((doc: DocumentationLink) => (
                <a
                  href={doc.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-xl border border-white/12 bg-white/8 px-4 py-3 text-sm font-medium text-white/90 no-underline motion-safe:transition-colors motion-safe:duration-150 hover:bg-white/12 hover:text-white"
                >
                  <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-primary)] shrink-0" aria-hidden="true" />
                  {doc.label}
                </a>
              ))
            }
          </div>
        </CardShell>
      </div>
    </div>
  </section>

  <section
    class="bg-[radial-gradient(circle_at_top_left,rgba(62,106,142,0.28),transparent_34%),linear-gradient(135deg,#091119_0%,#101922_38%,#172635_72%,#21384b_100%)] px-6 pb-10 text-white lg:px-8 lg:pb-12"
    aria-label="Documentation call to action"
  >
    <div class="max-w-[1200px] mx-auto border-t border-white/10 pt-8">
      <CtaBand title="Ready to get started?" titleClass="text-white">
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/about#contact" class="btn btn--outline">Get in touch</a>
          <a href="/register" class="btn btn--primary">Try it free</a>
        </div>
      </CtaBand>
    </div>
  </section>
</Base>

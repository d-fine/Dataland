---
import Base from '../layouts/Base.astro';
import {
  HOW_IT_WORKS_BLOCKS,
  GETTING_DATA_BLOCKS,
  FEATURE_CARDS,
  USE_CASES,
  CUSTOMER_STORIES_DETAILED,
  VALUE_PROPOSITIONS,
  PRICING_CARD,
  CREDITS_VISUAL,
  FRAMEWORK_DOC,
  API_DOC_LINKS,
} from '../data/product';

const CREDITS_TABLE = [
  { members: '1', cost: '1' },
  { members: '2', cost: '0.5' },
  { members: '3', cost: '0.4' },
  { members: '4', cost: '0.3' },
  { members: '5-9', cost: '0.2' },
  { members: '> 10', cost: '0.1' },
];
---

<Base title="Product — Dataland" description="Explore Dataland's ESG data platform features, frameworks, use cases, and pricing.">

  <!-- Section 1: Intro -->
  <section class="bg-[linear-gradient(90deg,#020408_0%,#08111b_24%,#142231_52%,#27435d_82%,#345877_100%)] px-6 pt-16 pb-12 text-white lg:px-8 lg:pt-24 lg:pb-16" aria-label="Product introduction">
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 gap-10 lg:grid-cols-[48%_52%] lg:items-stretch">
      <div class="flex h-full flex-col lg:pr-4 lg:pt-1">
        <div class="flex flex-1 flex-col">
          <h1 class="m-0 text-[1.95rem] font-bold leading-[1.05] text-white lg:text-[2.35rem]">
            Structured, source-based sustainability data
            <br />
            <span class="text-[var(--color-primary)]">for regulatory reporting and investment analysis.</span>
          </h1>
          <div class="flex flex-1 items-center justify-center py-6">
            <div class="flex w-full max-w-[36rem] items-center justify-center gap-12 lg:gap-16" aria-hidden="true">
              <img src="/static/images/arrow_right_orange_simple.svg" alt="" width="30" height="45" class="h-[11rem] w-auto opacity-65 saturate-[0.45]" />
              <img src="/static/images/arrow_right_orange_simple.svg" alt="" width="30" height="45" class="h-[11rem] w-auto opacity-82 saturate-[0.72]" />
              <img src="/static/images/arrow_right_orange_simple.svg" alt="" width="30" height="45" class="h-[11rem] w-auto" />
            </div>
          </div>
        </div>
        <div class="mt-auto flex flex-wrap gap-3">
          <a href="/register" class="btn btn--primary">Try it free</a>
          <a href="/about#contact" class="btn btn--outline">Book a demo</a>
          <a href="/about#contact" class="btn btn--outline">Get in touch</a>
        </div>
      </div>
      <div class="flex min-h-[320px] justify-center lg:min-h-[460px] lg:justify-end">
        <img
          src="/static/images/platform-screenshot.png"
          alt="Dataland platform showing structured company-level sustainability data"
          width="720"
          height="520"
          loading="eager"
          class="h-full w-full max-w-[720px] rounded-[1.5rem] object-cover object-left shadow-[0_20px_55px_rgba(0,0,0,0.28)] lg:max-w-none"
        />
      </div>
    </div>
  </section>

  <!-- Section 2: How It Works (white) -->
  <section id="how-it-works" class="scroll-mt-16 py-12 px-6 bg-[var(--color-surface-50)] lg:py-16 lg:px-8" aria-label="How it works">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-10">
      <div class="max-w-[860px] mx-auto flex flex-col gap-3 text-center">
        <h2 class="text-[1.75rem] font-bold m-0 text-[var(--color-text)]">How it works</h2>
        <p class="text-[1.06rem] leading-relaxed m-0 text-[var(--color-text-muted)] lg:text-[1.12rem]">
          Access and use Dataland in the way that fits your team
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        {HOW_IT_WORKS_BLOCKS.map((block, index) => (
          <article class="grid h-full grid-rows-[9.6rem_minmax(6.1rem,auto)_3rem_minmax(6.1rem,auto)] rounded-[1.25rem] border border-[var(--color-surface-200)] bg-[linear-gradient(180deg,#eef1f4_0%,#f8f7f4_42%,#fff3ea_72%,#ffe6d6_100%)] px-6 py-1 shadow-[0_10px_24px_rgba(15,23,42,0.05)]">
            <div class="flex items-center justify-center">
              <img
                src={index === 0 ? '/static/images/img_icon_desktop.png' : index === 1 ? '/static/images/img_icon_api.png' : '/static/images/img_icon_partner.png'}
                alt=""
                aria-hidden="true"
                width="176"
                height="176"
                class:list={[
                  'object-contain [filter:brightness(0)_saturate(100%)_invert(35%)_sepia(18%)_saturate(1059%)_hue-rotate(167deg)_brightness(90%)_contrast(91%)]',
                  index === 1 ? 'h-44 w-44' : 'h-40 w-40',
                ]}
                loading="lazy"
              />
            </div>
            <div class="flex flex-col items-center gap-1 self-start text-center">
              <h3 class="m-0 text-[1.02rem] font-bold leading-[1.22] text-[var(--color-text)]">{block.leftTitle}</h3>
              <p class="m-0 text-[1.02rem] leading-[1.38] text-[var(--color-text-muted)]">{block.leftText}</p>
            </div>
            <div class="flex items-start justify-center leading-none self-start -mt-10" aria-hidden="true">
              <img src="/static/images/arrow_right_orange_simple.svg" alt="" width="34" height="34" class="rotate-90" />
            </div>
            <div class="flex flex-col items-center gap-1 self-start text-center pt-2">
              <h3 class="m-0 text-[1.02rem] font-bold leading-[1.22] text-[var(--color-primary)]">{block.rightTitle}</h3>
              <p class="m-0 text-[1.02rem] leading-[1.38] text-[var(--color-text-muted)]">{block.rightText}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 3: Getting Data (grey) -->
  <section id="getting-data" class="scroll-mt-16 py-12 px-6 bg-[var(--color-surface-0)] lg:py-16 lg:px-8" aria-label="Getting data">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-10">
      <div class="max-w-[860px] mx-auto flex flex-col gap-3 text-center">
        <h2 class="text-[1.75rem] font-bold m-0 text-[var(--color-text)]">Getting the data you need</h2>
        <p class="text-[1.06rem] leading-relaxed m-0 text-[var(--color-text-muted)] lg:text-[1.12rem]">
          Members can use all data available on the platform or request additional datasets as needed.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        {GETTING_DATA_BLOCKS.map((block, index) => (
          <article
            class:list={[
              'grid h-full grid-rows-[2.6rem_4rem_3.7rem_3rem_3rem] rounded-[1.25rem] p-6 shadow-[0_10px_24px_rgba(15,23,42,0.22)]',
              index === 0
                ? 'border-[#223b50] bg-[linear-gradient(180deg,#0f1c29_0%,#1a3042_40%,#274862_76%,#3c6788_100%)]'
                : 'border-[#4a6c86] bg-[linear-gradient(180deg,#2b455c_0%,#456783_40%,#6288a3_76%,#7ca0b8_100%)]',
            ]}
          >
            <h3 class="m-0 text-[1.08rem] font-bold leading-[1.2] text-white text-center self-start">{block.title}</h3>
            <div class="flex items-start justify-center leading-none self-start -mt-10" aria-hidden="true">
              <img src="/static/images/arrow_right_orange_simple.svg" alt="" width="34" height="34" class="rotate-90" />
            </div>
            <p class="m-0 text-[1rem] leading-relaxed text-white/82 text-center self-start">{block.text}</p>
            {block.highlights.map((highlight) => (
              <span class="flex items-center justify-center self-center w-full rounded-md bg-white/14 px-3 py-2 text-center text-[0.78rem] font-semibold uppercase tracking-[0.08em] leading-[1.3] text-white/86">
                {highlight}
              </span>
            ))}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 4: Features (white) -->
  <section id="features" class="scroll-mt-16 py-12 px-6 bg-[#2C4A6B] text-white lg:py-16 lg:px-8" aria-label="Platform features">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
      <h2 class="text-[1.75rem] font-bold m-0 text-center">Platform features</h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {FEATURE_CARDS.map((card) => (
          <div class="flex h-full flex-col rounded-[1.1rem] border border-white/12 bg-[linear-gradient(180deg,rgba(255,255,255,0.12)_0%,rgba(255,255,255,0.06)_100%)] px-6 py-5 shadow-[0_10px_24px_rgba(0,0,0,0.12)] backdrop-blur-[2px]">
            <div class="mb-4 h-[3px] w-14 rounded-full bg-[var(--color-primary)]" aria-hidden="true"></div>
            <h3 class="mt-0 mb-0 text-[1.1rem] font-bold leading-[1.22] text-white">{card.title}</h3>
            <p class="mt-4 mb-0 text-[0.95rem] leading-relaxed text-white/82">{card.text}</p>
            <span class="mt-4 inline-flex w-full items-center justify-center rounded-md bg-white/14 px-3 py-2 text-center text-[0.78rem] font-semibold uppercase tracking-[0.08em] text-white/86">
              {card.subtitle}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 5: Use Cases (grey) -->
  <section id="use-cases" class="scroll-mt-16 py-12 px-6 bg-[var(--color-surface-50)] lg:py-16 lg:px-8" aria-label="Use cases">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
      <h2 class="text-[1.75rem] font-bold m-0 text-[var(--color-text)] text-center">Use cases</h2>
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-[49.5rem_minmax(0,1fr)] lg:items-stretch">
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
          {USE_CASES.map((uc, idx) => (
            <div class="grid h-full grid-rows-[3rem_4.2rem_1fr_2.75rem] items-start justify-items-start gap-2 bg-[var(--color-surface-0)] rounded-xl border border-[var(--color-surface-200)] border-t-4 border-t-[var(--color-primary)] p-6 pt-8 text-left shadow-[0_1px_4px_rgba(0,0,0,0.04)] motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-[0_4px_16px_rgba(0,0,0,0.08)]">
              <div class="w-12 h-12 rounded-lg bg-[var(--color-primary)]/10 flex items-center justify-center shrink-0 text-[var(--color-primary)]">
                <span class="text-lg font-bold leading-none">{String(idx + 1).padStart(2, '0')}</span>
              </div>
              <h3 class="text-[1.0625rem] font-bold m-0 text-[var(--color-text)] leading-[1.22]">
                {(uc.titleLines ?? [uc.title]).map((line) => (
                  <span class="block">{line}</span>
                ))}
              </h3>
              <p class="text-[0.9375rem] leading-relaxed m-0 text-[var(--color-text-muted)]">{uc.description}</p>
              <div class="flex flex-wrap gap-2">
                {uc.tags.map((tag) => (
                  <span class="inline-flex items-center rounded-md bg-[var(--color-primary)]/12 px-3 py-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.08em] text-[var(--color-primary)]">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
        <div class="overflow-hidden border border-[var(--color-surface-200)] shadow-[0_10px_28px_rgba(15,23,42,0.08)] bg-[linear-gradient(180deg,#27435d_0%,#345877_54%,#3E6A8E_100%)] p-6 text-white">
          <div class="flex h-full min-h-[32rem] flex-col justify-between py-6">
            <div class="flex h-[6.9rem] w-full items-center justify-center border border-white/14 bg-[linear-gradient(90deg,rgba(255,255,255,0.22)_0%,rgba(255,255,255,0.14)_50%,rgba(255,255,255,0.06)_100%)] px-6 py-4 text-center shadow-[0_12px_24px_rgba(0,0,0,0.12)]">
              <span class="text-[1.15rem] font-semibold leading-[1.1] text-white">Regulatory reporting</span>
            </div>
            <div class="flex h-[6.8rem] w-full items-center justify-center border border-white/14 bg-[linear-gradient(90deg,rgba(255,255,255,0.2)_0%,rgba(255,255,255,0.13)_52%,rgba(255,255,255,0.06)_100%)] px-6 py-4 text-center shadow-[0_12px_24px_rgba(0,0,0,0.12)]">
              <span class="text-[1.15rem] font-semibold leading-[1.1] text-white">Investment analysis</span>
            </div>
            <div class="flex h-[6.7rem] w-full items-center justify-center border border-white/14 bg-[linear-gradient(90deg,rgba(255,255,255,0.18)_0%,rgba(255,255,255,0.12)_54%,rgba(255,255,255,0.05)_100%)] px-6 py-4 text-center shadow-[0_12px_24px_rgba(0,0,0,0.12)]">
              <span class="text-[1.15rem] font-semibold leading-[1.1] text-white">Risk management</span>
            </div>
            <div class="flex h-[7.1rem] w-full items-center justify-center border border-white/14 bg-[linear-gradient(90deg,rgba(255,255,255,0.16)_0%,rgba(255,255,255,0.11)_56%,rgba(255,255,255,0.05)_100%)] px-6 py-4 text-center shadow-[0_12px_24px_rgba(0,0,0,0.12)]">
              <span class="text-[1.15rem] font-semibold leading-[1.1] text-white">Portfolio management</span>
            </div>
            <div class="flex h-[7.2rem] w-full items-center justify-center border border-white/14 bg-[linear-gradient(90deg,rgba(255,255,255,0.14)_0%,rgba(255,255,255,0.1)_58%,rgba(255,255,255,0.04)_100%)] px-6 py-4 text-center shadow-[0_12px_24px_rgba(0,0,0,0.12)]">
              <span class="text-[1.15rem] font-semibold leading-[1.1] text-white">Performance management</span>
            </div>
            <div class="flex h-[6.5rem] w-full items-center justify-center border border-white/14 bg-[linear-gradient(90deg,rgba(255,255,255,0.12)_0%,rgba(255,255,255,0.09)_60%,rgba(255,255,255,0.04)_100%)] px-6 py-4 text-center shadow-[0_12px_24px_rgba(0,0,0,0.12)]">
              <span class="text-[1.15rem] font-semibold leading-[1.1] text-white">Client advisory</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 6: Customer Stories (dark blue) -->
  <section id="customer-stories" class="scroll-mt-16 py-12 px-6 bg-[#2C4A6B] text-white lg:py-16 lg:px-8" aria-label="Customer stories">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-12">
      <h2 class="text-[1.75rem] font-bold m-0 text-center">Customer stories</h2>
      {CUSTOMER_STORIES_DETAILED.map((story) => (
        <article id={story.anchor} class="grid grid-cols-1 gap-6 p-6 bg-white/10 rounded-xl scroll-mt-24 lg:grid-cols-[24%_76%] lg:p-8">
          <div class="flex flex-col gap-4 lg:sticky lg:top-28 lg:self-start">
            <div class="flex min-h-[8rem] items-center justify-center rounded-xl bg-white px-4 py-5">
              <img
                src={story.logo}
                alt={`${story.anchor.toUpperCase()} logo`}
                class:list={['h-16 w-full object-contain object-center lg:h-20', story.logoClassName]}
                loading="lazy"
                width="220"
                height="80"
              />
            </div>
            <div class="flex min-h-[2.75rem] flex-wrap items-start gap-2">
              <span class="inline-flex items-center rounded-md bg-[var(--color-primary)]/12 px-3 py-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.08em] text-[var(--color-primary)]">{story.primaryTag}</span>
              {story.secondaryTags.map((tag) => (
                <span class="inline-flex items-center rounded-md bg-white/10 px-2.5 py-1.5 text-[0.66rem] font-semibold uppercase tracking-[0.08em] text-white/85">{tag}</span>
              ))}
            </div>
          </div>
          <div class="flex flex-col gap-4">
            <h3 class="text-xl font-bold m-0">{story.title}</h3>
            <p class="text-[0.9375rem] leading-relaxed m-0 text-white/80">{story.summary}</p>

            <h4 class="text-base font-bold m-0 text-[var(--color-primary)]">Challenge</h4>
            <p class="text-[0.9375rem] leading-relaxed m-0 text-white/80">{story.challenge}</p>

            <h4 class="text-base font-bold m-0 text-[var(--color-primary)]">Solution</h4>
            <p class="text-[0.9375rem] leading-relaxed m-0 text-white/80">{story.solution}</p>

            <h4 class="text-base font-bold m-0 text-[var(--color-primary)]">Value</h4>
            <p class="text-[0.9375rem] leading-relaxed m-0 text-white/80">{story.value}</p>

            <blockquote class="bg-white/10 border-l-4 border-[var(--color-primary)] py-5 px-6 rounded-r-lg m-0">
              <p class="italic text-[0.9375rem] leading-relaxed m-0 mb-3 text-white/90">&ldquo;{story.quoteText}&rdquo;</p>
              <footer class="flex flex-col gap-0.5">
                <cite class="not-italic font-bold text-sm text-white">{story.quoteAuthor}</cite>
                <span class="text-[0.8125rem] text-white/70">{story.quoteRole}</span>
              </footer>
            </blockquote>

            {story.successStorySlug && (
              <a href={`/success-stories/${story.successStorySlug}`} class="text-[0.9375rem] font-semibold text-[var(--color-primary)] no-underline self-start hover:underline">
                Read full story &rarr;
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Section 7: Membership & Pricing (grey) -->
  <section id="membership-pricing" class="scroll-mt-16 py-12 px-6 bg-[var(--color-surface-50)] lg:py-20 lg:px-8" aria-label="Membership and pricing">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-12">

      <!-- Header with subtitle -->
      <div class="flex flex-col items-center gap-2 text-center">
        <h2 class="text-[1.75rem] font-bold m-0 text-[var(--color-text)]">Membership and pricing</h2>
        <p class="text-[0.9375rem] m-0 text-[var(--color-text-muted)] max-w-[640px]">One membership. Full platform access. The more members request the same company, the lower the cost per dataset.</p>
      </div>

      <!-- 3 value proposition cards with top accent -->
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {VALUE_PROPOSITIONS.map((vp) => (
          <div class="flex flex-col items-center gap-4 text-center p-6 pt-8 bg-[var(--color-surface-0)] rounded-xl border border-[var(--color-surface-200)] border-t-4 border-t-[var(--color-primary)] shadow-[0_1px_4px_rgba(0,0,0,0.04)] motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-[0_4px_16px_rgba(0,0,0,0.08)]">
            <div class="w-12 h-12 rounded-lg bg-[var(--color-primary)]/10 flex items-center justify-center shrink-0">
              <img src={vp.icon} alt="" aria-hidden="true" width="28" height="28" loading="lazy" />
            </div>
            <h3 class="text-[1.0625rem] font-bold m-0 text-[var(--color-text)]">{vp.title}</h3>
            <p class="text-[0.9375rem] leading-relaxed m-0 text-[var(--color-text-muted)]">{vp.text}</p>
          </div>
        ))}
      </div>

      <!-- Pricing + Credits unified card -->
      <div class="bg-[var(--color-surface-0)] rounded-xl border border-[var(--color-surface-200)] border-t-4 border-t-[var(--color-primary)] shadow-[0_2px_16px_rgba(0,0,0,0.06)] overflow-hidden flex flex-col">
        <div class="grid grid-cols-1 lg:grid-cols-2">
          <!-- Left: Pricing -->
          <div>
            <div class="bg-[#2C4A6B] px-8 py-4 flex items-center min-h-[60px]">
              <h3 class="text-lg font-bold m-0 text-white">{PRICING_CARD.title}</h3>
            </div>
            <div class="px-8 py-6 flex flex-col gap-4">
              <ul class="list-none pl-0 m-0 flex flex-col gap-3.5">
                {PRICING_CARD.items.map((item) => (
                  <li class="flex items-start gap-3 text-[0.9375rem] text-[var(--color-text)]">
                    <span class="mt-1.5 w-2 h-2 shrink-0 rounded-full bg-[var(--color-primary)]" aria-hidden="true"></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Right: Credits table -->
          <div class="border-t border-[var(--color-surface-200)] lg:border-t-0 lg:border-l flex flex-col">
            <div class="px-8 py-4 bg-[var(--color-surface-50)] flex items-center min-h-[60px]">
              <h3 class="text-[0.9375rem] font-bold m-0 text-[var(--color-text)]">{CREDITS_VISUAL.title}</h3>
            </div>
            <div class="px-8 py-6 flex flex-col gap-4 flex-1">
              <table class="w-full text-sm border-collapse">
                <thead>
                  <tr class="border-b-2 border-[#2C4A6B]">
                    <th class="py-2.5 pr-4 text-left font-semibold text-[#2C4A6B] text-xs uppercase tracking-wide"># of Members</th>
                    <th class="py-2.5 pr-4 text-left font-semibold text-[#2C4A6B] text-xs uppercase tracking-wide">Cost (Credits)</th>
                  </tr>
                </thead>
                <tbody>
                  {CREDITS_TABLE.map((row, idx) => (
                    <tr class:list={['border-b border-[var(--color-surface-200)]', idx === CREDITS_TABLE.length - 1 && 'border-b-0']}>
                      <td class="py-2.5 pr-4 text-[var(--color-text)]">{row.members}</td>
                      <td class="py-2.5 pr-4 text-[var(--color-text)] font-semibold">{row.cost}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
              <p class="text-[0.8125rem] text-[var(--color-text-muted)] m-0 mt-auto">{CREDITS_VISUAL.caption}</p>
            </div>
          </div>
        </div>

        <!-- Bottom note integrated as card footer -->
        <div class="border-t border-[var(--color-surface-200)] bg-[#2C4A6B]/[0.04] px-8 py-4 flex items-start gap-3">
          <svg class="w-5 h-5 shrink-0 mt-0.5 text-[#2C4A6B]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4m0-4h.01"></path>
          </svg>
          <p class="text-[0.875rem] text-[var(--color-text)] m-0 leading-relaxed font-medium">{PRICING_CARD.footer}</p>
        </div>
      </div>

    </div>
  </section>

  <!-- Section 8: Documentation (dark) -->
  <section
    id="documentation"
    class="scroll-mt-16 bg-[radial-gradient(circle_at_top_left,rgba(62,106,142,0.28),transparent_34%),linear-gradient(135deg,#091119_0%,#101922_38%,#172635_72%,#21384b_100%)] px-6 py-16 text-white lg:px-8 lg:py-20"
    aria-label="Documentation and API references"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col items-center gap-12">
      <h2 class="text-[1.75rem] font-bold m-0 text-center">Documentation</h2>

      <div class="grid grid-cols-1 gap-6 w-full md:grid-cols-[1fr_1.5fr] md:items-stretch">
        <!-- Left card: Framework Guide -->
        <div class="flex flex-col justify-between gap-6 rounded-[1.5rem] border border-white/10 bg-white/6 p-7 backdrop-blur-[2px] lg:p-9">
          <div class="flex flex-col gap-4">
            <h3 class="text-lg font-bold m-0 text-white">Framework Guide</h3>
            <p class="min-h-[3.25rem] text-[0.98rem] leading-relaxed m-0 text-white/74">{FRAMEWORK_DOC.description}</p>
          </div>
          <a href={FRAMEWORK_DOC.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-[var(--color-primary)] text-sm font-semibold no-underline self-start hover:underline">
            View on GitHub &rarr;
          </a>
        </div>

        <!-- Right card: API Reference -->
        <div class="flex flex-col justify-between gap-6 rounded-[1.5rem] border border-white/12 bg-[linear-gradient(180deg,rgba(255,255,255,0.14),rgba(255,255,255,0.08))] p-7 shadow-[0_20px_50px_rgba(0,0,0,0.22)] lg:p-9">
          <div class="flex flex-col gap-4">
            <h3 class="text-lg font-bold m-0 text-white">API Reference</h3>
            <p class="min-h-[3.25rem] text-[0.98rem] leading-relaxed m-0 text-white/74">Interactive Swagger documentation for every Dataland service.</p>
          </div>
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
            {API_DOC_LINKS.map((doc) => (
              <a
                href={doc.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-xl border border-white/12 bg-white/8 px-4 py-3 text-sm font-medium text-white/90 no-underline motion-safe:transition-colors motion-safe:duration-150 hover:bg-white/12 hover:text-white"
              >
                <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-primary)] shrink-0" aria-hidden="true"></span>
                {doc.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col items-center gap-5 pt-4 border-t border-white/10 w-full">
        <p class="text-[0.9375rem] text-white/50 m-0">Ready to get started?</p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/about#contact" class="inline-flex items-center px-8 py-4 bg-[var(--color-primary)] text-white font-semibold text-base rounded-xl no-underline motion-safe:transition-colors duration-150 hover:bg-[#e55d10]">Get in touch</a>
          <a href="/register" class="inline-flex items-center px-8 py-4 bg-white text-[#111111] font-semibold text-base rounded-xl no-underline motion-safe:transition-colors duration-150 hover:bg-white/90">Try it free</a>
        </div>
      </div>
    </div>
  </section>

</Base>

---
import Base from '../layouts/Base.astro';
import { WHY_US_PAIRS } from '../data/whyUs';
import { TRUSTED_BY_LOGOS } from '../data/members';
import { TESTIMONIALS } from '../data/testimonials';
import { FRAMEWORK_CARDS } from '../data/frameworks';
import { CUSTOMER_STORY_SUMMARIES } from '../data/customerStories';
import { INDEX_PAGE_CONTENT } from '../data/pageContent';
import HeroSection from '../components/index/HeroSection.astro';
import SearchSection from '../components/index/SearchSection.astro';
import WhyUsSection from '../components/index/WhyUsSection.astro';
import TrustedBySection from '../components/index/TrustedBySection.astro';
import CustomerStoriesSection from '../components/index/CustomerStoriesSection.astro';
import TestimonialsSection from '../components/index/TestimonialsSection.astro';
import FrameworksSection from '../components/index/FrameworksSection.astro';
import IndexCtaSection from '../components/index/IndexCtaSection.astro';
import LogoutModal from '../components/index/LogoutModal.astro';
---

<Base title={INDEX_PAGE_CONTENT.meta.title}>
  <HeroSection content={INDEX_PAGE_CONTENT.hero} />
  <SearchSection title={INDEX_PAGE_CONTENT.search.title} />
  <WhyUsSection content={INDEX_PAGE_CONTENT.whyUs} pairs={WHY_US_PAIRS} />
  <TrustedBySection content={INDEX_PAGE_CONTENT.trustedBy} logos={TRUSTED_BY_LOGOS} />
  <CustomerStoriesSection content={INDEX_PAGE_CONTENT.customerStories} stories={CUSTOMER_STORY_SUMMARIES} />
  <TestimonialsSection content={INDEX_PAGE_CONTENT.testimonials} testimonials={TESTIMONIALS} />
  <FrameworksSection content={INDEX_PAGE_CONTENT.frameworks} frameworks={FRAMEWORK_CARDS} />
  <IndexCtaSection content={INDEX_PAGE_CONTENT.cta} />
  <LogoutModal />
</Base>

<script>
  import { initIndexPage } from '../scripts/indexPage.ts';
  initIndexPage();
</script>

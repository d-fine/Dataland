---
import Base from '../layouts/Base.astro';
import { WHY_US_PAIRS, type ProblemSolutionPair } from '../data/whyUs';
import { TRUSTED_BY_LOGOS, type TrustedByLogo } from '../data/members';
import { TESTIMONIALS, type Testimonial } from '../data/testimonials';
import { FRAMEWORK_CARDS, type FrameworkCard } from '../data/frameworks';
import { CUSTOMER_STORY_SUMMARIES, type CustomerStorySummary } from '../data/customerStories';
import CompanySearchBar from '../components/CompanySearchBar.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ArrowLink from '../components/ArrowLink.astro';
import CardShell from '../components/CardShell.astro';
import CtaBand from '../components/CtaBand.astro';
import StoryCard from '../components/StoryCard.astro';
import InfoCard from '../components/InfoCard.astro';

const trustedByCarousel: TrustedByLogo[] = [...TRUSTED_BY_LOGOS, ...TRUSTED_BY_LOGOS];
---

<Base title="Dataland — Non-profit sustainability data">
  <!-- Section 1: Hero (grey) -->
  <section
    class="py-12 px-6 bg-[var(--color-surface-50)] lg:py-20 lg:px-8"
    aria-label="The open-source platform for structured sustainability data"
  >
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 gap-10 items-center lg:grid-cols-[50%_50%]">
      <div>
        <h1
          class="page-title mb-4 max-w-[11.5ch] leading-[1.12] tracking-[-0.03em] text-[var(--color-text)] sm:max-w-[12.5ch] sm:text-[1.9rem] lg:max-w-none lg:leading-[1.2] lg:tracking-normal"
        >
          <span class="block lg:inline lg:whitespace-nowrap">Open-source platform for</span>{' '}
          <span class="block text-[var(--color-primary)] lg:inline lg:whitespace-nowrap"
            >structured sustainability data</span
          >
        </h1>
        <p class="m-0 mb-10 text-[1.14rem] font-normal text-[var(--color-text-subtle)]">
          Non-profit. Source-based. Unrestricted use.
        </p>
        <div
          class="mb-8 flex flex-row flex-nowrap items-start gap-x-6 gap-y-4 sm:gap-x-8 lg:gap-x-10"
          aria-label="Platform statistics"
        >
          <div class="flex flex-col gap-1.5">
            <div class="relative pl-[1.35rem] text-[color:rgba(62,106,142,0.84)]">
              <span
                class="absolute left-0 top-[0.2em] text-[1.8rem] font-normal leading-none tracking-[-0.08em] opacity-65 lg:text-[2.2rem]"
                >&gt;</span
              >
              <span
                class="block whitespace-nowrap text-[2.55rem] font-normal leading-none tracking-[-0.05em] lg:text-[3.1rem]"
                >1,000</span
              >
              <span
                class="block text-[0.82rem] font-semibold uppercase tracking-[0.14em] text-[color:rgba(62,106,142,0.84)]"
                >Users</span
              >
            </div>
          </div>
          <div class="flex flex-col gap-1.5">
            <div class="relative pl-[1.35rem] text-[color:rgba(62,106,142,0.84)]">
              <span
                class="absolute left-0 top-[0.2em] text-[1.8rem] font-normal leading-none tracking-[-0.08em] opacity-65 lg:text-[2.2rem]"
                >&gt;</span
              >
              <span
                class="block whitespace-nowrap text-[2.55rem] font-normal leading-none tracking-[-0.05em] lg:text-[3.1rem]"
                >3,000</span
              >
              <span
                class="block text-[0.82rem] font-semibold uppercase tracking-[0.14em] text-[color:rgba(62,106,142,0.84)]"
                >Datasets</span
              >
            </div>
          </div>
          <div class="flex flex-col gap-1.5">
            <div class="relative pl-[1.35rem] text-[color:rgba(62,106,142,0.84)]">
              <span
                class="absolute left-0 top-[0.2em] text-[1.8rem] font-normal leading-none tracking-[-0.08em] opacity-65 lg:text-[2.2rem]"
                >&gt;</span
              >
              <span
                class="block whitespace-nowrap text-[2.55rem] font-normal leading-none tracking-[-0.05em] lg:text-[3.1rem]"
                >300,000</span
              >
              <span
                class="block text-[0.82rem] font-semibold uppercase tracking-[0.14em] text-[color:rgba(62,106,142,0.84)]"
                >Live data points</span
              >
            </div>
          </div>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="/register" class="btn btn--primary">Try it free</a>
          <a href="/about" class="btn btn--outline">More about us</a>
          <a href="/about#contact" class="btn btn--outline">Get in touch</a>
        </div>
      </div>
      <div class="hero-image-wrap flex justify-center lg:justify-end" style="perspective: 1500px;">
        <img
          src="/static/images/img_index_main_1.png"
          alt="Dataland platform showing structured ESG data for a company"
          class="w-full max-w-[620px] h-auto rounded-xl shadow-[0_8px_30px_rgba(0,0,0,0.12),0_2px_8px_rgba(0,0,0,0.06)] motion-safe:[transform:perspective(1500px)_rotateY(-3deg)_rotateX(1deg)_scale(1.2)] motion-safe:transition-transform motion-safe:duration-400 lg:motion-safe:[transform:perspective(1500px)_rotateY(-5deg)_rotateX(2deg)_scale(1.2)]"
          loading="eager"
          width="600"
          height="400"
        />
      </div>
    </div>
  </section>

  <!-- Section 2: LEI Search (dark) -->
  <section
    class="px-6 bg-[radial-gradient(circle_at_top_left,rgba(62,106,142,0.28),transparent_34%),linear-gradient(135deg,#091119_0%,#101922_38%,#172635_72%,#21384b_100%)] text-white py-14 lg:py-16"
    aria-label="Search sustainability data by company name or LEI"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col items-center justify-center gap-4">
      <h2 class="relative -top-6 text-2xl font-bold m-0 text-center">
        Search sustainability data by company name or LEI
      </h2>
      <CompanySearchBar />
    </div>
  </section>

  <!-- Section 3: Why Us (grey) -->
  <section
    id="why-us"
    class="py-12 px-6 bg-[var(--color-surface-50)] lg:py-16 lg:px-8"
    aria-label="Why financial institutions choose Dataland"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-10">
      <SectionHeader
        title="Why financial institutions choose Dataland"
        intro="It comes down to how we solve common challenges in accessing, using, and sourcing ESG data."
        class="mx-auto max-w-[860px]"
      />

      <div class="flex flex-col gap-8">
        {
          WHY_US_PAIRS.map((pair: ProblemSolutionPair) => (
            <div class="grid grid-cols-1 gap-4 overflow-hidden rounded-[1.5rem] border border-[var(--color-surface-200)] bg-[linear-gradient(90deg,#eef1f4_0%,#f8f7f4_38%,#fff3ea_70%,#ffe6d6_100%)] shadow-[0_12px_32px_rgba(15,23,42,0.06)] lg:grid-cols-[1fr_auto_1fr] lg:grid-rows-[auto_auto_auto] lg:gap-x-0 lg:gap-y-0">
              <div class="px-6 pt-4 pb-1 lg:px-7 lg:pt-5 lg:pb-1.5 lg:row-start-1 lg:col-start-1">
                <span class="text-[0.82rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-label-muted)]">
                  Common Problems
                </span>
              </div>
              <div class="px-6 pb-3 lg:px-7 lg:pb-4 lg:row-start-2 lg:col-start-1">
                <h3 class="card-title text-[var(--color-text)]">{pair.problemTitle}</h3>
              </div>
              <div class="px-6 pb-6 lg:px-7 lg:pb-7 lg:row-start-3 lg:col-start-1">
                <p class="card-text text-[var(--color-text-muted)]">{pair.problemText}</p>
              </div>
              <div
                class="hidden lg:flex lg:row-span-3 lg:col-start-2 items-center justify-center px-3"
                aria-hidden="true"
              >
                <img src="/static/images/arrow_right_orange_simple.svg" alt="" width="42" height="42" />
              </div>
              <div class="h-px bg-[var(--color-surface-200)] lg:hidden" aria-hidden="true" />
              <div class="px-6 pt-4 pb-1 lg:px-7 lg:pt-5 lg:pb-1.5 lg:row-start-1 lg:col-start-3">
                <span class="text-[0.82rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-label-warm)]">
                  Dataland Solution
                </span>
              </div>
              <div class="px-6 pb-3 lg:px-7 lg:pb-4 lg:row-start-2 lg:col-start-3">
                <h3 class="card-title text-[var(--color-primary)]">{pair.solutionTitle}</h3>
              </div>
              <div class="px-6 pb-6 lg:px-7 lg:pb-7 lg:row-start-3 lg:col-start-3">
                <p class="card-text text-[var(--color-text-muted)]">{pair.solutionText}</p>
              </div>
            </div>
          ))
        }
      </div>

      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/product#features" class="btn btn--primary">Discover platform features</a>
        <a href="/product#use-cases" class="btn btn--outline">Explore use cases</a>
        <a href="/about#contact" class="btn btn--outline">Get in touch</a>
      </div>
    </div>
  </section>

  <!-- Section 4: Trusted By (white) -->
  <section
    class="py-12 px-6 bg-[var(--color-surface-0)] lg:py-16 lg:px-8"
    aria-label="Trusted by leading financial institutions"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col items-center gap-12 lg:gap-14">
      <SectionHeader
        title="Trusted by"
        intro="A growing network of members, partners, and sponsors across Europe."
        class="mx-auto max-w-[860px]"
      />
      <div
        class="trusted-by-marquee w-full overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_10%,black_90%,transparent)]"
      >
        <div class="trusted-by-track flex w-max items-center gap-5 lg:gap-7">
          {
            trustedByCarousel.map((logo, index) => (
              <a
                href="/community#trusted-organizations"
                class:list={[
                  'flex h-28 w-52 shrink-0 items-center justify-center px-4 py-3 lg:h-32 lg:w-60 lg:px-5',
                  logo.carouselContainerClassName,
                ]}
                aria-label={`See ${logo.name} on the community page`}
              >
                <div class="flex h-[3.75rem] w-full max-w-[9.75rem] items-center justify-center lg:h-[4.25rem] lg:max-w-[10.5rem]">
                  <div class:list={['flex h-full w-full items-center justify-center', logo.imageFrameClassName]}>
                    <img
                      src={logo.imagePath}
                      alt={logo.name}
                      class:list={[
                        'block max-h-full max-w-full object-contain opacity-85 grayscale-[20%] motion-safe:transition-[opacity,filter,transform] motion-safe:duration-200 hover:opacity-100 hover:grayscale-0',
                        logo.className,
                      ]}
                      style={`transform: scale(${logo.scale ?? 1}); transform-origin: center;`}
                      loading={index < TRUSTED_BY_LOGOS.length ? 'eager' : 'lazy'}
                      width="176"
                      height="80"
                    />
                  </div>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5: Customer Stories (grey) -->
  <section
    id="customer-stories"
    class="py-12 px-6 bg-[var(--color-surface-50)]"
    aria-label="How our members use Dataland"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
      <SectionHeader
        title="How our members use Dataland"
        intro="A number of ESG data challenges are addressed across use cases in reporting, risk, and compliance."
        class="mx-auto max-w-[860px]"
      />
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {
          CUSTOMER_STORY_SUMMARIES.map((story) => (
            <CardShell
              as="a"
              href={story.link}
              variant="light"
              accentTop={true}
              class="flex h-full flex-col overflow-hidden text-[var(--color-text)] no-underline motion-safe:transition-shadow motion-safe:duration-200 hover:shadow-[0_8px_22px_rgba(15,23,42,0.12)]"
              style="background:#ecece7;"
            >
              <div class="flex min-h-[6.25rem] items-center justify-center bg-white px-6 py-5">
                <img
                  src={story.logo}
                  alt=""
                  class:list={['h-16 w-full object-contain object-center', story.logoClassName]}
                  loading="lazy"
                  width="220"
                  height="64"
                />
              </div>
              <div class="grid h-full grid-rows-[3.2rem_4.5rem_auto] gap-4 p-6">
                <div class="flex min-h-[3.2rem] flex-wrap items-start gap-2">
                  <span class="inline-flex items-center rounded-md bg-[var(--color-primary)]/12 px-3 py-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.08em] text-[var(--color-primary)]">
                    {story.primaryTag}
                  </span>
                  {story.secondaryTags.map((tag) => (
                    <span class="inline-flex items-center rounded-md bg-[var(--color-brand-blue)]/10 px-2.5 py-1.5 text-[0.66rem] font-semibold uppercase tracking-[0.08em] text-[var(--color-brand-blue)]">
                      {tag}
                    </span>
                  ))}
                </div>
                <h3 class="card-title font-medium text-[var(--color-text)]">{story.title}</h3>
                <span class="arrow-link mt-auto">Read more &rarr;</span>
              </div>
            </CardShell>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Section 6: Testimonials (dark blue) -->
  <section
    class="py-12 px-6 bg-[var(--color-brand-blue)] text-white lg:py-16 lg:px-8"
    aria-label="What our members say"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
      <SectionHeader
        title="What our members say"
        intro="Insights from members, partners, and supporters based on their experience."
        tone="light"
        class="mx-auto max-w-[860px]"
      />
      <div class="flex items-center gap-3 lg:gap-5">
        <button
          type="button"
          class="testimonial-nav inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-white/20 bg-white/10 text-white motion-safe:transition-colors motion-safe:duration-150 hover:bg-white/18 disabled:cursor-not-allowed disabled:opacity-35"
          data-direction="prev"
          aria-label="Show previous testimonials"
        >
          <span aria-hidden="true" class="text-xl leading-none">&larr;</span>
        </button>
        <div
          class="testimonial-slider flex gap-5 overflow-x-auto snap-x snap-mandatory [-webkit-overflow-scrolling:touch] pb-2 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
          data-testimonial-slider
        >
          {
            TESTIMONIALS.map((t) => (
              <blockquote class="testimonial-card shrink-0 min-w-[280px] max-w-[340px] snap-start bg-white/10 rounded-xl p-5 m-0 flex flex-col gap-3.5 sm:p-6 sm:gap-4">
                <p class="m-0 flex-1 text-[1.06rem] italic leading-[1.62] text-white/90">&ldquo;{t.quote}&rdquo;</p>
                <footer class="flex flex-col gap-0.5">
                  <cite class="not-italic text-[0.95rem] font-bold text-white">{t.author}</cite>
                  <span class="text-[0.82rem] text-white/70">{t.affiliation}</span>
                </footer>
              </blockquote>
            ))
          }
        </div>
        <button
          type="button"
          class="testimonial-nav inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-white/20 bg-white/10 text-white motion-safe:transition-colors motion-safe:duration-150 hover:bg-white/18 disabled:cursor-not-allowed disabled:opacity-35"
          data-direction="next"
          aria-label="Show next testimonials"
        >
          <span aria-hidden="true" class="text-xl leading-none">&rarr;</span>
        </button>
      </div>
      <div class="flex justify-center">
        <ArrowLink href="/testimonials">Watch member testimonials <span aria-hidden="true">&rarr;</span></ArrowLink>
      </div>
    </div>
  </section>

  <!-- Section 7: Frameworks (grey) -->
  <section
    id="frameworks"
    class="py-12 px-6 bg-[radial-gradient(circle_at_top_left,rgba(62,106,142,0.28),transparent_34%),linear-gradient(135deg,#091119_0%,#101922_38%,#172635_72%,#21384b_100%)] text-white lg:py-16 lg:px-8"
    aria-label="Frameworks on Dataland"
  >
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
      <SectionHeader
        title="Frameworks on Dataland"
        intro="The platform covers the ESG frameworks most relevant to European financial institutions."
        tone="light"
        class="mx-auto max-w-[860px]"
      />
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          FRAMEWORK_CARDS.map((fw) => (
            <InfoCard variant="glass" title={fw.title} titleClass="text-white" class="px-6 py-5">
              <div slot="before" class="mb-4 h-[3px] w-14 rounded-full bg-[var(--color-primary)]" aria-hidden="true" />
              {fw.subtitle && (
                <p class="mt-3 mb-0 text-[0.82rem] font-semibold uppercase tracking-[0.08em] text-white/72">
                  {fw.subtitle}
                </p>
              )}
              <p class="card-text mt-4 text-white/82">{fw.description}</p>
            </InfoCard>
          ))
        }
      </div>
      <div class="flex justify-center">
        <ArrowLink href="/product#customer-stories"
          >Explore how companies and investors report under these frameworks &rarr;</ArrowLink
        >
      </div>
    </div>
  </section>

  <section
    class="bg-[radial-gradient(circle_at_top_left,rgba(62,106,142,0.28),transparent_34%),linear-gradient(135deg,#091119_0%,#101922_38%,#172635_72%,#21384b_100%)] px-6 pb-10 text-white lg:px-8 lg:pb-12"
    aria-label="Index call to action"
  >
    <div class="max-w-[1200px] mx-auto border-t border-white/10 pt-8">
      <CtaBand title="Ready to get started?">
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/about#contact" class="btn btn--outline">Get in touch</a>
          <a href="/register" class="btn btn--primary">Try it free</a>
        </div>
      </CtaBand>
    </div>
  </section>

  <!-- Simple logout modal -->
  <div id="logout-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 hidden">
    <div class="bg-white rounded-xl max-w-md w-full p-6 shadow-lg text-[var(--color-text)]">
      <h2 class="mb-3 text-[1.14rem] font-bold">You’ve been logged out</h2>
      <p class="mb-6 text-[0.82rem] text-[var(--color-text-muted)]">
        Your session has been closed due to inactivity. Login to start a new session.
      </p>
      <div class="flex justify-end gap-3">
        <button type="button" id="logout-modal-close" class="btn btn--outline">Close</button>
        <a href="/login" id="login_again_on_session_modal" class="btn btn--primary">Log in again</a>
      </div>
    </div>
  </div>
</Base>

<script>
  import { initIndexPage } from '../scripts/indexPage.ts';
  initIndexPage();
</script>

<style>
  .hero-image-wrap img {
    -webkit-mask-image:
      linear-gradient(
        to right,
        transparent 0%,
        rgba(0, 0, 0, 0.45) 12%,
        rgba(0, 0, 0, 0.88) 22%,
        rgba(0, 0, 0, 1) 32%,
        rgba(0, 0, 0, 1) 68%,
        rgba(0, 0, 0, 0.88) 78%,
        rgba(0, 0, 0, 0.45) 88%,
        transparent 100%
      ),
      linear-gradient(
        to bottom,
        transparent 0%,
        rgba(0, 0, 0, 0.45) 12%,
        rgba(0, 0, 0, 0.88) 22%,
        rgba(0, 0, 0, 1) 32%,
        rgba(0, 0, 0, 1) 68%,
        rgba(0, 0, 0, 0.88) 78%,
        rgba(0, 0, 0, 0.45) 88%,
        transparent 100%
      );
    mask-image:
      linear-gradient(
        to right,
        transparent 0%,
        rgba(0, 0, 0, 0.45) 12%,
        rgba(0, 0, 0, 0.88) 22%,
        rgba(0, 0, 0, 1) 32%,
        rgba(0, 0, 0, 1) 68%,
        rgba(0, 0, 0, 0.88) 78%,
        rgba(0, 0, 0, 0.45) 88%,
        transparent 100%
      ),
      linear-gradient(
        to bottom,
        transparent 0%,
        rgba(0, 0, 0, 0.45) 12%,
        rgba(0, 0, 0, 0.88) 22%,
        rgba(0, 0, 0, 1) 32%,
        rgba(0, 0, 0, 1) 68%,
        rgba(0, 0, 0, 0.88) 78%,
        rgba(0, 0, 0, 0.45) 88%,
        transparent 100%
      );
    -webkit-mask-composite: source-in;
    mask-composite: intersect;
  }

  .trusted-by-track {
    animation: trusted-by-scroll 84s linear infinite;
  }

  .trusted-by-marquee:hover .trusted-by-track {
    animation-play-state: paused;
  }

  @keyframes trusted-by-scroll {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .trusted-by-track {
      animation: none;
    }
  }
</style>

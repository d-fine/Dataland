{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "noEmitOnError": true,

    "rootDir": "src/scripts",
    "outDir": "public/scripts",

    "lib": ["DOM", "ES2017"],
    "allowJs": false,
    "jsx": "preserve",

    /* Key bits to fix your error: */
    "skipLibCheck": true,
    "types": []
  },
  "include": ["src/scripts/**/*"],
  "exclude": ["node_modules"]
}

{
  "name": "dataland-website",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build:scripts": "tsc --project tsconfig.scripts.json",
    "build": "npm run build:scripts && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "format": "prettier --write .",
    "formatci": "prettier --check .",
    "lint": "eslint . --fix",
    "lintci": "eslint . --max-warnings 0 --no-fix",
    "typecheck": "astro check",
    "updatepackages": "npm-check-updates -u",
    "updatepackagelock": "npm update --save --include=dev && npm audit fix",
    "fixvulnerabilites": "npm audit fix",
    "checkdependencies": "depcheck --ignores='@clients/*,@e2e/*,@sharedUtils/*,@ct/*,@vue/tsconfig,axios,tsconfig-paths,eslint-plugin-*,@vue/eslint-config-*,lint-staged,@types/dompurify,@types/markdown-it'"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^6.0.0",
    "@astrojs/sitemap": "^3.3.1",
    "@astrojs/vue": "^6.0.0",
    "@dataland/shared-elements": "file:../dataland-sharedElements",
    "astro": "^6.0.0",
    "typescript": "^6.0.0",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.1",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vue/eslint-config-prettier": "10.2.0",
    "eslint": "10.2.1",
    "eslint-plugin-astro": "1.7.0",
    "eslint-plugin-cypress": "6.3.1",
    "eslint-plugin-vue": "10.8.0",
    "npm-check-updates": "22.2.0",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "tailwindcss": "4.2.4",
    "vue-eslint-parser": "10.4.0"
  }
}

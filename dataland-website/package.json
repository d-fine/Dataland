{
  "name": "dataland-website",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build:scripts": "tsc --project tsconfig.scripts.json",
    "build": "npm run build:scripts && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "format": "prettier --write .",
    "formatci": "prettier --check .",

// Config file for cypress E2E tests
{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["tests/sharedUtils/**/*","tests/e2e/**/*","build/clients/**/*","src/types/**/*"],
  "compilerOptions": {
    "isolatedModules": false,
    "baseUrl": ".",
    "target": "es5",
    "lib": [
      "es5",
      "dom"
    ],
    "types": [
      "cypress",
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@clients/*": [
        "./build/clients/*"
      ],
      "@e2e/*": [
        "./tests/e2e/*"
      ],
      "@sharedUtils/*": [
        "./tests/sharedUtils/*"
      ]
    }
  }
}

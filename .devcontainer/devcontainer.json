{
  "name": "Dataland Development",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker": {
      "dockerDashComposeVersion": "v2"
    },
    "ghcr.io/devcontainers/features/java": {
      "version": "21",
      "installGradle": "false",
      "jdkDistro": "tem"
    },
    "ghcr.io/devcontainers/features/node": {
      "version": "24"
    },
    "ghcr.io/jsburckhardt/devcontainer-features/opencode:1": {}
  },
  "postCreateCommand": "sudo sh -c 'echo \"127.0.0.1 local-dev.dataland.com dataland-admin\" >> /etc/hosts' && git config --global --add safe.directory /workspaces/dataland"
}
